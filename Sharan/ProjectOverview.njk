---
pagination:
  data: Sharan.Projects
  size: 1
  alias: project
permalink: "/Sharan/projects/{{ project.Title | slug }}/index.html"
---

{% if project.Category and project.Category.name %}
  {% set catRaw = project.Category.name %}
{% else %}
  {% set catRaw = project.Category | string %}
{% endif %}
{% set catName = catRaw | replace("_data/Sharan/Projectcategories/","") | replace("_data/Sharan/ProjectCategories/","") | replace(".json","") | replace("-"," ") | trim %}

{% if project.Status and project.Status.name %}
  {% set statusRaw = project.Status.name %}
{% else %}
  {% set statusRaw = project.Status | string %}
{% endif %}
{% set statusName = statusRaw | replace("_data/Sharan/ProjectStatus/","") | replace(".json","") | replace("-"," ") | trim %}
{% set statusSlug = statusName | lower | replace(" ","-") %}

{% set projectSlug = project.Title | slug %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ project.Title }} — {{ Sharan.AboutPage.Name }}</title>
    <meta name="description" content="{{ project.Description | striptags }}">
    <meta property="og:title" content="{{ project.Title }}">
    <meta property="og:description" content="{{ project.Description | striptags }}">
    {% if project.Pics and project.Pics.length > 0 %}
    <meta property="og:image" content="/Adit-Sahai-Sharandeep-Singh.github.io{{ project.Pics[0] }}">
    {% endif %}
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/Adit-Sahai-Sharandeep-Singh.github.io/MainCode/style.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            padding: 0 5%;
            color: #e8e8e8;
            background: #0d0a08;
        }
        h1, h2, h3, h4, h5, h6 { color: #ffffff; }
        p, span, a, li, div { color: inherit; }

        :root {
            --glass-bg: rgba(255,255,255,0.04);
            --glass-bg-strong: rgba(255,255,255,0.07);
            --glass-border: rgba(255,255,255,0.1);
            --glass-border-hover: rgba(212,160,80,0.45);
            --accent-gold: #d4a050;
            --accent-gold-dim: rgba(212,160,80,0.12);
            --accent-gold-line: rgba(212,160,80,0.3);
            --text-main: #ffffff;
            --text-muted: rgba(255,255,255,0.6);
            --text-dim: rgba(255,255,255,0.35);
        }

        body::before {
            content: '';
            position: fixed; inset: 0;
            background: radial-gradient(ellipse at 50% 0%, rgba(212,160,80,0.04) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        /* ════════════════════════════════════════════════════════
           NAV
           ════════════════════════════════════════════════════════ */
        .sp-nav-fixed-wrap {
            position: fixed; top: 20px; left: 0; right: 0; z-index: 200;
            display: flex; justify-content: center; pointer-events: none;
        }
        .sp-nav-fixed-wrap > * { pointer-events: auto; }

        .sp-nav {
            width: 100%; max-width: 1100px; margin: 0 5%;
            display: grid; grid-template-columns: auto 1fr auto;
            align-items: center; gap: 0;
            padding: 10px 18px 10px 24px;
            background: var(--glass-bg-strong);
            border: 1px solid var(--glass-border);
            border-radius: 100px;
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.03) inset;
            transition: border-color 2.5s ease-in-out, background 2.5s ease-in-out, box-shadow 0.4s ease, transform 0.45s cubic-bezier(0.22,1,0.36,1);
        }
        .sp-nav.is-scrolled {
            box-shadow: 0 10px 36px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.04) inset;
            transform: translateY(-1px) scale(0.985);
        }
        .sp-nav:hover {
            border-color: var(--glass-border-hover);
            box-shadow: 0 12px 40px rgba(0,0,0,0.7), 0 0 18px var(--accent-gold-dim);
        }
        .sp-nav-spacer { height: 76px; width: 100%; }

        .sp-nav-left { display: flex; align-items: center; gap: 10px; }
        .sp-nav-home {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700; font-size: 0.78rem;
            color: var(--text-dim);
            text-decoration: none; letter-spacing: 1px;
            transition: color 0.2s ease;
            display: flex; align-items: center; gap: 5px;
        }
        .sp-nav-home:hover { color: var(--accent-gold); }
        .sp-nav-home svg { width: 11px; height: 11px; opacity: 0.7; flex-shrink: 0; }

        .sp-nav-sep { width: 1px; height: 16px; background: var(--glass-border); }

        .sp-nav-brand {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700; font-size: 0.9rem;
            color: var(--text-main); letter-spacing: 0.3px;
        }

        .sp-nav-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--accent-gold);
            box-shadow: 0 0 8px var(--accent-gold), 0 0 16px var(--accent-gold);
            animation: navDotPulse 2s ease-in-out infinite;
            flex-shrink: 0;
        }
        @keyframes navDotPulse {
            0%,100% { transform: scale(1); opacity: 0.8; }
            50%      { transform: scale(1.5); opacity: 1; }
        }

        .sp-nav-center { display: flex; align-items: center; justify-content: center; gap: 4px; }
        .sp-nav-right  { display: flex; align-items: center; justify-content: flex-end; gap: 4px; }

        .sp-nav-link {
            font-size: 0.72rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 2px;
            color: var(--text-muted); text-decoration: none;
            padding: 8px 20px; border-radius: 100px;
            border: 1px solid transparent;
            transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
            cursor: pointer; background: none;
        }
        .sp-nav-link:hover,
        .sp-nav-link.active {
            color: var(--accent-gold);
            background: var(--accent-gold-dim);
            border-color: var(--accent-gold-line);
        }

        /* ════════════════════════════════════════════════════════
           SCROLL PROGRESS
           ════════════════════════════════════════════════════════ */
        .sp-scroll-progress {
            position: fixed; top: 0; left: 0; height: 2px; width: 0%;
            background: linear-gradient(90deg, var(--accent-gold-line), var(--accent-gold));
            box-shadow: 0 0 10px var(--accent-gold);
            z-index: 300; transition: width 0.1s ease-out;
        }

        /* ════════════════════════════════════════════════════════
           PROJECT HERO
           ════════════════════════════════════════════════════════ */
        .proj-page {
            width: 100%; max-width: 1100px;
            margin: 0 auto;
            position: relative; z-index: 1;
        }

        .proj-hero {
            padding: 28px 0 0;
            text-align: center;
            display: flex; flex-direction: column; align-items: center;
        }

        .proj-status-badge {
            display: inline-flex; align-items: center; gap: 9px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem; font-weight: 700;
            letter-spacing: 2.5px; text-transform: uppercase;
            padding: 9px 22px; border-radius: 100px;
            border: 1px solid currentColor;
            margin-bottom: 28px;
        }
        .proj-status-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: currentColor;
            box-shadow: 0 0 10px currentColor;
            animation: statusPulse 2s ease-in-out infinite;
            flex-shrink: 0;
        }
        @keyframes statusPulse {
            0%,100% { opacity: 1; transform: scale(1); }
            50%      { opacity: 0.6; transform: scale(0.85); }
        }
        .proj-status-badge[data-status="completed"] { color: #00dc82; background: rgba(0,220,130,0.08); border-color: rgba(0,220,130,0.35); }
        .proj-status-badge[data-status="concept"]    { color: #a06fff; background: rgba(160,111,255,0.08); border-color: rgba(160,111,255,0.35); }
        .proj-status-badge[data-status="ongoing"]    { color: #00b4ff; background: rgba(0,180,255,0.08); border-color: rgba(0,180,255,0.35); }
        .proj-status-badge[data-status="onhold"]     { color: #ffbe32; background: rgba(255,190,50,0.08); border-color: rgba(255,190,50,0.35); }
        .proj-status-badge[data-status="canceled"]   { color: #ff5f56; background: rgba(255,95,86,0.08); border-color: rgba(255,95,86,0.35); }

        .proj-hero-title {
            font-family: 'Playfair Display', serif;
            font-style: italic; font-weight: 700;
            font-size: clamp(2.3rem, 5.4vw, 4.1rem);
            line-height: 1.08; letter-spacing: -0.02em;
            margin-bottom: 22px;
        }
        .proj-hero-title-inner {
            background: linear-gradient(
                100deg,
                rgba(255,255,255,0.55) 0%,
                #ffffff               15%,
                var(--accent-gold)    30%,
                #ffffff               45%,
                rgba(255,255,255,0.55) 60%,
                var(--accent-gold)    75%,
                #ffffff               90%,
                rgba(255,255,255,0.55) 100%
            );
            background-size: 250% auto;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            color: #fff;
            animation: heroTitleShimmer 5s linear infinite;
        }
        @keyframes heroTitleShimmer {
            0%   { background-position: 200% center; }
            100% { background-position: -50% center; }
        }
        @supports not (-webkit-background-clip: text) {
            .proj-hero-title-inner { background: none; -webkit-text-fill-color: rgba(255,255,255,0.95); color: rgba(255,255,255,0.95); animation: none; }
        }
        @media (max-width: 768px) {
            .proj-hero-title-inner { -webkit-text-fill-color: rgba(255,255,255,0.92); }
        }

        /* ════════════════════════════════════════════════════════
           IMAGE GALLERY
           ════════════════════════════════════════════════════════ */
        .proj-gallery { margin-bottom: 56px; position: relative; }

        .proj-gallery-label {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 20px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.66rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 4px;
            color: var(--text-dim);
        }
        .proj-gallery-label::before { content: ''; width: 20px; height: 1px; background: var(--accent-gold-line); }
        .proj-gallery-label::after  { content: ''; flex: 1; height: 1px; background: var(--glass-border); }

        .proj-gallery-strip { position: relative; overflow: hidden; }

        .proj-gallery-track {
            display: flex; gap: 0;
            transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1);
            will-change: transform;
        }

        .proj-gallery-slide {
            flex: 0 0 100%;
            display: flex; align-items: center; justify-content: center;
            position: relative;
        }

        .proj-gallery-slide img {
            max-width: 100%; max-height: 460px; width: auto; height: auto;
            object-fit: contain; border-radius: 10px; display: block;
            opacity: 0; transform: scale(0.97) translateY(6px);
            transition: opacity 0.5s ease, transform 0.5s ease, filter 0.4s ease;
            filter: brightness(0.93) saturate(0.9);
            cursor: zoom-in;
        }
        .proj-gallery-slide.is-active img {
            opacity: 1; transform: scale(1) translateY(0);
            filter: brightness(1) saturate(1);
        }
        .proj-gallery-slide img:hover { filter: brightness(1.04) saturate(1.05); }

        .proj-gallery-nav {
            display: flex; align-items: center; justify-content: center;
            gap: 18px; margin-top: 20px;
        }
        .proj-gallery-btn {
            width: 36px; height: 36px; border-radius: 50%;
            border: 1px solid var(--glass-border);
            background: var(--glass-bg); color: var(--text-muted); font-size: 0.85rem;
            cursor: pointer; display: flex; align-items: center; justify-content: center;
            transition: border-color 0.25s ease, background 0.25s ease, color 0.25s ease, transform 0.2s ease;
            flex-shrink: 0;
        }
        .proj-gallery-btn:hover { border-color: var(--accent-gold); background: var(--accent-gold-dim); color: var(--accent-gold); transform: scale(1.08); }
        .proj-gallery-btn:disabled { opacity: 0.25; cursor: default; pointer-events: none; }

        .proj-gallery-indicators { display: flex; align-items: center; gap: 6px; }
        .proj-gallery-pip {
            width: 5px; height: 5px; border-radius: 50%;
            background: var(--text-dim); border: none; cursor: pointer; padding: 0;
            transition: background 0.25s ease, transform 0.25s ease, width 0.3s ease;
        }
        .proj-gallery-pip.active { background: var(--accent-gold); width: 18px; border-radius: 3px; }

        .proj-gallery-index {
            font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--text-dim);
            letter-spacing: 1.5px; min-width: 40px; text-align: center;
        }

        .proj-lightbox {
            position: fixed; inset: 0; z-index: 9000;
            background: rgba(6, 4, 2, 0.96); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
        }
        .proj-lightbox.open { opacity: 1; pointer-events: all; }
        .proj-lightbox img {
            max-width: 90vw; max-height: 88vh; object-fit: contain; border-radius: 8px;
            transform: scale(0.93) translateY(10px);
            transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .proj-lightbox.open img { transform: scale(1) translateY(0); }
        .proj-lightbox-close {
            position: fixed; top: 24px; right: 28px;
            background: var(--glass-bg-strong); border: 1px solid var(--glass-border);
            color: var(--text-muted); font-size: 1.1rem; width: 38px; height: 38px;
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            cursor: pointer; z-index: 9001;
            transition: background 0.2s ease, transform 0.25s ease, color 0.2s ease;
        }
        .proj-lightbox-close:hover { background: var(--accent-gold); color: #000; transform: rotate(90deg) scale(1.08); }

        /* ════════════════════════════════════════════════════════
           FILES / LINKS
           ════════════════════════════════════════════════════════ */
        .proj-section-label {
            display: flex; align-items: center; gap: 12px; margin-bottom: 16px;
            font-family: 'JetBrains Mono', monospace; font-size: 0.66rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 4px; color: var(--text-dim);
        }
        .proj-section-label::before { content: ''; width: 20px; height: 1px; background: var(--accent-gold-line); }
        .proj-section-label::after  { content: ''; flex: 1; height: 1px; background: var(--glass-border); }

        .proj-files { margin-bottom: 40px; }
        .files-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
        .file-card {
            display: flex; align-items: center; gap: 14px; padding: 16px 20px;
            background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px;
            text-decoration: none; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            transition: background 2.5s ease-in-out, border-color 0.3s ease, transform 0.35s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.35s ease;
            position: relative; overflow: hidden;
        }
        .file-card:hover { border-color: var(--glass-border-hover); transform: translateY(-3px) scale(1.01); box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 0 12px var(--accent-gold-dim); }
        .file-icon { width: 42px; height: 42px; border-radius: 11px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.2rem; }
        .file-icon.type-pdf { background: rgba(255,120,50,0.15); border: 1px solid rgba(255,120,50,0.35); color: #ff7c3f; }
        .file-icon.type-doc { background: rgba(30,144,255,0.15); border: 1px solid rgba(30,144,255,0.35); color: #4da6ff; }
        .file-icon.type-other { background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); color: var(--accent-gold); }
        .file-info { flex: 1; min-width: 0; }
        .file-name { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 3px; }
        .file-type-label { display: block; font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1.5px; }
        .file-arrow { color: var(--accent-gold); opacity: 0; font-size: 0.9rem; flex-shrink: 0; transition: opacity 0.25s ease, transform 0.25s ease; }
        .file-card:hover .file-arrow { opacity: 1; transform: translateX(3px); }

        .proj-links { margin-bottom: 40px; }
        .links-embed-list { display: flex; flex-direction: column; gap: 20px; }
        .link-embed-frame {
            position: relative; width: 100%; border-radius: 12px; overflow: hidden;
            border: 1px solid var(--glass-border); background: #000; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
        }
        .link-embed-frame.aspect-video { aspect-ratio: 16 / 9; }
        .link-embed-frame.aspect-twitter { aspect-ratio: unset; min-height: 220px; background: transparent; }
        .link-embed-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; display: block; }
        .link-embed-frame.aspect-twitter iframe { position: static; width: 100%; height: auto; min-height: 220px; }
        .link-embed-frame.aspect-audio { aspect-ratio: unset; height: 152px; background: transparent; }
        .link-embed-frame.aspect-audio iframe { height: 152px; }
        .link-embed-frame.aspect-spotify-large { aspect-ratio: unset; height: 380px; background: transparent; }
        .link-embed-frame.aspect-spotify-large iframe { height: 380px; }

        .link-plain-card {
            display: flex; align-items: center; gap: 16px; padding: 18px 22px;
            background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px;
            text-decoration: none; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            transition: border-color 0.3s ease, transform 0.35s cubic-bezier(0.25,1,0.5,1), box-shadow 0.35s ease;
            overflow: hidden;
        }
        .link-plain-card:hover { border-color: var(--glass-border-hover); transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.5); }
        .link-plain-icon { width: 40px; height: 40px; border-radius: 10px; background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); color: var(--accent-gold); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
        .link-plain-text { flex: 1; min-width: 0; }
        .link-plain-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 3px; }
        .link-plain-url { display: block; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .link-plain-arrow { color: var(--accent-gold); opacity: 0; font-size: 0.9rem; flex-shrink: 0; transition: opacity 0.25s ease, transform 0.25s ease; }
        .link-plain-card:hover .link-plain-arrow { opacity: 1; transform: translateX(3px); }

        .link-embed-frame::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(90deg, rgba(212,160,80,0.04) 0%, rgba(212,160,80,0.10) 50%, rgba(212,160,80,0.04) 100%);
            background-size: 200% 100%; animation: embedShimmer 1.8s ease-in-out infinite;
            z-index: 0; pointer-events: none; border-radius: inherit;
        }
        .link-embed-frame.loaded::before { display: none; }
        @keyframes embedShimmer { 0% { background-position: 200% center; } 100% { background-position: -200% center; } }

        /* ════════════════════════════════════════════════════════
           BODY
           ════════════════════════════════════════════════════════ */
        #proj-overview { scroll-margin-top: 100px; }
        #proj-media    { scroll-margin-top: 100px; }
        #proj-updates  { scroll-margin-top: 100px; }

        .proj-body-wrap { display: grid; grid-template-columns: 3px 1fr; gap: 0 32px; margin-bottom: 60px; }
        .proj-body-rail { position: relative; }
        .proj-body-rail-line {
            position: absolute; top: 0; bottom: 0; left: 0; width: 3px;
            background: linear-gradient(to bottom, transparent 0%, var(--accent-gold-line) 8%, var(--accent-gold-line) 92%, transparent 100%);
            border-radius: 2px;
        }
        .proj-body-rail-dot {
            position: sticky; top: 120px; width: 11px; height: 11px; border-radius: 50%;
            background: var(--accent-gold); border: 2px solid #0d0a08;
            box-shadow: 0 0 0 2px var(--accent-gold), 0 0 16px var(--accent-gold);
            margin-left: -4px; margin-top: 8px;
            animation: railDotGlow 2.5s ease-in-out infinite;
        }
        @keyframes railDotGlow {
            0%,100% { box-shadow: 0 0 0 2px var(--accent-gold), 0 0 12px var(--accent-gold); }
            50%      { box-shadow: 0 0 0 2px var(--accent-gold), 0 0 24px var(--accent-gold), 0 0 40px rgba(212,160,80,0.3); }
        }
        .proj-body-content { padding: 0; }
        .proj-body-eyebrow {
            display: flex; align-items: center; gap: 10px;
            font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 4px; color: var(--accent-gold);
            margin-bottom: 18px; opacity: 0.8;
        }
        .proj-body-content .article-body { font-size: 1.025rem; line-height: 1.85; color: rgba(255,255,255,0.78); }
        .proj-body-content .article-body h2, .proj-body-content .article-body h3 {
            font-family: 'Space Grotesk', sans-serif; font-weight: 600; color: var(--text-main);
            margin-top: 2em; margin-bottom: 0.6em;
        }
        .proj-body-content .article-body h2 { font-size: 1.3rem; letter-spacing: -0.01em; }
        .proj-body-content .article-body h3 { font-size: 1.1rem; }
        .proj-body-content .article-body p { margin-bottom: 1.2em; }
        .proj-body-content .article-body a { color: var(--accent-gold); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--accent-gold-line); }
        .proj-body-content .article-body a:hover { text-decoration-color: var(--accent-gold); }
        .proj-body-content .article-body code {
            font-family: 'JetBrains Mono', monospace; font-size: 0.85em;
            background: rgba(212,160,80,0.1); border: 1px solid var(--accent-gold-line);
            border-radius: 4px; padding: 1px 6px; color: var(--accent-gold);
        }
        .proj-body-content .article-body blockquote {
            border-left: 2px solid var(--accent-gold-line); margin: 1.5em 0; padding: 0.6em 1.2em;
            color: var(--text-muted); font-style: italic;
        }
        .proj-body-content .article-body ul, .proj-body-content .article-body ol { padding-left: 1.5em; margin-bottom: 1.2em; }
        .proj-body-content .article-body li { margin-bottom: 0.4em; }

        /* ════════════════════════════════════════════════════════
           UPDATES TIMELINE
           ════════════════════════════════════════════════════════ */
        .upd-list { display: flex; flex-direction: column; gap: 14px; margin-bottom: 90px; }

        .upd-item {
            display: flex; align-items: center; gap: 18px;
            padding: 20px 26px;
            background: var(--glass-bg); border: 1px solid var(--glass-border);
            border-radius: 16px; text-decoration: none; color: inherit;
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            position: relative; overflow: hidden;
            transition: border-color 0.4s ease, transform 0.5s cubic-bezier(0.22,1,0.36,1), box-shadow 0.4s ease;
        }
        .upd-item:hover {
            border-color: var(--glass-border-hover);
            transform: translateY(-3px);
            box-shadow: 0 16px 40px rgba(0,0,0,0.5), 0 0 20px var(--accent-gold-dim);
        }
        .upd-item::after {
            content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 1px;
            background: linear-gradient(90deg, transparent, var(--accent-gold), transparent);
            box-shadow: 0 0 8px var(--accent-gold);
            transition: left 0.6s cubic-bezier(0.22,1,0.36,1); opacity: 0;
        }
        .upd-item:hover::after { left: 0; opacity: 1; }

        .upd-dot {
            width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0;
            background: currentColor; box-shadow: 0 0 10px currentColor;
        }
        .upd-dot[data-status="completed"] { color: #00dc82; }
        .upd-dot[data-status="concept"]    { color: #a06fff; }
        .upd-dot[data-status="ongoing"]    { color: #00b4ff; }
        .upd-dot[data-status="onhold"]     { color: #ffbe32; }
        .upd-dot[data-status="canceled"]   { color: #ff5f56; }

        .upd-body { flex: 1; min-width: 0; }
        .upd-title {
            font-family: 'Space Grotesk', sans-serif; font-size: 1.05rem; font-weight: 600;
            color: var(--text-main); margin-bottom: 4px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .upd-desc {
            font-size: 0.82rem; color: var(--text-muted); font-weight: 300;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .upd-date {
            font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--text-dim);
            letter-spacing: 1px; flex-shrink: 0; white-space: nowrap;
        }
        .upd-arrow { color: var(--accent-gold); opacity: 0; flex-shrink: 0; transition: opacity 0.25s ease, transform 0.4s ease; }
        .upd-item:hover .upd-arrow { opacity: 1; transform: translateX(4px); }

        .upd-empty {
            text-align: center; padding: 50px 0; color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace; font-size: 0.82rem; font-style: italic;
        }

        /* ════════════════════════════════════════════════════════
           LIKES — STAMP
           ════════════════════════════════════════════════════════ */
        .proj-likes-zone {
            display: flex; align-items: center; gap: 20px; margin: 48px 0 52px; padding: 20px 28px;
            background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px;
            position: relative; overflow: hidden;
        }
        .proj-likes-zone::before {
            content: ''; position: absolute; inset: 0;
            background: radial-gradient(ellipse at 0% 50%, rgba(212,160,80,0.06) 0%, transparent 60%);
            pointer-events: none;
        }
        .proj-stamp-btn {
            position: relative; width: 56px; height: 56px; border: 2px solid var(--glass-border);
            border-radius: 12px; background: var(--glass-bg); cursor: pointer;
            display: flex; align-items: center; justify-content: center; font-size: 1.5rem; line-height: 1;
            transition: border-color 0.3s ease, background 0.3s ease, transform 0.2s ease;
            flex-shrink: 0; transform-origin: center;
        }
        .proj-stamp-btn:hover { border-color: var(--accent-gold-line); background: var(--accent-gold-dim); transform: scale(1.06); }
        .proj-stamp-btn.stamped { border-color: var(--accent-gold); background: var(--accent-gold-dim); animation: stampPop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
        .proj-stamp-btn.stamped:hover { transform: scale(1.06) rotate(-3deg); }
        @keyframes stampPop {
            0%   { transform: scale(1.0); }
            40%  { transform: scale(0.88) rotate(-4deg); }
            70%  { transform: scale(1.12) rotate(2deg); }
            100% { transform: scale(1.0); }
        }
        .proj-stamp-icon { font-size: 1.4rem; line-height: 1; transition: transform 0.2s ease; user-select: none; }
        .proj-likes-info { flex: 1; }
        .proj-likes-count {
            font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; font-weight: 700;
            color: var(--text-main); letter-spacing: -0.02em; line-height: 1; margin-bottom: 4px; display: block;
        }
        .proj-likes-label {
            font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; text-transform: uppercase;
            letter-spacing: 3px; color: var(--text-dim); display: block;
        }
        .proj-likes-sparks { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
        .proj-spark { position: absolute; width: 4px; height: 4px; border-radius: 50%; background: var(--accent-gold); opacity: 0; pointer-events: none; }

        /* ════════════════════════════════════════════════════════
           DISCUSSION
           ════════════════════════════════════════════════════════ */
        .proj-discussion { margin-bottom: 80px; border: 1px solid var(--glass-border); border-radius: 16px; overflow: hidden; }
        .proj-discussion-header { padding: 18px 28px; border-bottom: 1px solid var(--glass-border); background: rgba(255,255,255,0.03); display: flex; align-items: center; gap: 14px; }
        .proj-discussion-chrome { display: flex; gap: 7px; align-items: center; }
        .proj-chrome-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--glass-border); }
        .proj-chrome-dot:nth-child(1) { background: rgba(255,95,86,0.6); }
        .proj-chrome-dot:nth-child(2) { background: rgba(255,189,46,0.6); }
        .proj-chrome-dot:nth-child(3) { background: rgba(39,201,63,0.6); }
        .proj-discussion-title { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 700; color: var(--text-dim); letter-spacing: 3px; text-transform: uppercase; margin: 0; }
        .proj-discussion-count { margin-left: auto; font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--text-dim); letter-spacing: 1px; }
        .proj-discussion-body { padding: 28px; }

        .proj-comment-compose { background: rgba(0,0,0,0.3); border: 1px solid var(--glass-border); border-radius: 12px; padding: 20px; margin-bottom: 32px; transition: border-color 0.3s ease; }
        .proj-comment-compose:focus-within { border-color: var(--accent-gold-line); }
        .proj-compose-row { display: grid; grid-template-columns: auto 1fr; gap: 14px; align-items: flex-start; }
        .proj-compose-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); display: flex; align-items: center; justify-content: center; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--accent-gold); font-weight: 700; flex-shrink: 0; }
        .proj-compose-fields { flex: 1; min-width: 0; }
        .proj-compose-name { width: 100%; background: transparent; border: none; border-bottom: 1px solid var(--glass-border); color: var(--text-main); font-family: 'Space Grotesk', sans-serif; font-size: 0.88rem; font-weight: 600; padding: 6px 0 8px; margin-bottom: 12px; outline: none; transition: border-color 0.2s ease; }
        .proj-compose-name::placeholder { color: var(--text-dim); font-weight: 400; }
        .proj-compose-name:focus { border-color: var(--accent-gold-line); }
        .proj-compose-text { width: 100%; background: transparent; border: none; color: rgba(255,255,255,0.75); font-family: 'Inter', sans-serif; font-size: 0.92rem; line-height: 1.65; padding: 0; outline: none; resize: none; min-height: 70px; }
        .proj-compose-text::placeholder { color: var(--text-dim); }
        .proj-compose-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--glass-border); }
        .proj-compose-chars { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--text-dim); letter-spacing: 1px; }
        .proj-compose-submit { font-family: 'Space Grotesk', sans-serif; font-size: 0.78rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #0d0a08; background: var(--accent-gold); border: none; border-radius: 100px; padding: 9px 22px; cursor: pointer; transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease; }
        .proj-compose-submit:hover { background: #e0b060; transform: translateY(-1px); box-shadow: 0 6px 18px rgba(212,160,80,0.35); }
        .proj-compose-submit:disabled { opacity: 0.5; cursor: default; transform: none; box-shadow: none; }
        .proj-compose-error { font-size: 0.78rem; color: #ff7070; margin-top: 10px; min-height: 18px; font-family: 'JetBrains Mono', monospace; }

        .proj-comments-list { display: flex; flex-direction: column; gap: 0; }
        .proj-comment-item { padding: 22px 0; border-bottom: 1px solid rgba(255,255,255,0.04); display: grid; grid-template-columns: 38px 1fr; gap: 14px; opacity: 0; transform: translateY(8px); animation: commentAppear 0.4s ease forwards; }
        .proj-comment-item:last-child { border-bottom: none; }
        @keyframes commentAppear { to { opacity: 1; transform: translateY(0); } }
        .proj-comment-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--glass-bg-strong); border: 1px solid var(--glass-border); display: flex; align-items: center; justify-content: center; font-family: 'Space Grotesk', sans-serif; font-size: 0.88rem; font-weight: 700; color: var(--text-muted); flex-shrink: 0; }
        .proj-comment-right { min-width: 0; }
        .proj-comment-meta { display: flex; align-items: baseline; gap: 10px; margin-bottom: 8px; }
        .proj-comment-author { font-family: 'Space Grotesk', sans-serif; font-size: 0.88rem; font-weight: 600; color: var(--text-main); }
        .proj-comment-date { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--text-dim); letter-spacing: 0.5px; }
        .proj-comment-text { font-size: 0.9rem; line-height: 1.7; color: rgba(255,255,255,0.65); margin: 0 0 12px; }
        .proj-comment-actions { display: flex; align-items: center; gap: 12px; }
        .proj-comment-like-btn { display: flex; align-items: center; gap: 5px; font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--text-dim); background: none; border: none; cursor: pointer; padding: 3px 8px; border-radius: 6px; transition: color 0.2s ease, background 0.2s ease; letter-spacing: 0.5px; }
        .proj-comment-like-btn:hover, .proj-comment-like-btn.liked { color: var(--accent-gold); background: var(--accent-gold-dim); }
        .proj-clheart { font-size: 0.75rem; }
        .proj-comment-delete-btn { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: rgba(255,100,100,0.45); background: none; border: none; cursor: pointer; padding: 3px 8px; border-radius: 6px; transition: color 0.2s ease, background 0.2s ease; letter-spacing: 0.5px; }
        .proj-comment-delete-btn:hover { color: #ff7070; background: rgba(255,70,70,0.08); }
        .proj-no-comments { text-align: center; padding: 40px 20px; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; letter-spacing: 1.5px; }
        .proj-no-comments::before { content: '// '; color: var(--accent-gold-line); }
        .proj-comments-loading { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 32px; }
        .proj-loading-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent-gold-line); animation: projLoadPulse 1.2s ease-in-out infinite; }
        .proj-loading-dot:nth-child(2) { animation-delay: 0.2s; }
        .proj-loading-dot:nth-child(3) { animation-delay: 0.4s; }
        @keyframes projLoadPulse { 0%,100% { transform: scale(0.7); opacity: 0.4; } 50% { transform: scale(1.2); opacity: 1; } }

        /* ════════════════════════════════════════════════════════
           FOOTER
           ════════════════════════════════════════════════════════ */
        .sp-footer { text-align: center; padding: 40px 24px; border-top: 1px solid var(--glass-border); color: var(--text-dim); font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; font-family: 'JetBrains Mono', monospace; max-width: 1100px; margin: 60px auto 0; }
        .sp-footer a { color: var(--accent-gold); text-decoration: none; }

        @media (max-width: 768px) {
            body { padding: 0 4%; }
            .sp-nav-fixed-wrap { padding: 0 4%; }
            .sp-nav { grid-template-columns: auto 1fr; margin: 0; }
            .sp-nav-center { display: none; }
            .proj-body-wrap { grid-template-columns: 3px 1fr; gap: 0 20px; }
            .proj-gallery-slide img { max-height: 280px; }
            .upd-item { flex-wrap: wrap; gap: 8px 14px; }
            .upd-date { order: 3; width: 100%; }
        }

        @media (prefers-reduced-motion: reduce) {
            html { scroll-behavior: auto; }
            .proj-gallery-slide img { transition: opacity 0.3s ease; }
            .proj-gallery-track { transition: none; }
        }
    </style>
</head>
<body>
    <div class="progress-bar sp-scroll-progress" id="progressBar"></div>
    <div id="bg-canvas"></div>
    <div id="bg-pattern"></div>
    <div id="bg-dots"></div>

    <div class="sp-nav-fixed-wrap">
        <nav class="sp-nav" id="spNav">
            <div class="sp-nav-left">
                <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Sharan/SharanPage.html#projects" class="sp-nav-home">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    Back
                </a>
                <div class="sp-nav-sep"></div>
                <div class="sp-nav-dot"></div>
                <span class="sp-nav-brand">{{ Sharan.SiteHeader.PageTitle }}</span>
            </div>

            <div class="sp-nav-center">
                <button class="sp-nav-link" id="navOverview" onclick="scrollToSection('proj-overview')">Overview</button>
                <button class="sp-nav-link" id="navMedia"    onclick="scrollToSection('proj-media')">Media</button>
                <button class="sp-nav-link" id="navUpdates"  onclick="scrollToSection('proj-updates')">Updates</button>
            </div>

            <div class="sp-nav-right"></div>
        </nav>
    </div>
    <div class="sp-nav-spacer"></div>

    <div class="proj-page">

        <!-- ── Hero ──────────────────────────────────────────────── -->
        <div class="proj-hero">
            <h1 class="proj-hero-title reveal-heading">
                <span class="proj-hero-title-inner">{{ project.Title }}</span>
            </h1>

            <div class="article-hero-meta reveal">
                {% if catName and catName != "undefined" and catName != "" %}
                <span class="category">{{ catName }}</span>
                <span class="meta-dot"></span>
                {% endif %}
                <span class="date">{{ project.StartedDate }}</span>
                {% if project.LastUpdated %}
                <span class="meta-dot"></span>
                <span class="date">Updated {{ project.LastUpdated }}</span>
                {% endif %}
            </div>

            <div class="proj-status-badge reveal" data-status="{{ statusSlug }}">
                <span class="proj-status-dot"></span>
                {{ statusName }}
            </div>

            <div class="article-title-rule reveal scale-in"><span>✦</span></div>
            <p class="article-lead reveal blur-in">{{ project.Description | safe }}</p>
        </div>

        <div class="article-divider reveal"><div class="article-divider-icon">· · ·</div></div>

        <!-- ══ OVERVIEW / BODY ══════════════════════════════════════ -->
        <div id="proj-overview">
            <div class="proj-body-wrap reveal">
                <div class="proj-body-rail">
                    <div class="proj-body-rail-line"></div>
                    <div class="proj-body-rail-dot"></div>
                </div>
                <div class="proj-body-content">
                    <div class="proj-body-eyebrow">Project Brief</div>
                    <div class="article-body">
                        {{ project.Body | safe }}
                    </div>
                </div>
            </div>
        </div>

        <!-- ══ MEDIA ══════════════════════════════════════════════ -->
        <div id="proj-media">

            {% if project.Pics and project.Pics.length > 0 %}
            <div class="proj-gallery reveal" id="galleryWrap">
                <div class="proj-gallery-label"><span>Images</span></div>
                <div class="proj-gallery-strip" id="galleryStrip">
                    <div class="proj-gallery-track" id="galleryTrack">
                        {% for pic in project.Pics %}
                        <div class="proj-gallery-slide{% if loop.first %} is-active{% endif %}" data-index="{{ loop.index0 }}">
                            <img src="/Adit-Sahai-Sharandeep-Singh.github.io{{ pic }}" alt="{{ project.Title }} — image {{ loop.index }}" loading="{{ 'eager' if loop.first else 'lazy' }}">
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% if project.Pics.length > 1 %}
                <div class="proj-gallery-nav">
                    <button class="proj-gallery-btn" id="galleryPrev" aria-label="Previous">&#8592;</button>
                    <div class="proj-gallery-indicators" id="galleryDots">
                        {% for pic in project.Pics %}
                        <button class="proj-gallery-pip{% if loop.first %} active{% endif %}" data-dot="{{ loop.index0 }}" aria-label="Image {{ loop.index }}"></button>
                        {% endfor %}
                    </div>
                    <span class="proj-gallery-index" id="galleryIndex">1 / {{ project.Pics.length }}</span>
                    <button class="proj-gallery-btn" id="galleryNext" aria-label="Next">&#8594;</button>
                </div>
                {% endif %}
            </div>
            <div class="proj-lightbox" id="projLightbox">
                <button class="proj-lightbox-close" id="lightboxClose">&#x2715;</button>
                <img id="lightboxImg" src="" alt="">
            </div>
            {% endif %}

            {% if project.Files and project.Files.length > 0 %}
            <div class="proj-files reveal">
                <div class="proj-section-label"><span>Attachments</span></div>
                <div class="files-grid">
                    {% for df in project.Files %}
                    {%- set ext = df.split('.') | last | lower -%}
                    {%- set isPdf = ext === 'pdf' -%}
                    {%- set isDoc = ext in ['doc','docx','odt','pages','txt','rtf','xls','xlsx','csv','ppt','pptx'] -%}
                    <a href="/Adit-Sahai-Sharandeep-Singh.github.io{{ df }}" class="file-card" target="_blank" rel="noopener noreferrer" download>
                        <div class="file-icon {% if isPdf %}type-pdf{% elif isDoc %}type-doc{% else %}type-other{% endif %}">
                            {% if isPdf %}📄{% elif ext in ['doc','docx','odt','pages','txt','rtf'] %}📝{% elif ext in ['xls','xlsx','csv'] %}📊{% elif ext in ['ppt','pptx'] %}📋{% elif ext in ['zip','rar','7z','tar','gz'] %}🗜️{% else %}📎{% endif %}
                        </div>
                        <div class="file-info">
                            <span class="file-name">{{ df.split('/') | last }}</span>
                            <span class="file-type-label">{{ ext | upper }}</span>
                        </div>
                        <span class="file-arrow">↓</span>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {% if project.Links and project.Links.length > 0 %}
            <div class="proj-links reveal" id="projectLinks">
                <div class="proj-section-label"><span>Links</span></div>
                <div class="links-embed-list" id="linksEmbedList">
                    {% for link in project.Links %}
                    <div class="link-embed-item reveal" style="transition-delay: {{ loop.index0 * 80 }}ms" data-url="{{ link }}"></div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

        </div><!-- /#proj-media -->

        <!-- ══ UPDATES ══════════════════════════════════════════════ -->
        <div id="proj-updates">
            <div class="sp-section reveal" style="margin-bottom:28px;">
                <h2 class="sp-section-title reveal" style="font-size: clamp(1.6rem, 3.4vw, 2.4rem) !important;">Updates</h2>
                <p class="sp-section-sub">Devlog &amp; changelog for this project</p>
            </div>

            <div class="upd-list">
                {% set anyUpdate = false %}
                {% for update in Sharan.ProjectUpdates %}
                {% if update.Published %}
                    {% if update.Project and update.Project.Title %}
                        {% set updProjTitle = update.Project.Title %}
                    {% else %}
                        {% set updProjRaw = update.Project | string %}
                        {% set updProjTitle = updProjRaw | replace("_data/Sharan/Projects/","") | replace(".json","") | replace("-"," ") | trim %}
                    {% endif %}
                    {% if (updProjTitle | slug) == projectSlug %}
                        {% set anyUpdate = true %}
                        {% if update.Status and update.Status.name %}
                            {% set uStatusRaw = update.Status.name %}
                        {% else %}
                            {% set uStatusRaw = update.Status | string %}
                        {% endif %}
                        {% set uStatusName = uStatusRaw | replace("_data/Sharan/ProjectStatus/","") | replace(".json","") | replace("-"," ") | trim %}
                        {% set uStatusSlug = uStatusName | lower | replace(" ","-") %}

                        <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Sharan/projects/{{ projectSlug }}/updates/{{ update.Title | slug }}/" class="upd-item reveal">
                            <span class="upd-dot" data-status="{{ uStatusSlug }}"></span>
                            <div class="upd-body">
                                <div class="upd-title">{{ update.Title }}</div>
                                <div class="upd-desc">{{ update.Description | striptags | truncate(110) }}</div>
                            </div>
                            <span class="upd-date">{{ update.UpdateDate }}</span>
                            <span class="upd-arrow">→</span>
                        </a>
                    {% endif %}
                {% endif %}
                {% endfor %}

                {% if not anyUpdate %}
                <p class="upd-empty">// no updates posted yet.</p>
                {% endif %}
            </div>
        </div>

        <!-- ── Likes ──────────────────────────────────────────────── -->
        {% if project.Likes %}
        <div class="proj-likes-zone reveal" id="likesSection">
            <div class="proj-likes-sparks" id="likesSparks"></div>
            <button class="proj-stamp-btn" id="likeBtn" aria-label="Like this project">
                <span class="proj-stamp-icon" id="stampIcon">✦</span>
            </button>
            <div class="proj-likes-info">
                <span class="proj-likes-count" id="likeCount">—</span>
                <span class="proj-likes-label">Likes</span>
            </div>
        </div>
        {% endif %}

        <!-- ── Discussion ─────────────────────────────────────────── -->
        {% if project.Comments %}
        <section class="proj-discussion reveal" id="commentsSection">
            <div class="proj-discussion-header">
                <div class="sp-nav-dot"></div>
                <h3 class="proj-discussion-title">discussion.log</h3>
                <span class="proj-discussion-count" id="commentsCount"></span>
            </div>
            <div class="proj-discussion-body">
                <div class="proj-comment-compose">
                    <div class="proj-compose-row">
                        <div class="proj-compose-avatar" id="composeAvatar">?</div>
                        <div class="proj-compose-fields">
                            <input type="text" id="commentName" class="proj-compose-name" placeholder="Your name" maxlength="60" autocomplete="name" />
                            <textarea id="commentBody" class="proj-compose-text" placeholder="Leave a thought…" maxlength="1200" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="proj-compose-footer">
                        <span class="proj-compose-chars" id="charCount">0 / 1200</span>
                        <button class="proj-compose-submit" id="submitBtn">Post</button>
                    </div>
                    <p class="proj-compose-error" id="commentError"></p>
                </div>
                <div id="commentsList" class="proj-comments-list">
                    <div class="proj-comments-loading" id="commentsLoading">
                        <div class="proj-loading-dot"></div>
                        <div class="proj-loading-dot"></div>
                        <div class="proj-loading-dot"></div>
                    </div>
                </div>
            </div>
        </section>
        {% endif %}

    </div><!-- /.proj-page -->

    <footer class="sp-footer">
        &copy; 2026 {{ Sharan.SiteHeader.PageTitle }} &nbsp;·&nbsp; Part of <a href="/Adit-Sahai-Sharandeep-Singh.github.io/index.html">A&amp;S</a>
    </footer>

    <script src="/Adit-Sahai-Sharandeep-Singh.github.io/MainCode/script.js"></script>
    <script>
    function scrollToSection(id) {
        const el = document.getElementById(id);
        if (el) el.scrollIntoView({ behavior: 'smooth' });
    }

    document.addEventListener('DOMContentLoaded', () => {

        function escHtml(s) {
            return String(s || '')
                .replace(/&/g, '&amp;').replace(/</g, '&lt;')
                .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        }
        function formatDate(iso) {
            return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        }

        (function () {
            const nav = document.getElementById('spNav');
            if (!nav) return;
            let last = false;
            window.addEventListener('scroll', () => {
                const s = window.scrollY > 12;
                if (s !== last) { nav.classList.toggle('is-scrolled', s); last = s; }
            }, { passive: true });
        })();

        (function () {
            const overviewEl = document.getElementById('proj-overview');
            const mediaEl    = document.getElementById('proj-media');
            const updatesEl  = document.getElementById('proj-updates');
            const navOv = document.getElementById('navOverview');
            const navMd = document.getElementById('navMedia');
            const navUp = document.getElementById('navUpdates');
            if (!overviewEl || !mediaEl || !updatesEl) return;

            const obs = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) return;
                    [navOv, navMd, navUp].forEach(n => n && n.classList.remove('active'));
                    if (entry.target === overviewEl) navOv.classList.add('active');
                    if (entry.target === mediaEl)    navMd.classList.add('active');
                    if (entry.target === updatesEl)  navUp.classList.add('active');
                });
            }, { rootMargin: '-40% 0px -40% 0px', threshold: 0 });

            obs.observe(overviewEl); obs.observe(mediaEl); obs.observe(updatesEl);
        })();

        const bar = document.getElementById('progressBar');
        if (bar) {
            window.addEventListener('scroll', () => {
                const docH = document.documentElement.scrollHeight - window.innerHeight;
                bar.style.width = (docH > 0 ? (window.scrollY / docH) * 100 : 0) + '%';
            }, { passive: true });
        }

        const SUPABASE_URL = 'https://mpeqripywqiotselpyut.supabase.co';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1wZXFyaXB5d3Fpb3RzZWxweXV0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEzMTE4MzUsImV4cCI6MjA5Njg4NzgzNX0.1lTHIY3M1xk5FmnTC2YMbSMNpi7vhWDuGGXUSNkwkm8';
        const PROJECT_ID   = '{{ projectSlug }}';

        async function sb(path, opts = {}) {
            const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
                headers: {
                    'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}`,
                    'Content-Type': 'application/json', 'Prefer': opts.prefer || '',
                    ...opts.headers
                },
                method: opts.method || 'GET',
                body: opts.body ? JSON.stringify(opts.body) : undefined
            });
            if (!res.ok) throw new Error(await res.text());
            const text = await res.text();
            return text ? JSON.parse(text) : null;
        }

        (function initGallery() {
            const track   = document.getElementById('galleryTrack');
            const prevBtn = document.getElementById('galleryPrev');
            const nextBtn = document.getElementById('galleryNext');
            const index   = document.getElementById('galleryIndex');
            const dots    = document.getElementById('galleryDots');
            const lightbox= document.getElementById('projLightbox');
            const lbImg   = document.getElementById('lightboxImg');
            const lbClose = document.getElementById('lightboxClose');
            const strip   = document.getElementById('galleryStrip');
            if (!track) return;

            const slides = track.querySelectorAll('.proj-gallery-slide');
            const total  = slides.length;
            let current  = 0;

            function goTo(idx) {
                slides[current].classList.remove('is-active');
                current = (idx + total) % total;
                slides[current].classList.add('is-active');
                track.style.transform = `translateX(-${current * 100}%)`;
                if (index) index.textContent = `${current + 1} / ${total}`;
                if (dots) dots.querySelectorAll('.proj-gallery-pip').forEach((p, i) => p.classList.toggle('active', i === current));
                if (prevBtn) prevBtn.disabled = current === 0;
                if (nextBtn) nextBtn.disabled = current === total - 1;
            }

            if (prevBtn) { prevBtn.disabled = true; prevBtn.addEventListener('click', () => goTo(current - 1)); }
            if (nextBtn) { nextBtn.disabled = total <= 1; nextBtn.addEventListener('click', () => goTo(current + 1)); }
            if (dots) dots.querySelectorAll('.proj-gallery-pip').forEach(p => p.addEventListener('click', () => goTo(parseInt(p.dataset.dot))));

            let tx = 0;
            strip && strip.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
            strip && strip.addEventListener('touchend', e => {
                const d = e.changedTouches[0].clientX - tx;
                if (Math.abs(d) > 40) goTo(current + (d < 0 ? 1 : -1));
            });

            function openLightbox(src, alt) { lbImg.src = src; lbImg.alt = alt; lightbox.classList.add('open'); document.body.style.overflow = 'hidden'; }
            function closeLightbox() { lightbox.classList.remove('open'); document.body.style.overflow = ''; }

            slides.forEach(slide => {
                slide.addEventListener('click', () => {
                    const img = slide.querySelector('img');
                    if (img) openLightbox(img.src, img.alt);
                });
            });
            lbClose  && lbClose.addEventListener('click', closeLightbox);
            lightbox && lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
            document.addEventListener('keydown', e => {
                if (!lightbox || !lightbox.classList.contains('open')) return;
                if (e.key === 'ArrowLeft')  goTo(current - 1);
                if (e.key === 'ArrowRight') goTo(current + 1);
                if (e.key === 'Escape')     closeLightbox();
            });
        })();

        const LIKE_KEY    = `likedProject:${PROJECT_ID}`;
        const likeBtn     = document.getElementById('likeBtn');
        const likeCountEl = document.getElementById('likeCount');
        const stampIcon   = document.getElementById('stampIcon');
        const sparksEl    = document.getElementById('likesSparks');

        function spawnSparks() {
            if (!sparksEl) return;
            for (let i = 0; i < 8; i++) {
                const s = document.createElement('div');
                s.className = 'proj-spark';
                const angle = (i / 8) * 360;
                const dist  = 30 + Math.random() * 30;
                const x = 50 + Math.cos(angle * Math.PI / 180) * dist;
                const y = 50 + Math.sin(angle * Math.PI / 180) * dist;
                s.style.cssText = `left:${x}%; top:${y}%; width:${3+Math.random()*3}px; height:${3+Math.random()*3}px;`;
                s.style.animation = `sparkFly ${0.5 + Math.random() * 0.3}s ease-out ${i * 30}ms forwards`;
                sparksEl.appendChild(s);
                setTimeout(() => s.remove(), 900);
            }
        }
        const sparkStyle = document.createElement('style');
        sparkStyle.textContent = `@keyframes sparkFly { 0% { opacity:1; transform:scale(1) translate(0,0); } 100% { opacity:0; transform:scale(0.3) translate(${Math.random()*20-10}px,${Math.random()*20-10}px); } }`;
        document.head.appendChild(sparkStyle);

        async function loadLikes() {
            if (!likeBtn) return;
            try {
                const all = await sb(`project_likes?project_id=eq.${PROJECT_ID}&select=id`);
                setLikeCount(all.length);
                if (localStorage.getItem(LIKE_KEY)) { likeBtn.classList.add('stamped'); stampIcon.textContent = '✦'; }
                likeBtn.addEventListener('click', toggleLike);
            } catch (e) { console.warn('Likes unavailable', e); }
        }
        function setLikeCount(n) { if (likeCountEl) likeCountEl.textContent = n; }

        async function toggleLike() {
            likeBtn.disabled = true;
            try {
                const liked = localStorage.getItem(LIKE_KEY);
                if (!liked) {
                    const fp = crypto.randomUUID();
                    await sb('project_likes', { method: 'POST', prefer: 'return=minimal', body: { project_id: PROJECT_ID, fingerprint: fp } });
                    localStorage.setItem(LIKE_KEY, fp);
                    likeBtn.classList.add('stamped'); stampIcon.textContent = '✦'; spawnSparks();
                } else {
                    await sb(`project_likes?project_id=eq.${PROJECT_ID}&fingerprint=eq.${liked}`, { method: 'DELETE' });
                    localStorage.removeItem(LIKE_KEY);
                    likeBtn.classList.remove('stamped'); stampIcon.textContent = '✦';
                }
                const all = await sb(`project_likes?project_id=eq.${PROJECT_ID}&select=id`);
                setLikeCount(all.length);
            } catch (e) { console.warn('Like failed', e); }
            likeBtn.disabled = false;
        }

        let commentLikeCounts = {};
        const nameInput = document.getElementById('commentName');
        const avatarEl  = document.getElementById('composeAvatar');
        if (nameInput && avatarEl) {
            nameInput.addEventListener('input', () => {
                const v = nameInput.value.trim();
                avatarEl.textContent = v ? v.charAt(0).toUpperCase() : '?';
            });
        }
        function getOwnerFp(id) { return localStorage.getItem(`comment_owner:${id}`); }
        function getCommentLikeFp(id) { return localStorage.getItem(`comment_liked:${id}`); }

        function renderComment(c) {
            const isOwner = !!getOwnerFp(c.id);
            const isLiked = !!getCommentLikeFp(c.id);
            const likes   = commentLikeCounts[c.id] || 0;
            const div = document.createElement('div');
            div.className = 'proj-comment-item';
            div.dataset.id = c.id;
            div.innerHTML = `
                <div class="proj-comment-avatar">${escHtml(c.name).trim().charAt(0).toUpperCase()}</div>
                <div class="proj-comment-right">
                    <div class="proj-comment-meta">
                        <span class="proj-comment-author">${escHtml(c.name)}</span>
                        <span class="proj-comment-date">${formatDate(c.created_at)}</span>
                    </div>
                    <p class="proj-comment-text">${escHtml(c.body)}</p>
                    <div class="proj-comment-actions">
                        <button class="proj-comment-like-btn ${isLiked ? 'liked' : ''}" data-comment-id="${c.id}">
                            <span class="proj-clheart">${isLiked ? '♥' : '♡'}</span>
                            <span class="cl-count">${likes > 0 ? likes : ''}</span>
                        </button>
                        ${isOwner ? `<button class="proj-comment-delete-btn" data-comment-id="${c.id}">delete</button>` : ''}
                    </div>
                </div>
            `;
            return div;
        }

        async function loadCommentLikes(ids) {
            if (!ids.length) return;
            try {
                const rows = await sb(`project_comment_likes?comment_id=in.(${ids.map(i=>`"${i}"`).join(',')})&select=comment_id`);
                rows.forEach(r => { commentLikeCounts[r.comment_id] = (commentLikeCounts[r.comment_id] || 0) + 1; });
            } catch(e) {}
        }

        async function toggleCommentLike(btn) {
            const id = btn.getAttribute('data-comment-id');
            btn.disabled = true;
            const fp = getCommentLikeFp(id);
            try {
                if (!fp) {
                    const nfp = crypto.randomUUID();
                    await sb('project_comment_likes', { method: 'POST', prefer: 'return=minimal', body: { comment_id: id, fingerprint: nfp } });
                    localStorage.setItem(`comment_liked:${id}`, nfp);
                    btn.classList.add('liked'); btn.querySelector('.proj-clheart').textContent = '♥';
                    commentLikeCounts[id] = (commentLikeCounts[id] || 0) + 1;
                } else {
                    await sb(`project_comment_likes?comment_id=eq.${id}&fingerprint=eq.${fp}`, { method: 'DELETE' });
                    localStorage.removeItem(`comment_liked:${id}`);
                    btn.classList.remove('liked'); btn.querySelector('.proj-clheart').textContent = '♡';
                    commentLikeCounts[id] = Math.max(0, (commentLikeCounts[id] || 1) - 1);
                }
                const c = commentLikeCounts[id];
                btn.querySelector('.cl-count').textContent = c > 0 ? c : '';
            } catch(e) {}
            btn.disabled = false;
        }

        async function deleteComment(btn) {
            const id = btn.getAttribute('data-comment-id');
            const fp = getOwnerFp(id);
            if (!fp || !confirm('Delete your comment?')) return;
            btn.disabled = true;
            try {
                await sb(`project_comments?id=eq.${id}&fingerprint=eq.${fp}`, { method: 'DELETE' });
                const item = document.querySelector(`.proj-comment-item[data-id="${id}"]`);
                if (item) { item.style.opacity = '0'; item.style.transform = 'translateY(-8px)'; item.style.transition = 'all 0.3s ease'; setTimeout(() => item.remove(), 320); }
                localStorage.removeItem(`comment_owner:${id}`);
                updateCommentCount(-1);
            } catch(e) { btn.disabled = false; }
        }

        function updateCommentCount(delta) {
            const el = document.getElementById('commentsCount');
            if (!el) return;
            const cur = parseInt(el.dataset.count || '0') + delta;
            el.dataset.count = cur;
            el.textContent = cur <= 0 ? '' : cur === 1 ? '1 entry' : `${cur} entries`;
        }

        async function loadComments() {
            const list   = document.getElementById('commentsList');
            const loader = document.getElementById('commentsLoading');
            if (!list) return;
            try {
                const data = await sb(`project_comments?project_id=eq.${PROJECT_ID}&order=created_at.desc&select=id,name,body,created_at,fingerprint`);
                await loadCommentLikes(data.map(c => c.id));
                if (loader) loader.remove();
                const el = document.getElementById('commentsCount');
                if (el) { el.dataset.count = data.length; el.textContent = data.length <= 0 ? '' : data.length === 1 ? '1 entry' : `${data.length} entries`; }
                if (!data.length) { list.innerHTML = '<p class="proj-no-comments">no comments yet</p>'; }
                else { data.forEach(c => list.appendChild(renderComment(c))); }
                list.addEventListener('click', e => {
                    const lb = e.target.closest('.proj-comment-like-btn');
                    if (lb) toggleCommentLike(lb);
                    const db = e.target.closest('.proj-comment-delete-btn');
                    if (db) deleteComment(db);
                });
            } catch(e) {
                if (loader) loader.innerHTML = '<span style="font-family:\'JetBrains Mono\',monospace;font-size:0.72rem;color:var(--text-dim)">// could not load entries</span>';
            }
        }

        async function submitComment() {
            const bodyEl = document.getElementById('commentBody');
            const errEl  = document.getElementById('commentError');
            const btn    = document.getElementById('submitBtn');
            if (!btn) return;
            errEl.textContent = '';
            const name = nameInput.value.trim();
            const body = bodyEl.value.trim();
            if (!name) { errEl.textContent = '// name required'; return; }
            if (!body || body.length < 3) { errEl.textContent = '// comment too short'; return; }
            btn.disabled = true; btn.textContent = '…';
            try {
                const fp = crypto.randomUUID();
                const result = await sb('project_comments', { method: 'POST', prefer: 'return=representation', headers: { 'Prefer': 'return=representation' }, body: { project_id: PROJECT_ID, name, body, fingerprint: fp } });
                const nc = Array.isArray(result) ? result[0] : result;
                if (nc?.id) localStorage.setItem(`comment_owner:${nc.id}`, fp);
                nameInput.value = ''; bodyEl.value = '';
                if (avatarEl) avatarEl.textContent = '?';
                document.getElementById('charCount').textContent = '0 / 1200';
                const list  = document.getElementById('commentsList');
                const noMsg = list.querySelector('.proj-no-comments');
                if (noMsg) noMsg.remove();
                const fake = { id: nc?.id || crypto.randomUUID(), name, body, created_at: new Date().toISOString() };
                list.insertBefore(renderComment(fake), list.firstChild);
                updateCommentCount(1);
            } catch(e) { errEl.textContent = '// post failed — try again'; }
            btn.disabled = false; btn.textContent = 'Post';
        }

        const bodyTa = document.getElementById('commentBody');
        if (bodyTa) bodyTa.addEventListener('input', () => { document.getElementById('charCount').textContent = `${bodyTa.value.length} / 1200`; });
        const submitTrigger = document.getElementById('submitBtn');
        if (submitTrigger) submitTrigger.addEventListener('click', submitComment);

        if (document.getElementById('likesSection'))    loadLikes();
        if (document.getElementById('commentsSection'))  loadComments();
        initLinks();
    });

    function initLinks() {
        const items = document.querySelectorAll('.link-embed-item[data-url]');
        if (!items.length) return;
        let twitterLoaded = false;

        items.forEach(item => {
            const raw = (item.dataset.url || '').trim();
            if (!raw) return;
            let url; try { url = new URL(raw); } catch(_) { item.appendChild(makePlainCard(raw, raw)); return; }
            const host = url.hostname.replace('www.','').toLowerCase();
            const path = url.pathname;

            if (host==='youtube.com'||host==='youtu.be'||host==='m.youtube.com') {
                let vid=null;
                if (host==='youtu.be') vid=path.slice(1).split('?')[0];
                else { vid=url.searchParams.get('v'); if(!vid&&path.startsWith('/shorts/')) vid=path.split('/shorts/')[1].split('/')[0]; if(!vid&&path.startsWith('/embed/')) vid=path.split('/embed/')[1].split('/')[0]; }
                if (vid) { const start=url.searchParams.get('t')||url.searchParams.get('start')||''; item.appendChild(makeIframe(`https://www.youtube-nocookie.com/embed/${vid}?rel=0&modestbranding=1${start?'&start='+parseInt(start):''}`, 'aspect-video','YouTube video')); return; }
            }
            if (host==='vimeo.com'||host==='player.vimeo.com') {
                const m=path.match(/(\d{5,})/);
                if (m) { item.appendChild(makeIframe(`https://player.vimeo.com/video/${m[1]}?title=0&byline=0&portrait=0`,'aspect-video','Vimeo video')); return; }
            }
            if (host==='open.spotify.com') {
                const ep=path.replace(/^\/(track|album|playlist|episode|show|artist)/,'/embed/$1');
                item.appendChild(makeIframe(`https://open.spotify.com${ep}?utm_source=generator&theme=0`, path.includes('/playlist/')||path.includes('/album/')?'aspect-spotify-large':'aspect-audio','Spotify')); return;
            }
            if (host==='soundcloud.com') { item.appendChild(makeIframe(`https://w.soundcloud.com/player/?url=${encodeURIComponent(raw)}&color=%23d4a050&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false`,'aspect-audio','SoundCloud')); return; }
            if (host==='twitter.com'||host==='x.com') {
                const m=path.match(/\/status\/(\d+)/);
                if (m) {
                    const w=document.createElement('div'); w.className='link-embed-frame aspect-twitter loaded'; w.style.cssText='background:transparent;border:1px solid var(--glass-border);border-radius:12px;overflow:hidden;padding:12px;';
                    const bq=document.createElement('blockquote'); bq.className='twitter-tweet'; bq.setAttribute('data-theme','dark'); bq.innerHTML=`<a href="${raw}"></a>`;
                    w.appendChild(bq); item.appendChild(w);
                    if (!twitterLoaded) { twitterLoaded=true; const s=document.createElement('script'); s.src='https://platform.twitter.com/widgets.js'; s.async=true; document.head.appendChild(s); }
                    return;
                }
            }
            const ext=path.split('.').pop().toLowerCase().split('?')[0];
            if (['mp4','webm','ogg','mov'].includes(ext)) {
                const w=document.createElement('div'); w.className='video-embed-wrap loaded'; w.style.cssText='border-radius:12px;overflow:hidden;border:1px solid var(--glass-border);';
                const v=document.createElement('video'); v.controls=true; v.preload='metadata'; v.setAttribute('playsinline',''); v.style.width='100%'; v.style.display='block';
                const s=document.createElement('source'); s.src=raw; s.type=`video/${ext==='mov'?'quicktime':ext}`; v.appendChild(s); w.appendChild(v); item.appendChild(w); return;
            }
            if (['mp3','wav','m4a','aac','flac','opus'].includes(ext)) {
                const w=document.createElement('div'); w.className='audio-player-item loaded';
                const a=document.createElement('audio'); a.controls=true; a.preload='metadata'; a.style.flex='1';
                const s=document.createElement('source'); s.src=raw; s.type=`audio/${ext}`; a.appendChild(s); w.appendChild(a); item.appendChild(w); return;
            }
            item.appendChild(makePlainCard(raw, url.hostname.replace('www.','')));
        });

        function makeIframe(src, cls, title) {
            const w=document.createElement('div'); w.className=`link-embed-frame ${cls}`;
            const f=document.createElement('iframe'); f.src=src; f.title=title; f.allow='accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture;web-share'; f.setAttribute('allowfullscreen',''); f.setAttribute('loading','lazy');
            f.addEventListener('load', ()=>w.classList.add('loaded')); w.appendChild(f); return w;
        }
        function makePlainCard(href, label, icon) {
            let h=label; try { h=label||new URL(href).hostname.replace('www.',''); } catch(_) {}
            const a=document.createElement('a'); a.href=href; a.target='_blank'; a.rel='noopener noreferrer'; a.className='link-plain-card';
            a.innerHTML=`<div class="link-plain-icon">${icon||guessIcon(href)}</div><div class="link-plain-text"><span class="link-plain-label">${esc(h)}</span><span class="link-plain-url">${esc(href)}</span></div><span class="link-plain-arrow">→</span>`;
            return a;
        }
        function guessIcon(u) { u=u.toLowerCase(); if(u.includes('github'))return'🐙'; if(u.includes('reddit'))return'🔴'; if(u.includes('medium'))return'📝'; if(u.includes('linkedin'))return'💼'; if(u.includes('instagram'))return'📸'; if(u.includes('notion'))return'🗒️'; if(u.includes('arxiv')||u.includes('.pdf'))return'📜'; return'🔗'; }
        function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    }
    </script>
</body>
</html>
