---
pagination:
  data: Sharan.ProjectUpdates
  size: 1
  alias: update
permalink: "/Sharan/projects/{{ update.Project.Title | slug if update.Project.Title else (update.Project | string | replace('_data/Sharan/Projects/','') | replace('.json','') | replace('-',' ') | trim | slug) }}/updates/{{ update.Title | slug }}/index.html"
---

{% if update.Project and update.Project.Title %}
  {% set projTitle = update.Project.Title %}
{% else %}
  {% set projRaw = update.Project | string %}
  {% set projTitle = projRaw | replace("_data/Sharan/Projects/","") | replace(".json","") | replace("-"," ") | trim %}
{% endif %}
{% set projectSlug = projTitle | slug %}

{% if update.Status and update.Status.name %}
  {% set statusRaw = update.Status.name %}
{% else %}
  {% set statusRaw = update.Status | string %}
{% endif %}
{% set statusName = statusRaw | replace("_data/Sharan/ProjectStatus/","") | replace(".json","") | replace("-"," ") | trim %}
{% set statusSlug = statusName | lower | replace(" ","-") %}

{% set updateSlug = update.Title | slug %}
{% set composedId = projectSlug + "__" + updateSlug %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ update.Title }} — {{ projTitle }} — {{ Sharan.AboutPage.Name }}</title>
    <meta name="description" content="{{ update.Description | striptags }}">
    <meta property="og:title" content="{{ update.Title }}">
    <meta property="og:description" content="{{ update.Description | striptags }}">
    {% if update.Pics and update.Pics.length > 0 %}
    <meta property="og:image" content="/Adit-Sahai-Sharandeep-Singh.github.io{{ update.Pics[0] }}">
    {% endif %}
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/Adit-Sahai-Sharandeep-Singh.github.io/MainCode/style.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { font-family: 'Inter', sans-serif; padding: 0 5%; color: #e8e8e8; background: #0d0a08; }
        h1, h2, h3, h4, h5, h6 { color: #ffffff; }
        p, span, a, li, div { color: inherit; }

        :root {
            --glass-bg: rgba(255,255,255,0.04);
            --glass-bg-strong: rgba(255,255,255,0.07);
            --glass-border: rgba(255,255,255,0.1);
            --glass-border-hover: rgba(212,160,80,0.45);
            --accent-gold: #d4a050;
            --accent-gold-dim: rgba(212,160,80,0.12);
            --accent-gold-line: rgba(212,160,80,0.3);
            --text-main: #ffffff;
            --text-muted: rgba(255,255,255,0.6);
            --text-dim: rgba(255,255,255,0.35);
        }

        body::before {
            content: ''; position: fixed; inset: 0;
            background: radial-gradient(ellipse at 50% 0%, rgba(212,160,80,0.04) 0%, transparent 60%);
            pointer-events: none; z-index: 0;
        }

        .sp-nav-fixed-wrap { position: fixed; top: 20px; left: 0; right: 0; z-index: 200; display: flex; justify-content: center; pointer-events: none; }
        .sp-nav-fixed-wrap > * { pointer-events: auto; }
        .sp-nav {
            width: 100%; max-width: 1100px; margin: 0 5%;
            display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 0;
            padding: 10px 18px 10px 24px;
            background: var(--glass-bg-strong); border: 1px solid var(--glass-border); border-radius: 100px;
            backdrop-filter: blur(40px); -webkit-backdrop-filter: blur(40px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.03) inset;
            transition: border-color 2.5s ease-in-out, background 2.5s ease-in-out, box-shadow 0.4s ease, transform 0.45s cubic-bezier(0.22,1,0.36,1);
        }
        .sp-nav.is-scrolled { box-shadow: 0 10px 36px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.04) inset; transform: translateY(-1px) scale(0.985); }
        .sp-nav:hover { border-color: var(--glass-border-hover); box-shadow: 0 12px 40px rgba(0,0,0,0.7), 0 0 18px var(--accent-gold-dim); }
        .sp-nav-spacer { height: 76px; width: 100%; }
        .sp-nav-left { display: flex; align-items: center; gap: 10px; min-width: 0; }
        .sp-nav-home {
            font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 0.78rem;
            color: var(--text-dim); text-decoration: none; letter-spacing: 1px;
            transition: color 0.2s ease; display: flex; align-items: center; gap: 5px; white-space: nowrap;
        }
        .sp-nav-home:hover { color: var(--accent-gold); }
        .sp-nav-home svg { width: 11px; height: 11px; opacity: 0.7; flex-shrink: 0; }
        .sp-nav-sep { width: 1px; height: 16px; background: var(--glass-border); flex-shrink: 0; }
        .sp-nav-brand {
            font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 0.85rem;
            color: var(--text-main); letter-spacing: 0.3px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .sp-nav-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent-gold); box-shadow: 0 0 8px var(--accent-gold), 0 0 16px var(--accent-gold); animation: navDotPulse 2s ease-in-out infinite; flex-shrink: 0; }
        @keyframes navDotPulse { 0%,100% { transform: scale(1); opacity: 0.8; } 50% { transform: scale(1.5); opacity: 1; } }
        .sp-nav-right { display: flex; align-items: center; justify-content: flex-end; gap: 4px; }

        /* Nav project info reveal */
        .sp-nav-project-info {
          display: flex; align-items: center; gap: 10px;
          opacity: 0; transform: translateX(-8px);
          pointer-events: none;
          transition: opacity 0.4s ease, transform 0.4s ease;
          overflow: hidden; white-space: nowrap;
        }
        .sp-nav-project-info.visible { opacity: 1; transform: translateX(0); pointer-events: auto; }
        .sp-nav-project-title {
          font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 0.85rem;
          color: var(--text-main); overflow: hidden; text-overflow: ellipsis;
          white-space: nowrap; max-width: 220px;
        }
        .sp-nav-project-status {
          display: inline-flex; align-items: center; gap: 5px;
          font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; font-weight: 700;
          letter-spacing: 1px; text-transform: uppercase; padding: 3px 10px; border-radius: 100px;
          border: 1px solid currentColor; flex-shrink: 0;
        }
        .sp-nav-project-status-dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; box-shadow: 0 0 6px currentColor; }
        .sp-nav-project-status[data-status="completed"] { color: #00dc82; background: rgba(0,220,130,0.08); }
        .sp-nav-project-status[data-status="concept"]   { color: #a06fff; background: rgba(160,111,255,0.08); }
        .sp-nav-project-status[data-status="ongoing"]   { color: #00b4ff; background: rgba(0,180,255,0.08); }
        .sp-nav-project-status[data-status="onhold"]    { color: #ffbe32; background: rgba(255,190,50,0.08); }
        .sp-nav-project-status[data-status="canceled"]  { color: #ff5f56; background: rgba(255,95,86,0.08); }
        @media (max-width: 768px) { .sp-nav-project-info { display: none; } }

        .sp-scroll-progress {
            position: fixed; top: 0; left: 0; height: 2px; width: 0%;
            background: linear-gradient(90deg, var(--accent-gold-line), var(--accent-gold));
            box-shadow: 0 0 10px var(--accent-gold); z-index: 300; transition: width 0.1s ease-out;
        }

        .upd-page { width: 100%; max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; }

        .upd-hero { padding: 28px 0 0; text-align: center; display: flex; flex-direction: column; align-items: center; }

        .upd-breadcrumb {
            display: inline-flex; align-items: center; gap: 8px;
            font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 1.5px;
            color: var(--text-dim); text-decoration: none; margin-bottom: 24px;
            padding: 7px 16px; border-radius: 100px; border: 1px solid var(--glass-border);
            background: var(--glass-bg); transition: border-color 0.25s ease, color 0.25s ease;
        }
        .upd-breadcrumb:hover { border-color: var(--accent-gold-line); color: var(--accent-gold); }

        .proj-status-badge {
            display: inline-flex; align-items: center; gap: 9px;
            font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; font-weight: 700;
            letter-spacing: 2.5px; text-transform: uppercase; padding: 9px 22px; border-radius: 100px;
            border: 1px solid currentColor; margin-bottom: 28px;
        }
        .proj-status-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; box-shadow: 0 0 10px currentColor; animation: statusPulse 2s ease-in-out infinite; flex-shrink: 0; }
        @keyframes statusPulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.6; transform: scale(0.85); } }
        .proj-status-badge[data-status="completed"] { color: #00dc82; background: rgba(0,220,130,0.08); border-color: rgba(0,220,130,0.35); }
        .proj-status-badge[data-status="concept"]    { color: #a06fff; background: rgba(160,111,255,0.08); border-color: rgba(160,111,255,0.35); }
        .proj-status-badge[data-status="ongoing"]    { color: #00b4ff; background: rgba(0,180,255,0.08); border-color: rgba(0,180,255,0.35); }
        .proj-status-badge[data-status="onhold"]     { color: #ffbe32; background: rgba(255,190,50,0.08); border-color: rgba(255,190,50,0.35); }
        .proj-status-badge[data-status="canceled"]   { color: #ff5f56; background: rgba(255,95,86,0.08); border-color: rgba(255,95,86,0.35); }

        .upd-hero-title {
            font-family: 'Playfair Display', serif; font-style: italic; font-weight: 700;
            font-size: clamp(2rem, 4.6vw, 3.4rem); line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 22px;
        }
        .upd-hero-title-inner {
            background: linear-gradient(100deg, rgba(255,255,255,0.55) 0%, #ffffff 15%, var(--accent-gold) 30%, #ffffff 45%, rgba(255,255,255,0.55) 60%, var(--accent-gold) 75%, #ffffff 90%, rgba(255,255,255,0.55) 100%);
            background-size: 250% auto; -webkit-background-clip: text; background-clip: text;
            -webkit-text-fill-color: transparent; color: #fff;
            animation: heroTitleShimmer 5s linear infinite;
        }
        @keyframes heroTitleShimmer { 0% { background-position: 200% center; } 100% { background-position: -50% center; } }
        @supports not (-webkit-background-clip: text) { .upd-hero-title-inner { background: none; -webkit-text-fill-color: rgba(255,255,255,0.95); color: rgba(255,255,255,0.95); animation: none; } }
        @media (max-width: 768px) { .upd-hero-title-inner { -webkit-text-fill-color: rgba(255,255,255,0.92); } }

        #upd-overview { scroll-margin-top: 100px; }
        .upd-body-wrap { display: grid; grid-template-columns: 3px 1fr; gap: 0 32px; margin-bottom: 60px; }
        .upd-body-rail { position: relative; }
        .upd-body-rail-line {
            position: absolute; top: 0; bottom: 0; left: 0; width: 3px;
            background: linear-gradient(to bottom, transparent 0%, var(--accent-gold-line) 8%, var(--accent-gold-line) 92%, transparent 100%);
            border-radius: 2px;
        }
        .upd-body-rail-dot {
            position: sticky; top: 120px; width: 11px; height: 11px; border-radius: 50%;
            background: var(--accent-gold); border: 2px solid #0d0a08;
            box-shadow: 0 0 0 2px var(--accent-gold), 0 0 16px var(--accent-gold);
            margin-left: -4px; margin-top: 8px; animation: railDotGlow 2.5s ease-in-out infinite;
        }
        @keyframes railDotGlow { 0%,100% { box-shadow: 0 0 0 2px var(--accent-gold), 0 0 12px var(--accent-gold); } 50% { box-shadow: 0 0 0 2px var(--accent-gold), 0 0 24px var(--accent-gold), 0 0 40px rgba(212,160,80,0.3); } }
        .upd-body-eyebrow {
          font-family: 'Space Grotesk', sans-serif;
          font-size: clamp(1.4rem, 3vw, 2rem);
          font-weight: 700;
          letter-spacing: -0.01em;
          text-transform: none;
          color: var(--text-main);
          opacity: 1;
          margin-bottom: 20px;
        }
        .upd-body-content .article-body { font-size: 1.025rem; line-height: 1.85; color: rgba(255,255,255,0.78); }
        .upd-body-content .article-body h2, .upd-body-content .article-body h3 { font-family: 'Space Grotesk', sans-serif; font-weight: 600; color: var(--text-main); margin-top: 2em; margin-bottom: 0.6em; }
        .upd-body-content .article-body h2 { font-size: 1.3rem; letter-spacing: -0.01em; }
        .upd-body-content .article-body h3 { font-size: 1.1rem; }
        .upd-body-content .article-body p { margin-bottom: 1.2em; }
        .upd-body-content .article-body a { color: var(--accent-gold); text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--accent-gold-line); }
        .upd-body-content .article-body code { font-family: 'JetBrains Mono', monospace; font-size: 0.85em; background: rgba(212,160,80,0.1); border: 1px solid var(--accent-gold-line); border-radius: 4px; padding: 1px 6px; color: var(--accent-gold); }
        .upd-body-content .article-body blockquote { border-left: 2px solid var(--accent-gold-line); margin: 1.5em 0; padding: 0.6em 1.2em; color: var(--text-muted); font-style: italic; }
        .upd-body-content .article-body ul, .upd-body-content .article-body ol { padding-left: 1.5em; margin-bottom: 1.2em; }
        .upd-body-content .article-body li { margin-bottom: 0.4em; }

        #upd-media { scroll-margin-top: 100px; }
        .proj-gallery { margin-bottom: 56px; position: relative; }
        .proj-gallery-label { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; font-family: 'JetBrains Mono', monospace; font-size: 0.66rem; font-weight: 700; text-transform: uppercase; letter-spacing: 4px; color: var(--text-dim); }
        .proj-gallery-label::before { content: ''; width: 20px; height: 1px; background: var(--accent-gold-line); }
        .proj-gallery-label::after  { content: ''; flex: 1; height: 1px; background: var(--glass-border); }
        .proj-gallery-strip { position: relative; overflow: hidden; }
        .proj-gallery-track { display: flex; gap: 0; transition: transform 0.55s cubic-bezier(0.4, 0, 0.2, 1); will-change: transform; }
        .proj-gallery-slide { flex: 0 0 100%; display: flex; align-items: center; justify-content: center; position: relative; }
        .proj-gallery-slide img { max-width: 100%; max-height: 460px; width: auto; height: auto; object-fit: contain; border-radius: 10px; display: block; opacity: 0; transform: scale(0.97) translateY(6px); transition: opacity 0.5s ease, transform 0.5s ease, filter 0.4s ease; filter: brightness(0.93) saturate(0.9); cursor: zoom-in; }
        .proj-gallery-slide.is-active img { opacity: 1; transform: scale(1) translateY(0); filter: brightness(1) saturate(1); }
        .proj-gallery-slide img:hover { filter: brightness(1.04) saturate(1.05); }
        .proj-gallery-nav { display: flex; align-items: center; justify-content: center; gap: 18px; margin-top: 20px; }
        .proj-gallery-btn { width: 36px; height: 36px; border-radius: 50%; border: 1px solid var(--glass-border); background: var(--glass-bg); color: var(--text-muted); font-size: 0.85rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: border-color 0.25s ease, background 0.25s ease, color 0.25s ease, transform 0.2s ease; flex-shrink: 0; }
        .proj-gallery-btn:hover { border-color: var(--accent-gold); background: var(--accent-gold-dim); color: var(--accent-gold); transform: scale(1.08); }
        .proj-gallery-btn:disabled { opacity: 0.25; cursor: default; pointer-events: none; }
        .proj-gallery-indicators { display: flex; align-items: center; gap: 6px; }
        .proj-gallery-pip { width: 5px; height: 5px; border-radius: 50%; background: var(--text-dim); border: none; cursor: pointer; padding: 0; transition: background 0.25s ease, transform 0.25s ease, width 0.3s ease; }
        .proj-gallery-pip.active { background: var(--accent-gold); width: 18px; border-radius: 3px; }
        .proj-gallery-index { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--text-dim); letter-spacing: 1.5px; min-width: 40px; text-align: center; }
        .proj-lightbox { position: fixed; inset: 0; z-index: 9000; background: rgba(6, 4, 2, 0.96); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
        .proj-lightbox.open { opacity: 1; pointer-events: all; }
        .proj-lightbox img { max-width: 90vw; max-height: 88vh; object-fit: contain; border-radius: 8px; transform: scale(0.93) translateY(10px); transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1); }
        .proj-lightbox.open img { transform: scale(1) translateY(0); }
        .proj-lightbox-close { position: fixed; top: 24px; right: 28px; background: var(--glass-bg-strong); border: 1px solid var(--glass-border); color: var(--text-muted); font-size: 1.1rem; width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 9001; transition: background 0.2s ease, transform 0.25s ease, color 0.2s ease; }
        .proj-lightbox-close:hover { background: var(--accent-gold); color: #000; transform: rotate(90deg) scale(1.08); }

        .proj-section-label { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; font-family: 'JetBrains Mono', monospace; font-size: 0.66rem; font-weight: 700; text-transform: uppercase; letter-spacing: 4px; color: var(--text-dim); }
        .proj-section-label::before { content: ''; width: 20px; height: 1px; background: var(--accent-gold-line); }
        .proj-section-label::after  { content: ''; flex: 1; height: 1px; background: var(--glass-border); }

        .proj-files { margin-bottom: 40px; }
        .files-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
        .file-card { display: flex; align-items: center; gap: 14px; padding: 16px 20px; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px; text-decoration: none; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); transition: background 2.5s ease-in-out, border-color 0.3s ease, transform 0.35s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.35s ease; position: relative; overflow: hidden; }
        .file-card:hover { border-color: var(--glass-border-hover); transform: translateY(-3px) scale(1.01); box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 0 12px var(--accent-gold-dim); }
        .file-icon { width: 42px; height: 42px; border-radius: 11px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 1.2rem; }
        .file-icon.type-pdf { background: rgba(255,120,50,0.15); border: 1px solid rgba(255,120,50,0.35); color: #ff7c3f; }
        .file-icon.type-doc { background: rgba(30,144,255,0.15); border: 1px solid rgba(30,144,255,0.35); color: #4da6ff; }
        .file-icon.type-other { background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); color: var(--accent-gold); }
        .file-info { flex: 1; min-width: 0; }
        .file-name { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 3px; }
        .file-type-label { display: block; font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1.5px; }
        .file-arrow { color: var(--accent-gold); opacity: 0; font-size: 0.9rem; flex-shrink: 0; transition: opacity 0.25s ease, transform 0.25s ease; }
        .file-card:hover .file-arrow { opacity: 1; transform: translateX(3px); }

        .proj-links { margin-bottom: 40px; }
        .links-embed-list { display: flex; flex-direction: column; gap: 20px; }
        .link-embed-frame { position: relative; width: 100%; border-radius: 12px; overflow: hidden; border: 1px solid var(--glass-border); background: #000; box-shadow: 0 8px 32px rgba(0,0,0,0.5); }
        .link-embed-frame.aspect-video { aspect-ratio: 16 / 9; }
        .link-embed-frame.aspect-twitter { aspect-ratio: unset; min-height: 220px; background: transparent; }
        .link-embed-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; display: block; }
        .link-embed-frame.aspect-twitter iframe { position: static; width: 100%; height: auto; min-height: 220px; }
        .link-embed-frame.aspect-audio { aspect-ratio: unset; height: 152px; background: transparent; }
        .link-embed-frame.aspect-audio iframe { height: 152px; }
        .link-embed-frame.aspect-spotify-large { aspect-ratio: unset; height: 380px; background: transparent; }
        .link-embed-frame.aspect-spotify-large iframe { height: 380px; }
        .link-plain-card { display: flex; align-items: center; gap: 16px; padding: 18px 22px; background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px; text-decoration: none; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); transition: border-color 0.3s ease, transform 0.35s cubic-bezier(0.25,1,0.5,1), box-shadow 0.35s ease; overflow: hidden; }
        .link-plain-card:hover { border-color: var(--glass-border-hover); transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.5); }
        .link-plain-icon { width: 40px; height: 40px; border-radius: 10px; background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); color: var(--accent-gold); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
        .link-plain-text { flex: 1; min-width: 0; }
        .link-plain-label { display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 3px; }
        .link-plain-url { display: block; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .link-plain-arrow { color: var(--accent-gold); opacity: 0; font-size: 0.9rem; flex-shrink: 0; transition: opacity 0.25s ease, transform 0.25s ease; }
        .link-plain-card:hover .link-plain-arrow { opacity: 1; transform: translateX(3px); }
        .link-embed-frame::before { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, rgba(212,160,80,0.04) 0%, rgba(212,160,80,0.10) 50%, rgba(212,160,80,0.04) 100%); background-size: 200% 100%; animation: embedShimmer 1.8s ease-in-out infinite; z-index: 0; pointer-events: none; border-radius: inherit; }
        .link-embed-frame.loaded::before { display: none; }
        @keyframes embedShimmer { 0% { background-position: 200% center; } 100% { background-position: -200% center; } }

        /* ── Likes Zone ───────────────────────────────────────────── */
        .proj-likes-zone {
          position: relative; display: flex; align-items: center; gap: 28px;
          margin: 56px 0 60px; padding: 32px 40px;
          background: rgba(255,255,255,0.03); border: 1px solid var(--glass-border); border-radius: 24px;
          overflow: hidden; transition: border-color 0.5s ease, box-shadow 0.5s ease;
        }
        .proj-likes-zone.is-liked { border-color: var(--glass-border-hover); box-shadow: 0 0 60px var(--accent-gold-dim), 0 20px 60px rgba(0,0,0,0.4); }
        .plz-bg-fill {
          position: absolute; inset: 0;
          background: linear-gradient(90deg, var(--accent-gold-dim) 0%, transparent 60%, transparent 100%);
          transform: scaleX(0); transform-origin: left center;
          transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
          pointer-events: none; border-radius: 24px;
        }
        .proj-likes-zone.is-liked .plz-bg-fill { transform: scaleX(1); }
        .plz-sparks-canvas { position: absolute; inset: 0; pointer-events: none; overflow: hidden; border-radius: 24px; }
        .plz-heart-btn {
          position: relative; flex-shrink: 0; width: 72px; height: 72px; border-radius: 20px;
          background: rgba(255,255,255,0.04); border: 1.5px solid var(--glass-border);
          cursor: pointer; display: flex; align-items: center; justify-content: center;
          transition: border-color 0.35s ease, background 0.35s ease, transform 0.2s ease;
          overflow: hidden; z-index: 1;
        }
        .plz-heart-btn:hover { border-color: var(--accent-gold-line); background: var(--accent-gold-dim); transform: scale(1.06); }
        .plz-heart-btn.stamped { border-color: var(--accent-gold); background: var(--accent-gold-dim); }
        .plz-heart-btn:active { transform: scale(0.94); }
        .plz-heart-svg { width: 34px; height: 34px; transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1); position: relative; z-index: 1; }
        .plz-heart-btn:hover .plz-heart-svg { transform: scale(1.12); }
        .plz-heart-path { stroke: var(--text-dim); fill: transparent; transition: stroke 0.35s ease, fill 0.35s ease, stroke-width 0.35s ease; }
        .plz-heart-btn.stamped .plz-heart-path { stroke: var(--accent-gold); fill: var(--accent-gold-dim); stroke-width: 2; }
        .plz-ripple { position: absolute; inset: 0; border-radius: 20px; pointer-events: none; opacity: 0; background: radial-gradient(circle at center, var(--accent-gold-dim) 0%, transparent 65%); transform: scale(0.5); }
        .plz-ripple.fire { animation: plzRipplePop 0.5s ease-out forwards; }
        @keyframes plzRipplePop { 0% { opacity: 1; transform: scale(0.5); } 100% { opacity: 0; transform: scale(2.2); } }
        @keyframes heartStampPop {
          0%   { transform: scale(1); }
          30%  { transform: scale(0.82) rotate(-6deg); }
          65%  { transform: scale(1.22) rotate(3deg); }
          82%  { transform: scale(0.96) rotate(-1deg); }
          100% { transform: scale(1) rotate(0deg); }
        }
        .plz-heart-btn.just-stamped .plz-heart-svg { animation: heartStampPop 0.55s cubic-bezier(0.34,1.56,0.64,1); }
        .plz-count-block { display: flex; flex-direction: column; gap: 4px; z-index: 1; }
        .plz-count-num { font-family: 'Space Grotesk', sans-serif; font-size: 2.6rem; font-weight: 700; line-height: 1; letter-spacing: -0.04em; color: var(--text-main); transition: color 0.4s ease; min-width: 3ch; }
        .proj-likes-zone.is-liked .plz-count-num { color: var(--accent-gold); }
        .plz-count-word { color: rgba(255,255,255,0.55); font-size: 0.68rem; font-family: 'JetBrains Mono', monospace; letter-spacing: 3px; text-transform: uppercase; }
        .plz-divider { width: 1px; height: 48px; background: var(--glass-border); flex-shrink: 0; z-index: 1; }
        .plz-prompt-block { z-index: 1; flex: 1; }
        .plz-prompt-line { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; color: rgba(255,255,255,0.6); letter-spacing: 1.5px; font-style: italic; transition: color 0.4s ease; }
        .proj-likes-zone.is-liked .plz-prompt-line { color: var(--accent-gold-line); }
        .plz-spark-particle { position: absolute; border-radius: 50%; background: var(--accent-gold); pointer-events: none; opacity: 0; }
        @media (max-width: 600px) {
          .proj-likes-zone { padding: 24px 20px; gap: 18px; }
          .plz-count-num { font-size: 2rem; }
          .plz-divider { display: none; }
          .plz-prompt-block { display: none; }
          .plz-heart-btn { width: 60px; height: 60px; }
        }

        /* ── Discussion ── */
        .proj-discussion { margin-bottom: 80px; border: 1px solid var(--glass-border); border-radius: 16px; overflow: hidden; }
        .proj-discussion-header { padding: 18px 28px; border-bottom: 1px solid var(--glass-border); background: rgba(255,255,255,0.03); display: flex; align-items: center; gap: 14px; }
        .proj-chrome-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--glass-border); }
        .proj-discussion-title {
          font-family: 'JetBrains Mono', monospace; font-size: 0.95rem; font-weight: 700;
          color: rgba(255,255,255,0.85); letter-spacing: 2px; text-transform: uppercase; margin: 0;
        }
        .proj-discussion-count { margin-left: auto; font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: rgba(255,255,255,0.55); letter-spacing: 1px; }
        .proj-discussion-body { padding: 28px; }
        .proj-comment-compose { background: rgba(0,0,0,0.3); border: 1px solid var(--glass-border); border-radius: 12px; padding: 20px; margin-bottom: 32px; transition: border-color 0.3s ease; }
        .proj-comment-compose:focus-within { border-color: var(--accent-gold-line); }
        .proj-compose-row { display: grid; grid-template-columns: auto 1fr; gap: 14px; align-items: flex-start; }
        .proj-compose-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); display: flex; align-items: center; justify-content: center; font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; color: var(--accent-gold); font-weight: 700; flex-shrink: 0; }
        .proj-compose-fields { flex: 1; min-width: 0; }
        .proj-compose-name { width: 100%; background: transparent; border: none; border-bottom: 1px solid var(--glass-border); color: var(--text-main); font-family: 'Space Grotesk', sans-serif; font-size: 0.88rem; font-weight: 600; padding: 6px 0 8px; margin-bottom: 12px; outline: none; transition: border-color 0.2s ease; }
        .proj-compose-name::placeholder { color: rgba(255,255,255,0.42); font-weight: 400; }
        .proj-compose-name:focus { border-color: var(--accent-gold-line); }
        .proj-compose-text { width: 100%; background: transparent; border: none; color: rgba(255,255,255,0.75); font-family: 'Inter', sans-serif; font-size: 0.92rem; line-height: 1.65; padding: 0; outline: none; resize: none; min-height: 70px; }
        .proj-compose-text::placeholder { color: rgba(255,255,255,0.42); }
        .proj-compose-footer { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; padding-top: 14px; border-top: 1px solid var(--glass-border); }
        .proj-compose-chars { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: rgba(255,255,255,0.4); letter-spacing: 1px; }
        .proj-compose-submit { font-family: 'Space Grotesk', sans-serif; font-size: 0.78rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: #0d0a08; background: var(--accent-gold); border: none; border-radius: 100px; padding: 9px 22px; cursor: pointer; transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease; }
        .proj-compose-submit:hover { background: #e0b060; transform: translateY(-1px); box-shadow: 0 6px 18px rgba(212,160,80,0.35); }
        .proj-compose-submit:disabled { opacity: 0.5; cursor: default; transform: none; box-shadow: none; }
        .proj-compose-error { font-size: 0.78rem; color: #ff7070; margin-top: 10px; min-height: 18px; font-family: 'JetBrains Mono', monospace; }
        .proj-comments-list { display: flex; flex-direction: column; gap: 0; }
        .proj-comment-item { padding: 22px 0; border-bottom: 1px solid rgba(255,255,255,0.04); display: grid; grid-template-columns: 38px 1fr; gap: 14px; opacity: 0; transform: translateY(8px); animation: commentAppear 0.4s ease forwards; }
        .proj-comment-item:last-child { border-bottom: none; }
        @keyframes commentAppear { to { opacity: 1; transform: translateY(0); } }
        .proj-comment-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--glass-bg-strong); border: 1px solid var(--glass-border); display: flex; align-items: center; justify-content: center; font-family: 'Space Grotesk', sans-serif; font-size: 0.88rem; font-weight: 700; color: var(--text-muted); flex-shrink: 0; }
        .proj-comment-right { min-width: 0; }
        .proj-comment-meta { display: flex; align-items: baseline; gap: 10px; margin-bottom: 8px; }
        .proj-comment-author { font-family: 'Space Grotesk', sans-serif; font-size: 0.88rem; font-weight: 600; color: var(--text-main); }
        .proj-comment-date { font-family: 'JetBrains Mono', monospace; font-size: 0.74rem; color: rgba(255,255,255,0.5); letter-spacing: 0.5px; }
        .proj-comment-text { font-size: 0.9rem; line-height: 1.7; color: rgba(255,255,255,0.65); margin: 0 0 12px; }
        .proj-comment-actions { display: flex; align-items: center; gap: 16px; }
        .proj-comment-like-btn, .proj-comment-reply-btn {
          display: flex; align-items: center; gap: 6px;
          font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
          color: rgba(255,255,255,0.55); background: none; border: none; cursor: pointer;
          padding: 6px 12px; border-radius: 8px; letter-spacing: 0.5px;
          transition: color 0.2s ease, background 0.2s ease;
        }
        .proj-comment-like-btn:hover, .proj-comment-like-btn.liked, .proj-comment-reply-btn:hover { color: var(--accent-gold); background: var(--accent-gold-dim); }
        .proj-clheart { font-size: 0.95rem; }
        .proj-comment-delete-btn {
          font-family: 'JetBrains Mono', monospace; font-size: 0.76rem;
          color: rgba(255,110,110,0.6); background: none; border: none; cursor: pointer;
          padding: 6px 12px; border-radius: 8px; letter-spacing: 0.5px;
          transition: color 0.2s ease, background 0.2s ease;
        }
        .proj-comment-delete-btn:hover { color: #ff7070; background: rgba(255,70,70,0.1); }
        .proj-no-comments { text-align: center; padding: 40px 20px; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; letter-spacing: 1.5px; }
        .proj-no-comments::before { content: '// '; color: var(--accent-gold-line); }
        .proj-comments-loading { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 32px; }
        .proj-loading-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent-gold-line); animation: projLoadPulse 1.2s ease-in-out infinite; }
        .proj-loading-dot:nth-child(2) { animation-delay: 0.2s; }
        .proj-loading-dot:nth-child(3) { animation-delay: 0.4s; }
        @keyframes projLoadPulse { 0%,100% { transform: scale(0.7); opacity: 0.4; } 50% { transform: scale(1.2); opacity: 1; } }

        /* ── Host Badge ── */
        .host-badge {
          display: inline-flex; align-items: center; gap: 4px;
          font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; font-weight: 700;
          letter-spacing: 1.5px; text-transform: uppercase;
          color: #0d0a08; background: var(--accent-gold);
          padding: 3px 9px; border-radius: 6px;
          box-shadow: 0 0 10px var(--accent-gold-dim);
        }
        .host-badge::before { content: '✦'; font-size: 0.62rem; }
        .proj-comment-item.is-host-comment {
          background: linear-gradient(90deg, var(--accent-gold-dim), transparent 40%);
          border-radius: 10px; padding-left: 12px; margin-left: -12px;
        }

        /* ── Comment Tree ── */
        .proj-comment-node { display: block; }
        .proj-comments-list > .proj-comment-node { padding: 22px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .proj-comments-list > .proj-comment-node:last-child { border-bottom: none; }
        .proj-comment-node .proj-comment-item { padding: 0; border-bottom: none; animation: none; opacity: 1; transform: none; }

        .reply-compose {
          margin-top: 14px; margin-left: 52px;
          background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border);
          border-radius: 10px; padding: 14px; display: none;
        }
        .reply-compose.open { display: block; animation: replyOpen 0.25s ease; }
        @keyframes replyOpen { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
        .reply-compose input, .reply-compose textarea {
          width: 100%; background: transparent; border: none; color: var(--text-main);
          font-family: 'Inter', sans-serif; outline: none;
        }
        .reply-compose input {
          border-bottom: 1px solid var(--glass-border); font-family: 'Space Grotesk', sans-serif;
          font-size: 0.82rem; font-weight: 600; padding: 4px 0 6px; margin-bottom: 10px;
        }
        .reply-compose input::placeholder, .reply-compose textarea::placeholder { color: rgba(255,255,255,0.4); }
        .reply-compose textarea { font-size: 0.86rem; line-height: 1.6; resize: none; min-height: 50px; }
        .reply-compose-footer { display: flex; justify-content: flex-end; gap: 10px; margin-top: 10px; }
        .reply-compose-cancel {
          font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: rgba(255,255,255,0.5);
          background: none; border: none; cursor: pointer; letter-spacing: 1px;
        }
        .reply-compose-submit {
          font-family: 'Space Grotesk', sans-serif; font-size: 0.74rem; font-weight: 700;
          letter-spacing: 1px; text-transform: uppercase; color: #0d0a08; background: var(--accent-gold);
          border: none; border-radius: 100px; padding: 7px 18px; cursor: pointer; transition: background 0.2s ease;
        }
        .reply-compose-submit:hover { background: #e0b060; }

        .proj-replies-wrap {
          margin-left: 52px; margin-top: 14px;
          border-left: 2px solid var(--accent-gold-line);
          padding-left: 20px;
          display: flex; flex-direction: column; gap: 18px;
        }
        .proj-replies-toggle {
          display: flex; align-items: center; gap: 6px; margin-left: 52px; margin-top: 12px;
          font-family: 'JetBrains Mono', monospace; font-size: 0.74rem; color: var(--accent-gold);
          background: none; border: none; cursor: pointer; letter-spacing: 1px; opacity: 0.9;
        }
        .proj-replies-toggle:hover { opacity: 1; }
        .proj-replies-toggle-arrow { transition: transform 0.25s ease; display: inline-block; }
        .proj-replies-toggle.expanded .proj-replies-toggle-arrow { transform: rotate(90deg); }

        .sp-footer { text-align: center; padding: 40px 24px; border-top: 1px solid var(--glass-border); color: var(--text-dim); font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase; font-family: 'JetBrains Mono', monospace; max-width: 1100px; margin: 60px auto 0; }
        .sp-footer a { color: var(--accent-gold); text-decoration: none; }

        @media (max-width: 768px) {
            body { padding: 0 4%; }
            .sp-nav-fixed-wrap { padding: 0 4%; }
            .upd-body-wrap { grid-template-columns: 3px 1fr; gap: 0 20px; }
            .proj-gallery-slide img { max-height: 280px; }
        }
        @media (prefers-reduced-motion: reduce) {
            html { scroll-behavior: auto; }
            .proj-gallery-slide img { transition: opacity 0.3s ease; }
            .proj-gallery-track { transition: none; }
        }
    </style>
</head>
<body>
    <div class="progress-bar sp-scroll-progress" id="progressBar"></div>
    <div id="bg-canvas"></div>
    <div id="bg-pattern"></div>
    <div id="bg-dots"></div>

    <div class="sp-nav-fixed-wrap">
        <nav class="sp-nav" id="spNav">
            <div class="sp-nav-left">
                <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Sharan/projects/{{ projectSlug }}/#proj-updates" class="sp-nav-home">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    Back
                </a>
                <div class="sp-nav-sep"></div>
                <div class="sp-nav-dot"></div>
                <span class="sp-nav-brand">{{ projTitle }}</span>
                <div class="sp-nav-project-info" id="navProjectInfo">
                    <div class="sp-nav-sep"></div>
                    <span class="sp-nav-project-title">{{ update.Title }}</span>
                    <span class="sp-nav-project-status" data-status="{{ statusSlug }}">
                        <span class="sp-nav-project-status-dot"></span>{{ statusName }}
                    </span>
                </div>
            </div>
            <div class="sp-nav-right"></div>
        </nav>
    </div>
    <div class="sp-nav-spacer"></div>

    <div class="upd-page">

        <div class="upd-hero">
            <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Sharan/projects/{{ projectSlug }}/" class="upd-breadcrumb reveal">
                <span>{{ projTitle }}</span> <span>/</span> <span>update</span>
            </a>

            <h1 class="upd-hero-title reveal-heading">
                <span class="upd-hero-title-inner">{{ update.Title }}</span>
            </h1>

            <div class="article-hero-meta reveal">
                <span class="date">{{ update.UpdateDate }}</span>
            </div>

            <div class="proj-status-badge reveal" data-status="{{ statusSlug }}">
                <span class="proj-status-dot"></span>
                {{ statusName }}
            </div>

            <div class="article-title-rule reveal scale-in"><span>✦</span></div>
            {% if update.Description %}
            <p class="article-lead reveal blur-in">{{ update.Description | safe }}</p>
            {% endif %}
        </div>

        <div class="article-divider reveal"><div class="article-divider-icon">· · ·</div></div>

        <div id="upd-overview">
            <div class="upd-body-wrap reveal">
                <div class="upd-body-rail">
                    <div class="upd-body-rail-line"></div>
                    <div class="upd-body-rail-dot"></div>
                </div>
                <div class="upd-body-content">
                    <div class="upd-body-eyebrow">What Changed</div>
                    <div class="article-body">
                        {{ update.Body | safe }}
                    </div>
                </div>
            </div>
        </div>

        <div id="upd-media">

            {% if update.Pics and update.Pics.length > 0 %}
            <div class="proj-gallery reveal" id="galleryWrap">
                <div class="proj-gallery-label"><span>Images</span></div>
                <div class="proj-gallery-strip" id="galleryStrip">
                    <div class="proj-gallery-track" id="galleryTrack">
                        {% for pic in update.Pics %}
                        <div class="proj-gallery-slide{% if loop.first %} is-active{% endif %}" data-index="{{ loop.index0 }}">
                            <img src="/Adit-Sahai-Sharandeep-Singh.github.io{{ pic }}" alt="{{ update.Title }} — image {{ loop.index }}" loading="{{ 'eager' if loop.first else 'lazy' }}">
                        </div>
                        {% endfor %}
                    </div>
                </div>
                {% if update.Pics.length > 1 %}
                <div class="proj-gallery-nav">
                    <button class="proj-gallery-btn" id="galleryPrev" aria-label="Previous">&#8592;</button>
                    <div class="proj-gallery-indicators" id="galleryDots">
                        {% for pic in update.Pics %}
                        <button class="proj-gallery-pip{% if loop.first %} active{% endif %}" data-dot="{{ loop.index0 }}" aria-label="Image {{ loop.index }}"></button>
                        {% endfor %}
                    </div>
                    <span class="proj-gallery-index" id="galleryIndex">1 / {{ update.Pics.length }}</span>
                    <button class="proj-gallery-btn" id="galleryNext" aria-label="Next">&#8594;</button>
                </div>
                {% endif %}
            </div>
            <div class="proj-lightbox" id="projLightbox">
                <button class="proj-lightbox-close" id="lightboxClose">&#x2715;</button>
                <img id="lightboxImg" src="" alt="">
            </div>
            {% endif %}

            {% if update.Files and update.Files.length > 0 %}
            <div class="proj-files reveal">
                <div class="proj-section-label"><span>Attachments</span></div>
                <div class="files-grid">
                    {% for df in update.Files %}
                    {%- set ext = df.split('.') | last | lower -%}
                    {%- set isPdf = ext === 'pdf' -%}
                    {%- set isDoc = ext in ['doc','docx','odt','pages','txt','rtf','xls','xlsx','csv','ppt','pptx'] -%}
                    <a href="/Adit-Sahai-Sharandeep-Singh.github.io{{ df }}" class="file-card" target="_blank" rel="noopener noreferrer" download>
                        <div class="file-icon {% if isPdf %}type-pdf{% elif isDoc %}type-doc{% else %}type-other{% endif %}">
                            {% if isPdf %}📄{% elif ext in ['doc','docx','odt','pages','txt','rtf'] %}📝{% elif ext in ['xls','xlsx','csv'] %}📊{% elif ext in ['ppt','pptx'] %}📋{% elif ext in ['zip','rar','7z','tar','gz'] %}🗜️{% else %}📎{% endif %}
                        </div>
                        <div class="file-info">
                            <span class="file-name">{{ df.split('/') | last }}</span>
                            <span class="file-type-label">{{ ext | upper }}</span>
                        </div>
                        <span class="file-arrow">↓</span>
                    </a>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {% if update.Links and update.Links.length > 0 %}
            <div class="proj-links reveal" id="updateLinks">
                <div class="proj-section-label"><span>Links</span></div>
                <div class="links-embed-list" id="linksEmbedList">
                    {% for link in update.Links %}
                    <div class="link-embed-item reveal" style="transition-delay: {{ loop.index0 * 80 }}ms" data-url="{{ link }}"></div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

        </div><!-- /#upd-media -->

        {% if update.Likes %}
        <div class="proj-likes-zone reveal" id="likesSection">
          <div class="plz-bg-fill" id="likesBgFill"></div>
          <div class="plz-sparks-canvas" id="likesSparks"></div>
          <button class="plz-heart-btn" id="likeBtn" aria-label="Like this update">
            <svg class="plz-heart-svg" id="heartSvg" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path class="plz-heart-path" d="M16 28s-13-8.35-13-16a7 7 0 0 1 13-3.55A7 7 0 0 1 29 12c0 7.65-13 16-13 16z" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div class="plz-ripple" id="heartRipple"></div>
          </button>
          <div class="plz-count-block">
            <span class="plz-count-num" id="likeCount">—</span>
            <span class="plz-count-word">people liked this</span>
          </div>
          <div class="plz-divider"></div>
          <div class="plz-prompt-block">
            <span class="plz-prompt-line" id="likePrompt">enjoyed this? leave a mark.</span>
          </div>
        </div>
        {% endif %}

        {% if update.Comments %}
        <section class="proj-discussion reveal" id="commentsSection">
            <div class="proj-discussion-header">
                <div class="sp-nav-dot"></div>
                <h3 class="proj-discussion-title">discussion.log</h3>
                <span class="proj-discussion-count" id="commentsCount"></span>
            </div>
            <div class="proj-discussion-body">
                <div class="proj-comment-compose">
                    <div class="proj-compose-row">
                        <div class="proj-compose-avatar" id="composeAvatar">?</div>
                        <div class="proj-compose-fields">
                            <input type="text" id="commentName" class="proj-compose-name" placeholder="Your name" maxlength="60" autocomplete="name" />
                            <textarea id="commentBody" class="proj-compose-text" placeholder="Leave a thought…" maxlength="1200" rows="3"></textarea>
                        </div>
                    </div>
                    <div class="proj-compose-footer">
                        <span class="proj-compose-chars" id="charCount">0 / 1200</span>
                        <button class="proj-compose-submit" id="submitBtn">Post</button>
                    </div>
                    <p class="proj-compose-error" id="commentError"></p>
                </div>
                <div id="commentsList" class="proj-comments-list">
                    <div class="proj-comments-loading" id="commentsLoading">
                        <div class="proj-loading-dot"></div>
                        <div class="proj-loading-dot"></div>
                        <div class="proj-loading-dot"></div>
                    </div>
                </div>
            </div>
        </section>
        {% endif %}

    </div><!-- /.upd-page -->

    <footer class="sp-footer">
        &copy; 2026 {{ Sharan.AboutPage.Name }} &nbsp;·&nbsp; Part of <a href="/Adit-Sahai-Sharandeep-Singh.github.io/index.html">A&amp;S</a>
    </footer>

    <script src="/Adit-Sahai-Sharandeep-Singh.github.io/MainCode/script.js"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {

    function escHtml(s) {
        return String(s || '')
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function formatDate(iso) {
        return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    }

    (function () {
        const nav = document.getElementById('spNav');
        if (!nav) return;
        let last = false;
        window.addEventListener('scroll', () => {
            const s = window.scrollY > 12;
            if (s !== last) { nav.classList.toggle('is-scrolled', s); last = s; }
        }, { passive: true });
    })();

    (function () {
        const heroEl = document.querySelector('.upd-hero');
        const navInfo = document.getElementById('navProjectInfo');
        if (!heroEl || !navInfo) return;
        const obs = new IntersectionObserver((entries) => {
            entries.forEach(entry => navInfo.classList.toggle('visible', !entry.isIntersecting));
        }, { rootMargin: '-80px 0px 0px 0px', threshold: 0 });
        obs.observe(heroEl);
    })();

    (function () {
        const hero = document.querySelector('.upd-hero');
        if (!hero) return;
        hero.style.willChange = 'opacity, transform';
        window.addEventListener('scroll', () => {
            const y = window.scrollY;
            const fade = Math.max(0, 1 - y / 380);
            const translate = Math.min(36, y * 0.14);
            hero.style.opacity = fade;
            hero.style.transform = `translateY(-${translate}px)`;
        }, { passive: true });
    })();

    const bar = document.getElementById('progressBar');
    if (bar) {
        window.addEventListener('scroll', () => {
            const docH = document.documentElement.scrollHeight - window.innerHeight;
            bar.style.width = (docH > 0 ? (window.scrollY / docH) * 100 : 0) + '%';
        }, { passive: true });
    }

    const SUPABASE_URL = 'https://mpeqripywqiotselpyut.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1wZXFyaXB5d3Fpb3RzZWxweXV0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEzMTE4MzUsImV4cCI6MjA5Njg4NzgzNX0.1lTHIY3M1xk5FmnTC2YMbSMNpi7vhWDuGGXUSNkwkm8';
    const PROJECT_ID = '{{ composedId }}';
    const LIKE_KEY   = `likedProject:${PROJECT_ID}`;

    async function sb(path, opts = {}) {
        const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
            headers: {
                'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}`,
                'Content-Type': 'application/json', 'Prefer': opts.prefer || '',
                ...opts.headers
            },
            method: opts.method || 'GET',
            body: opts.body ? JSON.stringify(opts.body) : undefined
        });
        if (!res.ok) throw new Error(await res.text());
        const text = await res.text();
        return text ? JSON.parse(text) : null;
    }

    (function initGallery() {
        const track   = document.getElementById('galleryTrack');
        const prevBtn = document.getElementById('galleryPrev');
        const nextBtn = document.getElementById('galleryNext');
        const index   = document.getElementById('galleryIndex');
        const dots    = document.getElementById('galleryDots');
        const lightbox= document.getElementById('projLightbox');
        const lbImg   = document.getElementById('lightboxImg');
        const lbClose = document.getElementById('lightboxClose');
        const strip   = document.getElementById('galleryStrip');
        if (!track) return;

        const slides = track.querySelectorAll('.proj-gallery-slide');
        const total  = slides.length;
        let current  = 0;

        function goTo(idx) {
            slides[current].classList.remove('is-active');
            current = (idx + total) % total;
            slides[current].classList.add('is-active');
            track.style.transform = `translateX(-${current * 100}%)`;
            if (index) index.textContent = `${current + 1} / ${total}`;
            if (dots) dots.querySelectorAll('.proj-gallery-pip').forEach((p, i) => p.classList.toggle('active', i === current));
            if (prevBtn) prevBtn.disabled = current === 0;
            if (nextBtn) nextBtn.disabled = current === total - 1;
        }

        if (prevBtn) { prevBtn.disabled = true; prevBtn.addEventListener('click', () => goTo(current - 1)); }
        if (nextBtn) { nextBtn.disabled = total <= 1; nextBtn.addEventListener('click', () => goTo(current + 1)); }
        if (dots) dots.querySelectorAll('.proj-gallery-pip').forEach(p => p.addEventListener('click', () => goTo(parseInt(p.dataset.dot))));

        let tx = 0;
        strip && strip.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
        strip && strip.addEventListener('touchend', e => {
            const d = e.changedTouches[0].clientX - tx;
            if (Math.abs(d) > 40) goTo(current + (d < 0 ? 1 : -1));
        });

        function openLightbox(src, alt) { lbImg.src = src; lbImg.alt = alt; lightbox.classList.add('open'); document.body.style.overflow = 'hidden'; }
        function closeLightbox() { lightbox.classList.remove('open'); document.body.style.overflow = ''; }

        slides.forEach(slide => {
            slide.addEventListener('click', () => {
                const img = slide.querySelector('img');
                if (img) openLightbox(img.src, img.alt);
            });
        });
        lbClose  && lbClose.addEventListener('click', closeLightbox);
        lightbox && lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });
        document.addEventListener('keydown', e => {
            if (!lightbox || !lightbox.classList.contains('open')) return;
            if (e.key === 'ArrowLeft')  goTo(current - 1);
            if (e.key === 'ArrowRight') goTo(current + 1);
            if (e.key === 'Escape')     closeLightbox();
        });
    })();

    /* ── Likes Zone ── */
    (function initLikesZone() {
        const zone      = document.getElementById('likesSection');
        const likeBtn   = document.getElementById('likeBtn');
        const likeCount = document.getElementById('likeCount');
        const prompt    = document.getElementById('likePrompt');
        const ripple    = document.getElementById('heartRipple');
        const sparks    = document.getElementById('likesSparks');
        if (!zone || !likeBtn) return;

        function spawnSparks(e) {
            const count = 12;
            const zoneRect = zone.getBoundingClientRect();
            const cx = e.clientX - zoneRect.left;
            const cy = e.clientY - zoneRect.top;
            for (let i = 0; i < count; i++) {
                const s = document.createElement('div');
                s.className = 'plz-spark-particle';
                const angle = (i / count) * Math.PI * 2;
                const speed = 40 + Math.random() * 50;
                const size  = 3 + Math.random() * 4;
                const dur   = 0.5 + Math.random() * 0.35;
                const delay = i * 20;
                const tx = Math.cos(angle) * speed;
                const ty = Math.sin(angle) * speed;
                s.style.cssText = `left:${cx}px;top:${cy}px;width:${size}px;height:${size}px;opacity:1;animation:plzSparkFly${i} ${dur}s ease-out ${delay}ms forwards;`;
                const kf = `@keyframes plzSparkFly${i} { 0% { opacity:1; transform:translate(0,0) scale(1); } 100% { opacity:0; transform:translate(${tx}px,${ty}px) scale(0.2); } }`;
                const st = document.createElement('style');
                st.textContent = kf;
                document.head.appendChild(st);
                sparks.appendChild(s);
                setTimeout(() => { s.remove(); st.remove(); }, (dur + delay / 1000 + 0.1) * 1000);
            }
        }

        function fireRipple() {
            ripple.classList.remove('fire');
            void ripple.offsetWidth;
            ripple.classList.add('fire');
            setTimeout(() => ripple.classList.remove('fire'), 500);
        }

        function rollCount(el, to) {
            const from  = parseInt(el.textContent) || 0;
            const steps = 18;
            const dur   = 600;
            let step = 0;
            const id = setInterval(() => {
                step++;
                const t    = step / steps;
                const ease = 1 - Math.pow(1 - t, 3);
                el.textContent = Math.round(from + (to - from) * ease);
                if (step >= steps) { clearInterval(id); el.textContent = to; }
            }, dur / steps);
        }

        async function plzLoad() {
            try {
                const all = await sb(`project_likes?project_id=eq.${PROJECT_ID}&select=id`);
                likeCount.textContent = all.length;
                const liked = localStorage.getItem(LIKE_KEY);
                if (liked) {
                    zone.classList.add('is-liked');
                    likeBtn.classList.add('stamped');
                    prompt.textContent = 'you already liked this — thanks ✦';
                }
            } catch(e) { likeCount.textContent = '—'; console.warn('Likes unavailable', e); }

            likeBtn.addEventListener('click', async (e) => {
                likeBtn.disabled = true;
                const liked = localStorage.getItem(LIKE_KEY);
                fireRipple();
                if (!liked) {
                    likeBtn.classList.add('stamped', 'just-stamped');
                    zone.classList.add('is-liked');
                    prompt.textContent = 'you liked this — thanks ✦';
                    spawnSparks(e);
                    setTimeout(() => likeBtn.classList.remove('just-stamped'), 600);
                    try {
                        const fp = crypto.randomUUID();
                        await sb('project_likes', { method: 'POST', prefer: 'return=minimal', body: { project_id: PROJECT_ID, fingerprint: fp } });
                        localStorage.setItem(LIKE_KEY, fp);
                    } catch(e) { console.warn('Like failed', e); }
                } else {
                    likeBtn.classList.remove('stamped');
                    zone.classList.remove('is-liked');
                    prompt.textContent = 'enjoyed this? leave a mark.';
                    try {
                        await sb(`project_likes?project_id=eq.${PROJECT_ID}&fingerprint=eq.${liked}`, { method: 'DELETE' });
                        localStorage.removeItem(LIKE_KEY);
                    } catch(e) { console.warn('Unlike failed', e); }
                }
                try {
                    const all = await sb(`project_likes?project_id=eq.${PROJECT_ID}&select=id`);
                    rollCount(likeCount, all.length);
                } catch(e) {}
                likeBtn.disabled = false;
            });
        }

        plzLoad();
    })();

    /* ── Comments ── */

    let commentLikeCounts = {};
    const nameInput = document.getElementById('commentName');
    const avatarEl  = document.getElementById('composeAvatar');
    if (nameInput && avatarEl) {
        nameInput.addEventListener('input', () => {
            const v = nameInput.value.trim();
            avatarEl.textContent = v ? v.charAt(0).toUpperCase() : '?';
        });
    }
    function getOwnerFp(id) { return localStorage.getItem(`comment_owner:${id}`); }
    function getCommentLikeFp(id) { return localStorage.getItem(`comment_liked:${id}`); }
    function getHostPassphrase() { return localStorage.getItem('hostPassphrase') || null; }

    if (location.search.includes('setuphost')) {
        const p = prompt('Enter host passphrase:');
        if (p) { localStorage.setItem('hostPassphrase', p); alert('Host key saved on this device.'); }
    }

    const expandedThreads = new Set();

    function countDescendants(id, byParent) {
        const kids = byParent[id] || [];
        let total = kids.length;
        kids.forEach(k => { total += countDescendants(k.id, byParent); });
        return total;
    }

    function renderCommentNode(c, byParent) {
        const isOwner = !!getOwnerFp(c.id);
        const isLiked = !!getCommentLikeFp(c.id);
        const likes   = commentLikeCounts[c.id] || 0;

        const node = document.createElement('div');
        node.className = 'proj-comment-node';
        node.dataset.id = c.id;

        const item = document.createElement('div');
        item.className = 'proj-comment-item' + (c.is_host ? ' is-host-comment' : '');
        item.innerHTML = `
            <div class="proj-comment-avatar">${escHtml(c.name).trim().charAt(0).toUpperCase()}</div>
            <div class="proj-comment-right">
                <div class="proj-comment-meta">
                    <span class="proj-comment-author">${escHtml(c.name)}</span>
                    ${c.is_host ? '<span class="host-badge">Host</span>' : ''}
                    <span class="proj-comment-date">${formatDate(c.created_at)}</span>
                </div>
                <p class="proj-comment-text">${escHtml(c.body)}</p>
                <div class="proj-comment-actions">
                    <button class="proj-comment-like-btn ${isLiked ? 'liked' : ''}" data-comment-id="${c.id}">
                        <span class="proj-clheart">${isLiked ? '♥' : '♡'}</span>
                        <span class="cl-count">${likes > 0 ? likes : ''}</span>
                    </button>
                    <button class="proj-comment-reply-btn" data-comment-id="${c.id}">reply</button>
                    ${isOwner ? `<button class="proj-comment-delete-btn" data-comment-id="${c.id}">delete</button>` : ''}
                </div>
                <div class="reply-compose" id="reply-compose-${c.id}">
                    <input type="text" class="reply-name" placeholder="Your name" maxlength="60" />
                    <textarea class="reply-body" placeholder="Write a reply…" maxlength="1200" rows="2"></textarea>
                    <div class="reply-compose-footer">
                        <button class="reply-compose-cancel" data-cancel-for="${c.id}">cancel</button>
                        <button class="reply-compose-submit" data-reply-to="${c.id}">Reply</button>
                    </div>
                </div>
            </div>
        `;
        node.appendChild(item);

        const children = (byParent[c.id] || []).sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
        if (children.length) {
            const key = String(c.id);
            const isOpen = expandedThreads.has(key);
            const totalReplies = countDescendants(c.id, byParent);

            const toggle = document.createElement('button');
            toggle.className = 'proj-replies-toggle' + (isOpen ? ' expanded' : '');
            toggle.innerHTML = `<span class="proj-replies-toggle-arrow">▸</span> ${totalReplies} ${totalReplies === 1 ? 'reply' : 'replies'}`;
            const wrap = document.createElement('div');
            wrap.className = 'proj-replies-wrap';
            wrap.style.display = isOpen ? 'block' : 'none';
            children.forEach(child => wrap.appendChild(renderCommentNode(child, byParent)));

            toggle.addEventListener('click', () => {
                const open = wrap.style.display !== 'none';
                wrap.style.display = open ? 'none' : 'block';
                toggle.classList.toggle('expanded', !open);
                if (open) { expandedThreads.delete(key); } else { expandedThreads.add(key); }
            });

            node.appendChild(toggle);
            node.appendChild(wrap);
        }

        return node;
    }

    async function loadCommentLikes(ids) {
        if (!ids.length) return;
        try {
            const rows = await sb(`project_comment_likes?comment_id=in.(${ids.map(i=>`"${i}"`).join(',')})&select=comment_id`);
            rows.forEach(r => { commentLikeCounts[r.comment_id] = (commentLikeCounts[r.comment_id] || 0) + 1; });
        } catch(e) {}
    }

    async function toggleCommentLike(btn) {
        const id = btn.getAttribute('data-comment-id');
        btn.disabled = true;
        const fp = getCommentLikeFp(id);
        try {
            if (!fp) {
                const nfp = crypto.randomUUID();
                await sb('project_comment_likes', { method: 'POST', prefer: 'return=minimal', body: { comment_id: id, fingerprint: nfp } });
                localStorage.setItem(`comment_liked:${id}`, nfp);
                btn.classList.add('liked'); btn.querySelector('.proj-clheart').textContent = '♥';
                commentLikeCounts[id] = (commentLikeCounts[id] || 0) + 1;
            } else {
                await sb(`project_comment_likes?comment_id=eq.${id}&fingerprint=eq.${fp}`, { method: 'DELETE' });
                localStorage.removeItem(`comment_liked:${id}`);
                btn.classList.remove('liked'); btn.querySelector('.proj-clheart').textContent = '♡';
                commentLikeCounts[id] = Math.max(0, (commentLikeCounts[id] || 1) - 1);
            }
            const c = commentLikeCounts[id];
            btn.querySelector('.cl-count').textContent = c > 0 ? c : '';
        } catch(e) {}
        btn.disabled = false;
    }

    async function deleteComment(btn) {
        const id = btn.getAttribute('data-comment-id');
        const fp = getOwnerFp(id);
        if (!fp || !confirm('Delete this comment?')) return;
        btn.disabled = true;
        try {
            await sb(`project_comments?id=eq.${id}&fingerprint=eq.${fp}`, { method: 'DELETE' });
            localStorage.removeItem(`comment_owner:${id}`);
            loadComments();
        } catch(e) { btn.disabled = false; }
    }

    function updateCommentCount(totalCount) {
        const el = document.getElementById('commentsCount');
        if (!el) return;
        el.textContent = totalCount <= 0 ? '' : totalCount === 1 ? '1 comment' : `${totalCount} comments`;
    }

    async function loadComments() {
        const list   = document.getElementById('commentsList');
        const loader = document.getElementById('commentsLoading');
        if (!list) return;
        try {
            const data = await sb(`project_comments?project_id=eq.${PROJECT_ID}&order=created_at.asc&select=id,name,body,created_at,fingerprint,parent_id,is_host`);
            commentLikeCounts = {};
            await loadCommentLikes(data.map(c => c.id));

            const topLevel = data.filter(c => !c.parent_id).sort((a,b) => new Date(b.created_at) - new Date(a.created_at));
            const repliesByParent = {};
            data.filter(c => c.parent_id).forEach(r => {
                (repliesByParent[r.parent_id] = repliesByParent[r.parent_id] || []).push(r);
            });

            if (loader) loader.remove();
            updateCommentCount(data.length);

            list.innerHTML = '';
            if (!topLevel.length) { list.innerHTML = '<p class="proj-no-comments">no comments yet</p>'; }
            else { topLevel.forEach(c => list.appendChild(renderCommentNode(c, repliesByParent))); }
        } catch(e) {
            list.innerHTML = '<span style="font-family:\'JetBrains Mono\',monospace;font-size:0.72rem;color:var(--text-dim)">// could not load entries</span>';
        }
    }

    async function submitReply(btn) {
        const parentId = String(btn.getAttribute('data-reply-to'));
        const box = document.getElementById(`reply-compose-${parentId}`);
        const nameEl = box.querySelector('.reply-name');
        const bodyEl = box.querySelector('.reply-body');
        const name = nameEl.value.trim();
        const body = bodyEl.value.trim();
        if (!name || !body || body.length < 2) return;
        btn.disabled = true; btn.textContent = '…';
        try {
            const fp = crypto.randomUUID();
            const passphrase = getHostPassphrase();
            const result = await sb('rpc/post_project_comment', {
                method: 'POST', prefer: 'return=representation',
                body: { p_project_id: PROJECT_ID, p_name: name, p_body: body, p_fingerprint: fp, p_parent_id: parentId, p_passphrase: passphrase }
            });
            const nc = Array.isArray(result) ? result[0] : result;
            if (nc?.id) localStorage.setItem(`comment_owner:${nc.id}`, fp);
            box.classList.remove('open');
            nameEl.value = ''; bodyEl.value = '';
            expandedThreads.add(parentId);
            await loadComments();
        } catch(e) { alert('Reply failed — try again'); }
        btn.disabled = false; btn.textContent = 'Reply';
    }

    async function submitComment() {
        const bodyEl = document.getElementById('commentBody');
        const errEl  = document.getElementById('commentError');
        const btn    = document.getElementById('submitBtn');
        if (!btn) return;
        errEl.textContent = '';
        const name = nameInput.value.trim();
        const body = bodyEl.value.trim();
        if (!name) { errEl.textContent = '// name required'; return; }
        if (!body || body.length < 3) { errEl.textContent = '// comment too short'; return; }
        btn.disabled = true; btn.textContent = '…';
        try {
            const fp = crypto.randomUUID();
            const passphrase = getHostPassphrase();
            const result = await sb('rpc/post_project_comment', {
                method: 'POST', prefer: 'return=representation',
                body: { p_project_id: PROJECT_ID, p_name: name, p_body: body, p_fingerprint: fp, p_parent_id: null, p_passphrase: passphrase }
            });
            const nc = Array.isArray(result) ? result[0] : result;
            if (nc?.id) localStorage.setItem(`comment_owner:${nc.id}`, fp);
            nameInput.value = ''; bodyEl.value = '';
            if (avatarEl) avatarEl.textContent = '?';
            document.getElementById('charCount').textContent = '0 / 1200';
            await loadComments();
        } catch(e) { errEl.textContent = '// post failed — try again'; }
        btn.disabled = false; btn.textContent = 'Post';
    }

    const bodyTa = document.getElementById('commentBody');
    if (bodyTa) bodyTa.addEventListener('input', () => { document.getElementById('charCount').textContent = `${bodyTa.value.length} / 1200`; });
    const submitTrigger = document.getElementById('submitBtn');
    if (submitTrigger) submitTrigger.addEventListener('click', submitComment);

    const commentsListEl = document.getElementById('commentsList');
    if (commentsListEl) {
        commentsListEl.addEventListener('click', e => {
            const lb = e.target.closest('.proj-comment-like-btn');
            if (lb) toggleCommentLike(lb);
            const db = e.target.closest('.proj-comment-delete-btn');
            if (db) deleteComment(db);
            const rb = e.target.closest('.proj-comment-reply-btn');
            if (rb) {
                const id = rb.getAttribute('data-comment-id');
                document.querySelectorAll('.reply-compose.open').forEach(el => { if (el.id !== `reply-compose-${id}`) el.classList.remove('open'); });
                document.getElementById(`reply-compose-${id}`)?.classList.toggle('open');
            }
            const cb = e.target.closest('.reply-compose-cancel');
            if (cb) document.getElementById(`reply-compose-${cb.getAttribute('data-cancel-for')}`)?.classList.remove('open');
            const sb2 = e.target.closest('.reply-compose-submit');
            if (sb2) submitReply(sb2);
        });
    }

    if (document.getElementById('commentsSection')) loadComments();
});

function initLinks() {
    const items = document.querySelectorAll('.link-embed-item[data-url]');
    if (!items.length) return;
    let twitterLoaded = false;

    items.forEach(item => {
        const raw = (item.dataset.url || '').trim();
        if (!raw) return;
        let url; try { url = new URL(raw); } catch(_) { item.appendChild(makePlainCard(raw, raw)); return; }
        const host = url.hostname.replace('www.','').toLowerCase();
        const path = url.pathname;

        if (host==='youtube.com'||host==='youtu.be'||host==='m.youtube.com') {
            let vid=null;
            if (host==='youtu.be') vid=path.slice(1).split('?')[0];
            else { vid=url.searchParams.get('v'); if(!vid&&path.startsWith('/shorts/')) vid=path.split('/shorts/')[1].split('/')[0]; if(!vid&&path.startsWith('/embed/')) vid=path.split('/embed/')[1].split('/')[0]; }
            if (vid) { const start=url.searchParams.get('t')||url.searchParams.get('start')||''; item.appendChild(makeIframe(`https://www.youtube-nocookie.com/embed/${vid}?rel=0&modestbranding=1${start?'&start='+parseInt(start):''}`, 'aspect-video','YouTube video')); return; }
        }
        if (host==='vimeo.com'||host==='player.vimeo.com') {
            const m=path.match(/(\d{5,})/);
            if (m) { item.appendChild(makeIframe(`https://player.vimeo.com/video/${m[1]}?title=0&byline=0&portrait=0`,'aspect-video','Vimeo video')); return; }
        }
        if (host==='open.spotify.com') {
            const ep=path.replace(/^\/(track|album|playlist|episode|show|artist)/,'/embed/$1');
            item.appendChild(makeIframe(`https://open.spotify.com${ep}?utm_source=generator&theme=0`, path.includes('/playlist/')||path.includes('/album/')?'aspect-spotify-large':'aspect-audio','Spotify')); return;
        }
        if (host==='soundcloud.com') { item.appendChild(makeIframe(`https://w.soundcloud.com/player/?url=${encodeURIComponent(raw)}&color=%23d4a050&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false`,'aspect-audio','SoundCloud')); return; }
        if (host==='twitter.com'||host==='x.com') {
            const m=path.match(/\/status\/(\d+)/);
            if (m) {
                const w=document.createElement('div'); w.className='link-embed-frame aspect-twitter loaded'; w.style.cssText='background:transparent;border:1px solid var(--glass-border);border-radius:12px;overflow:hidden;padding:12px;';
                const bq=document.createElement('blockquote'); bq.className='twitter-tweet'; bq.setAttribute('data-theme','dark'); bq.innerHTML=`<a href="${raw}"></a>`;
                w.appendChild(bq); item.appendChild(w);
                if (!twitterLoaded) { twitterLoaded=true; const s=document.createElement('script'); s.src='https://platform.twitter.com/widgets.js'; s.async=true; document.head.appendChild(s); }
                return;
            }
        }
        const ext=path.split('.').pop().toLowerCase().split('?')[0];
        if (['mp4','webm','ogg','mov'].includes(ext)) {
            const w=document.createElement('div'); w.className='video-embed-wrap loaded'; w.style.cssText='border-radius:12px;overflow:hidden;border:1px solid var(--glass-border);';
            const v=document.createElement('video'); v.controls=true; v.preload='metadata'; v.setAttribute('playsinline',''); v.style.width='100%'; v.style.display='block';
            const s=document.createElement('source'); s.src=raw; s.type=`video/${ext==='mov'?'quicktime':ext}`; v.appendChild(s); w.appendChild(v); item.appendChild(w); return;
        }
        if (['mp3','wav','m4a','aac','flac','opus'].includes(ext)) {
            const w=document.createElement('div'); w.className='audio-player-item loaded';
            const a=document.createElement('audio'); a.controls=true; a.preload='metadata'; a.style.flex='1';
            const s=document.createElement('source'); s.src=raw; s.type=`audio/${ext}`; a.appendChild(s); w.appendChild(a); item.appendChild(w); return;
        }
        item.appendChild(makePlainCard(raw, url.hostname.replace('www.','')));
    });

    function makeIframe(src, cls, title) {
        const w=document.createElement('div'); w.className=`link-embed-frame ${cls}`;
        const f=document.createElement('iframe'); f.src=src; f.title=title; f.allow='accelerometer;autoplay;clipboard-write;encrypted-media;gyroscope;picture-in-picture;web-share'; f.setAttribute('allowfullscreen',''); f.setAttribute('loading','lazy');
        f.addEventListener('load', ()=>w.classList.add('loaded')); w.appendChild(f); return w;
    }
    function makePlainCard(href, label, icon) {
        let h=label; try { h=label||new URL(href).hostname.replace('www.',''); } catch(_) {}
        const a=document.createElement('a'); a.href=href; a.target='_blank'; a.rel='noopener noreferrer'; a.className='link-plain-card';
        a.innerHTML=`<div class="link-plain-icon">${icon||guessIcon(href)}</div><div class="link-plain-text"><span class="link-plain-label">${esc(h)}</span><span class="link-plain-url">${esc(href)}</span></div><span class="link-plain-arrow">→</span>`;
        return a;
    }
    function guessIcon(u) { u=u.toLowerCase(); if(u.includes('github'))return'🐙'; if(u.includes('reddit'))return'🔴'; if(u.includes('medium'))return'📝'; if(u.includes('linkedin'))return'💼'; if(u.includes('instagram'))return'📸'; if(u.includes('notion'))return'🗒️'; if(u.includes('arxiv')||u.includes('.pdf'))return'📜'; return'🔗'; }
    function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
}
</script>
</body>
</html>
