---
pagination:
  data: Sharan.Projects
  size: 1
  alias: project
permalink: "/Sharan/projects/{{ project.Title | slug }}/index.html"
---
{#
  NOTES FOR ADIT / SHARAN (delete this comment once read):

  1. New Supabase tables needed — fully separate from the Adit/article tables:
       - project_likes         (id, project_id text, fingerprint text, created_at timestamptz default now())
       - project_comments      (id, project_id text, name text, body text, fingerprint text, created_at timestamptz default now())
       - project_comment_likes (id, comment_id uuid -> project_comments.id, fingerprint text, created_at timestamptz default now())
     See projects_supabase.sql for the full create-table + RLS policy script.

  2. This page reuses a handful of class names that live in your shared
     MainCode/style.css rather than redefining them here — same trick article.njk
     uses (.article-hero-meta, .category, .meta-dot, .read-time, .date,
     .article-title-rule, .article-lead, .article-divider, .article-body-card,
     .article-body, .interactions-row, .like-btn, .comments-section and friends,
     .search-wrap/.search-toggle/.search-box). Because we redeclare the gold
     --accent-* variables on :root below (same trick SharanPage.html uses), those
     shared components should automatically pick up Sharan's palette. If anything
     looks off against the shared stylesheet, flag it and it's an easy tweak.
#}

{% if project.Category and project.Category.name %}
  {% set catRaw = project.Category.name %}
{% else %}
  {% set catRaw = project.Category | string %}
{% endif %}
{% set catName = catRaw | replace("_data/Sharan/Projectcategories/","") | replace("_data/Sharan/ProjectCategories/","") | replace(".json","") | replace("-"," ") | trim %}

{% if project.Status and project.Status.name %}
  {% set statusRaw = project.Status.name %}
{% else %}
  {% set statusRaw = project.Status | string %}
{% endif %}
{% set statusName = statusRaw | replace("_data/Sharan/ProjectStatus/","") | replace(".json","") | replace("-"," ") | trim %}
{% set statusSlug = statusName | lower | replace(" ","-") %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ project.Title }} — {{ Sharan.AboutPage.Name }}</title>
    <meta name="description" content="{{ project.Description | striptags }}">
    <meta property="og:title" content="{{ project.Title }}">
    <meta property="og:description" content="{{ project.Description | striptags }}">
    {% if project.Pics and project.Pics.length > 0 %}
    <meta property="og:image" content="/Adit-Sahai.github.io{{ project.Pics[0] }}">
    {% endif %}
    <meta property="og:type" content="website">
    <meta name="twitter:card" content="summary_large_image">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;0,800;0,900;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/Adit-Sahai.github.io/MainCode/style.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            padding: 0 5%;
            color: #e8e8e8;
            background: #0d0a08;
        }
        h1, h2, h3, h4, h5, h6 { color: #ffffff; }
        p, span, a, li, div { color: inherit; }

        :root {
            --glass-bg: rgba(255,255,255,0.04);
            --glass-bg-strong: rgba(255,255,255,0.07);
            --glass-border: rgba(255,255,255,0.1);
            --glass-border-hover: rgba(212,160,80,0.45);
            --accent-gold: #d4a050;
            --accent-gold-dim: rgba(212,160,80,0.12);
            --accent-gold-line: rgba(212,160,80,0.3);
            --text-main: #ffffff;
            --text-muted: rgba(255,255,255,0.6);
            --text-dim: rgba(255,255,255,0.35);
        }

        body::before {
            content: '';
            position: fixed; inset: 0;
            background: radial-gradient(ellipse at 50% 0%, rgba(212,160,80,0.04) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        /* ════════════════════════════════════════════════════════
           NAV (fixed, same treatment as SharanPage)
           ════════════════════════════════════════════════════════ */
        .sp-nav-fixed-wrap {
            position: fixed; top: 20px; left: 0; right: 0; z-index: 200;
            display: flex; justify-content: center; pointer-events: none;
        }
        .sp-nav-fixed-wrap > * { pointer-events: auto; }

        .sp-nav {
            width: 100%; max-width: 1100px; margin: 0 5%;
            display: grid; grid-template-columns: auto 1fr auto;
            align-items: center; gap: 0;
            padding: 10px 18px 10px 24px;
            background: var(--glass-bg-strong);
            border: 1px solid var(--glass-border);
            border-radius: 100px;
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.03) inset;
            transition: border-color 2.5s ease-in-out, background 2.5s ease-in-out, box-shadow 0.4s ease, transform 0.45s cubic-bezier(0.22,1,0.36,1);
        }
        .sp-nav.is-scrolled {
            box-shadow: 0 10px 36px rgba(0,0,0,0.65), 0 0 0 1px rgba(255,255,255,0.04) inset;
            transform: translateY(-1px) scale(0.985);
        }
        .sp-nav:hover {
            border-color: var(--glass-border-hover);
            box-shadow: 0 12px 40px rgba(0,0,0,0.7), 0 0 18px var(--accent-gold-dim);
        }
        .sp-nav-spacer { height: 76px; width: 100%; }

        .sp-nav-left { display: flex; align-items: center; gap: 10px; }
        .sp-nav-home {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700; font-size: 0.78rem;
            color: var(--text-dim);
            text-decoration: none; letter-spacing: 1px;
            transition: color 0.2s ease;
            display: flex; align-items: center; gap: 5px;
        }
        .sp-nav-home:hover { color: var(--accent-gold); }
        .sp-nav-home svg { width: 11px; height: 11px; opacity: 0.7; flex-shrink: 0; }

        .sp-nav-sep { width: 1px; height: 16px; background: var(--glass-border); }

        .sp-nav-brand {
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700; font-size: 0.9rem;
            color: var(--text-main); letter-spacing: 0.3px;
        }

        .sp-nav-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--accent-gold);
            box-shadow: 0 0 8px var(--accent-gold), 0 0 16px var(--accent-gold);
            animation: navDotPulse 2s ease-in-out infinite;
            flex-shrink: 0;
        }
        @keyframes navDotPulse {
            0%,100% { transform: scale(1); opacity: 0.8; }
            50%      { transform: scale(1.5); opacity: 1; }
        }

        .sp-nav-center { display: flex; align-items: center; justify-content: center; gap: 4px; }
        .sp-nav-right  { display: flex; align-items: center; justify-content: flex-end; gap: 4px; }

        .sp-nav-link {
            font-size: 0.72rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: 2px;
            color: var(--text-muted); text-decoration: none;
            padding: 8px 20px; border-radius: 100px;
            border: 1px solid transparent;
            transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
        }
        .sp-nav-link:hover {
            color: var(--accent-gold);
            background: var(--accent-gold-dim);
            border-color: var(--accent-gold-line);
        }

        /* ════════════════════════════════════════════════════════
           SCROLL PROGRESS
           ════════════════════════════════════════════════════════ */
        .sp-scroll-progress {
            position: fixed; top: 0; left: 0; height: 2px; width: 0%;
            background: linear-gradient(90deg, var(--accent-gold-line), var(--accent-gold));
            box-shadow: 0 0 10px var(--accent-gold);
            z-index: 300; transition: width 0.1s ease-out;
        }

        /* ════════════════════════════════════════════════════════
           PROJECT HERO
           ════════════════════════════════════════════════════════ */
        .proj-page {
            width: 100%; max-width: 1100px;
            margin: 0 auto;
            position: relative; z-index: 1;
        }

        .proj-hero {
            padding: 28px 0 0;
            text-align: center;
            display: flex; flex-direction: column; align-items: center;
        }

        .proj-status-badge {
            display: inline-flex; align-items: center; gap: 9px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem; font-weight: 700;
            letter-spacing: 2.5px; text-transform: uppercase;
            padding: 9px 22px; border-radius: 100px;
            border: 1px solid currentColor;
            margin-bottom: 28px;
        }
        .proj-status-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: currentColor;
            box-shadow: 0 0 10px currentColor;
            animation: statusPulse 2s ease-in-out infinite;
            flex-shrink: 0;
        }
        @keyframes statusPulse {
            0%,100% { opacity: 1; transform: scale(1); }
            50%      { opacity: 0.6; transform: scale(0.85); }
        }
        .proj-status-badge[data-status="completed"] { color: #00dc82; background: rgba(0,220,130,0.08); border-color: rgba(0,220,130,0.35); }
        .proj-status-badge[data-status="wip"]       { color: #ffbe32; background: rgba(255,190,50,0.08); border-color: rgba(255,190,50,0.35); }
        .proj-status-badge[data-status="concept"]   { color: #a06fff; background: rgba(160,111,255,0.08); border-color: rgba(160,111,255,0.35); }
        .proj-status-badge[data-status="released"]  { color: #00b4ff; background: rgba(0,180,255,0.08); border-color: rgba(0,180,255,0.35); }
        .proj-status-badge[data-status="ongoing"]   { color: #00b4ff; background: rgba(0,180,255,0.08); border-color: rgba(0,180,255,0.35); }
        .proj-status-badge[data-status="shelved"]   { color: #8a8a8a; background: rgba(138,138,138,0.08); border-color: rgba(138,138,138,0.35); }

        .proj-hero-title {
            font-family: 'Playfair Display', serif;
            font-style: italic; font-weight: 700;
            font-size: clamp(2.3rem, 5.4vw, 4.1rem);
            line-height: 1.08; letter-spacing: -0.02em;
            margin-bottom: 22px;
        }
        .proj-hero-title-inner {
            background: linear-gradient(
                100deg,
                rgba(255,255,255,0.55) 0%,
                #ffffff               15%,
                var(--accent-gold)    30%,
                #ffffff               45%,
                rgba(255,255,255,0.55) 60%,
                var(--accent-gold)    75%,
                #ffffff               90%,
                rgba(255,255,255,0.55) 100%
            );
            background-size: 250% auto;
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            color: #fff;
            animation: heroTitleShimmer 5s linear infinite;
        }
        @keyframes heroTitleShimmer {
            0%   { background-position: 200% center; }
            100% { background-position: -50% center; }
        }
        @supports not (-webkit-background-clip: text) {
            .proj-hero-title-inner { background: none; -webkit-text-fill-color: rgba(255,255,255,0.95); color: rgba(255,255,255,0.95); animation: none; }
        }
        @media (max-width: 768px) {
            .proj-hero-title-inner { -webkit-text-fill-color: rgba(255,255,255,0.92); }
        }

        /* ════════════════════════════════════════════════════════
           IMAGE GALLERY (same engine as the article pages)
           ════════════════════════════════════════════════════════ */
        .article-gallery { margin-bottom: 40px; position: relative; }

        .media-section-label {
            display: flex; align-items: center; gap: 12px;
            margin-bottom: 18px;
            color: var(--accent-gold);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.68rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 4px;
            opacity: 0.85;
        }
        .media-section-label::after {
            content: ''; flex: 1; height: 1px; background: var(--accent-gold-line);
        }

        .gallery-viewport {
            position: relative; overflow: hidden; border-radius: 16px;
            border: 1px solid var(--glass-border);
            background: rgba(3, 7, 18, 0.85);
            box-shadow: 0 12px 40px rgba(0,0,0,0.55);
            transition: border-color 2.5s ease-in-out;
        }
        .gallery-track {
            display: flex; transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1); will-change: transform;
        }
        .gallery-slide {
            flex: 0 0 100%; position: relative; max-height: 520px; overflow: hidden;
            display: flex; align-items: center; justify-content: center;
            background: rgba(3, 7, 18, 0.95); cursor: zoom-in;
        }
        .gallery-slide img {
            width: 100%; height: 100%; object-fit: contain; max-height: 520px; display: block;
            transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), filter 0.4s ease;
            filter: brightness(0.96) saturate(0.95);
        }
        .gallery-slide:hover img { transform: scale(1.015); filter: brightness(1) saturate(1); }
        .gallery-slide::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(to top, rgba(2,6,23,0.55) 0%, transparent 35%), linear-gradient(to bottom, rgba(2,6,23,0.25) 0%, transparent 25%);
            z-index: 1; pointer-events: none;
        }
        .gallery-counter {
            position: absolute; bottom: 16px; right: 20px; z-index: 3;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem; font-weight: 600; color: rgba(230, 247, 255, 0.75);
            background: rgba(6, 15, 30, 0.7); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(212,160,80,0.25); border-radius: 100px; padding: 4px 12px;
            letter-spacing: 1px; pointer-events: none;
        }
        .gallery-btn {
            position: absolute; top: 50%; transform: translateY(-50%); z-index: 4;
            width: 42px; height: 42px; border-radius: 50%;
            border: 1px solid var(--glass-border-hover);
            background: rgba(6, 15, 30, 0.75); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            color: var(--text-main); font-size: 1rem; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
            transition: background 0.25s ease, border-color 0.25s ease, transform 0.25s ease, opacity 0.25s ease;
            opacity: 0;
        }
        .gallery-viewport:hover .gallery-btn { opacity: 1; }
        .gallery-btn:hover { background: var(--accent-gold); border-color: var(--accent-gold); color: #000; transform: translateY(-50%) scale(1.08); }
        .gallery-btn-prev { left: 14px; }
        .gallery-btn-next { right: 14px; }
        .gallery-viewport.single .gallery-btn,
        .gallery-viewport.single .gallery-counter,
        .gallery-dots { display: none; }

        .gallery-dots { display: flex; justify-content: center; gap: 8px; margin-top: 14px; }
        .gallery-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--glass-border-hover); border: none; cursor: pointer; padding: 0;
            transition: background 0.25s ease, transform 0.25s ease, width 0.3s ease;
        }
        .gallery-dot.active { background: var(--accent-gold); width: 22px; border-radius: 4px; transform: scaleY(1.1); }

        .gallery-lightbox {
            position: fixed; inset: 0; z-index: 9000;
            background: rgba(2, 6, 23, 0.95); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            display: flex; align-items: center; justify-content: center;
            opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
        }
        .gallery-lightbox.open { opacity: 1; pointer-events: all; }
        .gallery-lightbox img {
            max-width: 90vw; max-height: 88vh; object-fit: contain; border-radius: 10px;
            box-shadow: 0 24px 80px rgba(0,0,0,0.8); transform: scale(0.94);
            transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .gallery-lightbox.open img { transform: scale(1); }
        .gallery-lightbox-close {
            position: fixed; top: 24px; right: 28px;
            background: rgba(6, 15, 30, 0.75); border: 1px solid var(--glass-border-hover);
            color: var(--text-main); font-size: 1.25rem; width: 42px; height: 42px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center; cursor: pointer;
            transition: background 0.25s ease, transform 0.25s ease; z-index: 9001;
        }
        .gallery-lightbox-close:hover { background: var(--accent-gold); color: #000; border-color: var(--accent-gold); transform: scale(1.1) rotate(90deg); }

        /* ════════════════════════════════════════════════════════
           VIDEO / AUDIO / FILES
           ════════════════════════════════════════════════════════ */
        .article-video-embed { margin-bottom: 40px; }
        .video-embed-wrap {
            position: relative; width: 100%; border-radius: 16px; overflow: hidden;
            border: 1px solid var(--glass-border); background: #000;
            box-shadow: 0 12px 40px rgba(0,0,0,0.6); transition: border-color 2.5s ease-in-out;
        }
        .video-embed-wrap video { width: 100%; display: block; max-height: 480px; object-fit: contain; background: #000; }

        .audio-player-wrap { display: flex; flex-direction: column; gap: 10px; margin-bottom: 40px; }
        .audio-player-item {
            display: flex; align-items: center; gap: 14px; padding: 14px 20px;
            background: var(--glass-bg); border: 1px solid var(--glass-border);
            border-radius: 12px; transition: border-color 2.5s ease-in-out;
        }
        .audio-player-item audio { flex: 1; height: 36px; accent-color: var(--accent-gold); outline: none; }

        .article-files { margin-bottom: 40px; }
        .files-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px; }
        .file-card {
            display: flex; align-items: center; gap: 14px; padding: 16px 20px;
            background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px;
            text-decoration: none; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            transition: background 2.5s ease-in-out, border-color 0.3s ease, transform 0.35s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.35s ease;
            position: relative; overflow: hidden;
        }
        .file-card::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(105deg, transparent 40%, rgba(212,160,80,0.08) 50%, transparent 60%);
            background-size: 200% 100%; background-position: 200% center;
            transition: background-position 0.6s ease; pointer-events: none;
        }
        .file-card:hover::before { background-position: -200% center; }
        .file-card:hover {
            border-color: var(--glass-border-hover); transform: translateY(-3px) scale(1.01);
            box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 0 12px var(--accent-gold-dim);
        }
        .file-icon {
            width: 42px; height: 42px; border-radius: 11px;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
            font-size: 1.2rem; font-weight: 700; line-height: 1;
            transition: transform 0.35s ease, filter 0.35s ease;
        }
        .file-card:hover .file-icon { transform: scale(1.1) rotate(-3deg); filter: brightness(1.15); }
        .file-icon.type-pdf { background: rgba(255, 120, 50, 0.15); border: 1px solid rgba(255, 120, 50, 0.35); color: #ff7c3f; }
        .file-icon.type-doc { background: rgba(30, 144, 255, 0.15); border: 1px solid rgba(30, 144, 255, 0.35); color: #4da6ff; }
        .file-icon.type-other { background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); color: var(--accent-gold); }
        .file-info { flex: 1; min-width: 0; }
        .file-name {
            display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-main);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 3px;
        }
        .file-type-label {
            display: block; font-family: 'JetBrains Mono', monospace;
            font-size: 0.68rem; color: var(--text-dim); text-transform: uppercase;
            letter-spacing: 1.5px; font-weight: 600;
        }
        .file-arrow { color: var(--accent-gold); opacity: 0; font-size: 0.9rem; flex-shrink: 0; transition: opacity 0.25s ease, transform 0.25s ease; }
        .file-card:hover .file-arrow { opacity: 1; transform: translateX(3px); }

        /* ════════════════════════════════════════════════════════
           LINKS
           ════════════════════════════════════════════════════════ */
        .article-links { margin-bottom: 40px; }
        .links-embed-list { display: flex; flex-direction: column; gap: 20px; }
        .link-embed-frame {
            position: relative; width: 100%; border-radius: 14px; overflow: hidden;
            border: 1px solid var(--glass-border); background: #000;
            box-shadow: 0 10px 36px rgba(0,0,0,0.55); transition: border-color 2.5s ease-in-out;
        }
        .link-embed-frame.aspect-video { aspect-ratio: 16 / 9; }
        .link-embed-frame.aspect-twitter { aspect-ratio: unset; min-height: 220px; background: transparent; }
        .link-embed-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; display: block; }
        .link-embed-frame.aspect-twitter iframe { position: static; width: 100%; height: auto; min-height: 220px; }
        .link-embed-frame.aspect-audio { aspect-ratio: unset; height: 152px; background: transparent; }
        .link-embed-frame.aspect-audio iframe { height: 152px; }
        .link-embed-frame.aspect-spotify-large { aspect-ratio: unset; height: 380px; background: transparent; }
        .link-embed-frame.aspect-spotify-large iframe { height: 380px; }

        .link-plain-card {
            display: flex; align-items: center; gap: 16px; padding: 18px 22px;
            background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 14px;
            text-decoration: none; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            transition: border-color 0.3s ease, transform 0.35s cubic-bezier(0.25,1,0.5,1), box-shadow 0.35s ease, background 2.5s ease-in-out;
            overflow: hidden;
        }
        .link-plain-card:hover { border-color: var(--glass-border-hover); transform: translateY(-3px); box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 0 10px var(--accent-gold-dim); }
        .link-plain-icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: var(--accent-gold-dim); border: 1px solid var(--accent-gold-line); color: var(--accent-gold);
            display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0;
            transition: transform 0.3s ease, filter 0.3s ease;
        }
        .link-plain-card:hover .link-plain-icon { transform: scale(1.1) rotate(-4deg); filter: brightness(1.2); }
        .link-plain-text { flex: 1; min-width: 0; }
        .link-plain-label {
            display: block; font-size: 0.85rem; font-weight: 600; color: var(--text-main);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-bottom: 3px;
        }
        .link-plain-url {
            display: block; font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
            color: var(--text-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .link-plain-arrow { color: var(--accent-gold); opacity: 0; font-size: 0.9rem; flex-shrink: 0; transition: opacity 0.25s ease, transform 0.25s ease; }
        .link-plain-card:hover .link-plain-arrow { opacity: 1; transform: translateX(3px); }

        .link-embed-frame::before {
            content: ''; position: absolute; inset: 0;
            background: linear-gradient(90deg, rgba(212,160,80,0.04) 0%, rgba(212,160,80,0.10) 50%, rgba(212,160,80,0.04) 100%);
            background-size: 200% 100%; animation: embedShimmer 1.8s ease-in-out infinite;
            z-index: 0; pointer-events: none; border-radius: inherit;
        }
        .link-embed-frame.loaded::before { display: none; }
        @keyframes embedShimmer { 0% { background-position: 200% center; } 100% { background-position: -200% center; } }

        /* ════════════════════════════════════════════════════════
           FOOTER
           ════════════════════════════════════════════════════════ */
        .sp-footer {
            text-align: center; padding: 40px 24px;
            border-top: 1px solid var(--glass-border);
            color: var(--text-dim); font-size: 0.7rem; letter-spacing: 2px; text-transform: uppercase;
            font-family: 'JetBrains Mono', monospace;
            max-width: 1100px; margin: 60px auto 0;
        }
        .sp-footer a { color: var(--accent-gold); text-decoration: none; }

        @media (max-width: 768px) {
            body { padding: 0 4%; }
            .sp-nav-fixed-wrap { padding: 0 4%; }
            .sp-nav { grid-template-columns: auto 1fr; margin: 0; }
            .sp-nav-center { display: none; }
            .gallery-btn { width: 34px; height: 34px; font-size: 0.85rem; }
            .gallery-slide { max-height: 300px; }
            .gallery-slide img { max-height: 300px; }
            .files-grid { grid-template-columns: 1fr; }
        }

        @media (prefers-reduced-motion: reduce) {
            html { scroll-behavior: auto; }
        }
    </style>
</head>
<body>
    <div class="progress-bar sp-scroll-progress" id="progressBar"></div>

    <div id="bg-canvas"></div>
    <div id="bg-pattern"></div>
    <div id="bg-dots"></div>

    <div class="sp-nav-fixed-wrap">
        <nav class="sp-nav" id="spNav">
            <div class="sp-nav-left">
                <a href="/Adit-Sahai.github.io/Sharan/SharanPage.html#projects" class="sp-nav-home">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                    Back to Projects
                </a>
                <div class="sp-nav-sep"></div>
                <div class="sp-nav-dot"></div>
                <span class="sp-nav-brand">{{ Sharan.AboutPage.Name }}</span>
            </div>

            <div class="sp-nav-center">
                <a href="/Adit-Sahai.github.io/Sharan/SharanPage.html#about" class="sp-nav-link">About</a>
                <a href="/Adit-Sahai.github.io/Sharan/SharanPage.html#projects" class="sp-nav-link">Projects</a>
                <a href="/Adit-Sahai.github.io/Sharan/SharanPage.html#links" class="sp-nav-link">Links</a>
            </div>

            <div class="sp-nav-right">
                <div class="search-wrap" id="searchWrap">
                    <button class="search-toggle" id="searchToggle" aria-label="Search projects" title="Search projects">
                        &#x2315;
                    </button>
                    <div class="search-box" id="searchBox">
                        <input
                            class="search-input"
                            id="searchInput"
                            type="text"
                            placeholder="Search projects…"
                            autocomplete="off"
                            spellcheck="false"
                        />
                        <div class="search-results" id="searchResults"></div>
                    </div>
                </div>
            </div>
        </nav>
    </div>
    <div class="sp-nav-spacer"></div>

    <div class="proj-page">

        <!-- Hero -->
        <div class="proj-hero">
            <div class="proj-status-badge reveal" data-status="{{ statusSlug }}">
                <span class="proj-status-dot"></span>
                {{ statusName }}
            </div>

            <h1 class="proj-hero-title reveal-heading">
                <span class="proj-hero-title-inner">{{ project.Title }}</span>
            </h1>

            <div class="article-hero-meta reveal">
                {% if catName and catName != "undefined" and catName != "" %}
                <span class="category">{{ catName }}</span>
                <span class="meta-dot"></span>
                {% endif %}
                {% if project.ReadTime %}
                <span class="read-time">{{ project.ReadTime }} min read</span>
                <span class="meta-dot"></span>
                {% endif %}
                <span class="date">{{ project.StartedDate }}</span>
                {% if project.LastUpdated %}
                <span class="meta-dot"></span>
                <span class="date">Updated {{ project.LastUpdated }}</span>
                {% endif %}
            </div>

            <div class="article-title-rule reveal scale-in"><span>✦</span></div>
            <p class="article-lead reveal blur-in">{{ project.Description | safe }}</p>
        </div>

        <div class="article-divider reveal">
            <div class="article-divider-icon">· · ·</div>
        </div>

        <!-- ══ IMAGE GALLERY ══════════════════════════════════════ -->
        {% if project.Pics and project.Pics.length > 0 %}
        <div class="article-gallery reveal scale-in" id="galleryWrap">
            <div class="media-section-label">
                <span>📷</span>
                <span>Images</span>
            </div>
            <div class="gallery-viewport{% if project.Pics.length === 1 %} single{% endif %}" id="galleryViewport">
                <div class="gallery-track" id="galleryTrack">
                    {% for pic in project.Pics %}
                    <div class="gallery-slide" data-index="{{ loop.index0 }}">
                        <img
                            src="/Adit-Sahai.github.io{{ pic }}"
                            alt="{{ project.Title }} — image {{ loop.index }}"
                            loading="{{ 'eager' if loop.first else 'lazy' }}"
                        >
                    </div>
                    {% endfor %}
                </div>

                <button class="gallery-btn gallery-btn-prev" id="galleryPrev" aria-label="Previous image">&#8592;</button>
                <button class="gallery-btn gallery-btn-next" id="galleryNext" aria-label="Next image">&#8594;</button>

                <div class="gallery-counter" id="galleryCounter">
                    1 / {{ project.Pics.length }}
                </div>
            </div>

            {% if project.Pics.length > 1 %}
            <div class="gallery-dots" id="galleryDots">
                {% for pic in project.Pics %}
                <button
                    class="gallery-dot{% if loop.first %} active{% endif %}"
                    data-dot="{{ loop.index0 }}"
                    aria-label="Go to image {{ loop.index }}"
                ></button>
                {% endfor %}
            </div>
            {% endif %}
        </div>

        <div class="gallery-lightbox" id="galleryLightbox" role="dialog" aria-label="Image lightbox">
            <button class="gallery-lightbox-close" id="lightboxClose" aria-label="Close">&#x2715;</button>
            <img id="lightboxImg" src="" alt="">
        </div>
        {% endif %}

        <!-- ══ VIDEO / AUDIO FILES ════════════════════════════════ -->
        {%- set videoFiles = [] -%}
        {%- set audioFiles = [] -%}
        {%- set docFiles = [] -%}
        {%- if project.Files -%}
            {%- for file in project.Files -%}
                {%- set ext = file | lower -%}
                {%- if '.mp4' in ext or '.webm' in ext or '.ogg' in ext or '.mov' in ext -%}
                    {%- set videoFiles = (videoFiles.push(file), videoFiles) -%}
                {%- elif '.mp3' in ext or '.wav' in ext or '.m4a' in ext or '.aac' in ext or '.flac' in ext -%}
                    {%- set audioFiles = (audioFiles.push(file), audioFiles) -%}
                {%- else -%}
                    {%- set docFiles = (docFiles.push(file), docFiles) -%}
                {%- endif -%}
            {%- endfor -%}
        {%- endif -%}

        {% if videoFiles.length > 0 %}
        <div class="article-video-embed reveal">
            <div class="media-section-label">
                <span>🎬</span>
                <span>Video{{ 's' if videoFiles.length > 1 }}</span>
            </div>
            {% for vf in videoFiles %}
            <div class="video-embed-wrap" style="{{ 'margin-bottom:14px;' if not loop.last }}">
                <video controls preload="metadata" playsinline>
                    <source src="/Adit-Sahai.github.io{{ vf }}" type="video/{{ vf.split('.')[-1] | lower | replace('mov','quicktime') }}">
                    Your browser doesn't support the video tag.
                </video>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if audioFiles.length > 0 %}
        <div class="reveal">
            <div class="media-section-label">
                <span>🎧</span>
                <span>Audio{{ 's' if audioFiles.length > 1 }}</span>
            </div>
            <div class="audio-player-wrap">
                {% for af in audioFiles %}
                <div class="audio-player-item">
                    <audio controls preload="metadata" style="flex:1;">
                        <source src="/Adit-Sahai.github.io{{ af }}" type="audio/{{ af.split('.')[-1] | lower }}">
                        Your browser doesn't support the audio element.
                    </audio>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Body -->
        <div class="article-body-card reveal scale-in">
            <div class="article-body">
                {{ project.Body | safe }}
            </div>
        </div>

        <!-- ══ DOCUMENTS & OTHER FILES ════════════════════════════ -->
        {% if docFiles.length > 0 %}
        <div class="article-files reveal">
            <div class="media-section-label">
                <span>📎</span>
                <span>Attachments</span>
            </div>
            <div class="files-grid">
                {% for df in docFiles %}
                {%- set ext = df.split('.') | last | lower -%}
                {%- set isPdf = ext === 'pdf' -%}
                {%- set isDoc = ext in ['doc','docx','odt','pages','txt','rtf','xls','xlsx','csv','ppt','pptx'] -%}
                <a
                    href="/Adit-Sahai.github.io{{ df }}"
                    class="file-card link-card reveal"
                    style="transition-delay: {{ loop.index0 * 60 }}ms"
                    target="_blank"
                    rel="noopener noreferrer"
                    download
                >
                    <div class="file-icon {% if isPdf %}type-pdf{% elif isDoc %}type-doc{% else %}type-other{% endif %}">
                        {% if isPdf %}📄
                        {% elif ext in ['doc','docx','odt','pages','txt','rtf'] %}📝
                        {% elif ext in ['xls','xlsx','csv'] %}📊
                        {% elif ext in ['ppt','pptx'] %}📋
                        {% elif ext in ['zip','rar','7z','tar','gz'] %}🗜️
                        {% else %}📎{% endif %}
                    </div>
                    <div class="file-info">
                        <span class="file-name">{{ df.split('/') | last }}</span>
                        <span class="file-type-label">{{ ext | upper }}</span>
                    </div>
                    <span class="file-arrow">↓</span>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- ══ LINKS ════════════════════════════════════════════ -->
        {% if project.Links and project.Links.length > 0 %}
        <div class="article-links reveal" id="projectLinks">
            <div class="media-section-label">
                <span>🔗</span>
                <span>Links</span>
            </div>
            <div class="links-embed-list" id="linksEmbedList">
                {% for link in project.Links %}
                <div class="link-embed-item reveal" style="transition-delay: {{ loop.index0 * 80 }}ms" data-url="{{ link }}"></div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- ── Likes ─────────────────────────────────────────── -->
        {% if project.Likes %}
        <div class="interactions-row reveal scale-in" id="likesSection">
            <button class="like-btn" id="likeBtn">
                <span class="like-heart" id="likeHeart">♡</span>
                <span id="likeCount">—</span>
            </button>
        </div>
        {% endif %}

        <!-- ── Comments ──────────────────────────────────────── -->
        {% if project.Comments %}
        <section class="comments-section reveal" id="commentsSection">
            <div class="comments-header">
                <h3 class="comments-title">Discussion</h3>
                <span class="comments-count" id="commentsCount"></span>
            </div>

            <div class="comment-form-card reveal blur-in">
                <div class="comment-form-fields">
                    <input
                        type="text"
                        id="commentName"
                        class="comment-input"
                        placeholder="Your name"
                        maxlength="60"
                        autocomplete="name"
                    />
                    <textarea
                        id="commentBody"
                        class="comment-textarea"
                        placeholder="Share your thoughts…"
                        maxlength="1200"
                        rows="4"
                    ></textarea>
                </div>
                <div class="comment-form-footer">
                    <span class="comment-char-count" id="charCount">0 / 1200</span>
                    <button class="comment-submit-btn" id="submitBtn">
                        Post Comment
                    </button>
                </div>
                <p class="comment-error" id="commentError"></p>
            </div>

            <div id="commentsList" class="comments-list">
                <div class="comments-loading" id="commentsLoading">
                    <span class="loading-dot"></span>
                    <span class="loading-dot"></span>
                    <span class="loading-dot"></span>
                </div>
            </div>
        </section>
        {% endif %}

    </div>

    <footer class="sp-footer">
        &copy; 2026 {{ Sharan.AboutPage.Name }} &nbsp;·&nbsp; Part of <a href="/Adit-Sahai.github.io/index.html">A&amp;S</a>
    </footer>

    <script src="/Adit-Sahai.github.io/MainCode/script.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {

        function escHtml(s) {
            return String(s || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function formatDate(iso) {
            return new Date(iso).toLocaleDateString('en-US', {
                year: 'numeric', month: 'short', day: 'numeric'
            });
        }

        // ── Fixed nav scroll state ──────────────────────────────
        (function () {
            const nav = document.getElementById('spNav');
            if (!nav) return;
            let lastScrolled = false;
            function onScroll() {
                const scrolled = window.scrollY > 12;
                if (scrolled !== lastScrolled) {
                    nav.classList.toggle('is-scrolled', scrolled);
                    lastScrolled = scrolled;
                }
            }
            window.addEventListener('scroll', onScroll, { passive: true });
            onScroll();
        })();

        // ── Reading / scroll progress ───────────────────────────
        const bar = document.getElementById('progressBar');
        if (bar) {
            window.addEventListener('scroll', () => {
                const docH = document.documentElement.scrollHeight - window.innerHeight;
                bar.style.width = (docH > 0 ? (window.scrollY / docH) * 100 : 0) + '%';
            }, { passive: true });
        }

        // ── Config ────────────────────────────────────────────────
        const SUPABASE_URL = 'https://mpeqripywqiotselpyut.supabase.co';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1wZXFyaXB5d3Fpb3RzZWxweXV0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEzMTE4MzUsImV4cCI6MjA5Njg4NzgzNX0.1lTHIY3M1xk5FmnTC2YMbSMNpi7vhWDuGGXUSNkwkm8';
        const PROJECT_ID  = '{{ project.Title | slug }}';

        async function sb(path, opts = {}) {
            const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
                headers: {
                    'apikey':        SUPABASE_KEY,
                    'Authorization': `Bearer ${SUPABASE_KEY}`,
                    'Content-Type':  'application/json',
                    'Prefer':        opts.prefer || '',
                    ...opts.headers
                },
                method: opts.method || 'GET',
                body:   opts.body ? JSON.stringify(opts.body) : undefined
            });
            if (!res.ok) throw new Error(await res.text());
            const text = await res.text();
            return text ? JSON.parse(text) : null;
        }

        // ══════════════════════════════════════════════════════════
        // IMAGE GALLERY
        // ══════════════════════════════════════════════════════════
        (function initGallery() {
            const track     = document.getElementById('galleryTrack');
            const viewport  = document.getElementById('galleryViewport');
            const prevBtn   = document.getElementById('galleryPrev');
            const nextBtn   = document.getElementById('galleryNext');
            const counter   = document.getElementById('galleryCounter');
            const dotsWrap  = document.getElementById('galleryDots');
            const lightbox  = document.getElementById('galleryLightbox');
            const lbImg     = document.getElementById('lightboxImg');
            const lbClose   = document.getElementById('lightboxClose');

            if (!track) return;

            const slides = track.querySelectorAll('.gallery-slide');
            const total  = slides.length;
            let   current = 0;

            function openLightbox(src, alt) {
                lbImg.src = src; lbImg.alt = alt;
                lightbox.classList.add('open');
                document.body.style.overflow = 'hidden';
            }
            function closeLightbox() {
                lightbox.classList.remove('open');
                document.body.style.overflow = '';
            }

            slides.forEach(slide => {
                slide.addEventListener('click', () => {
                    const img = slide.querySelector('img');
                    if (img) openLightbox(img.src, img.alt);
                });
            });
            lbClose  && lbClose.addEventListener('click', closeLightbox);
            lightbox && lightbox.addEventListener('click', e => { if (e.target === lightbox) closeLightbox(); });

            if (total <= 1) return;

            function goTo(idx) {
                current = (idx + total) % total;
                track.style.transform = `translateX(-${current * 100}%)`;
                if (counter) counter.textContent = `${current + 1} / ${total}`;
                if (dotsWrap) {
                    dotsWrap.querySelectorAll('.gallery-dot').forEach((dot, i) => {
                        dot.classList.toggle('active', i === current);
                    });
                }
            }

            prevBtn && prevBtn.addEventListener('click', () => goTo(current - 1));
            nextBtn && nextBtn.addEventListener('click', () => goTo(current + 1));

            if (dotsWrap) {
                dotsWrap.querySelectorAll('.gallery-dot').forEach(dot => {
                    dot.addEventListener('click', () => goTo(parseInt(dot.dataset.dot)));
                });
            }

            let touchStartX = 0;
            viewport && viewport.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
            viewport && viewport.addEventListener('touchend', e => {
                const delta = e.changedTouches[0].clientX - touchStartX;
                if (Math.abs(delta) > 40) goTo(current + (delta < 0 ? 1 : -1));
            });

            document.addEventListener('keydown', e => {
                if (lightbox && lightbox.classList.contains('open')) {
                    if (e.key === 'ArrowLeft')  goTo(current - 1);
                    if (e.key === 'ArrowRight') goTo(current + 1);
                    if (e.key === 'Escape')     closeLightbox();
                }
            });
        })();

        // ══════════════════════════════════════════════════════════
        // PROJECT LIKES
        // ══════════════════════════════════════════════════════════
        const LIKE_KEY = `likedProject:${PROJECT_ID}`;
        const likeBtn = document.getElementById('likeBtn');
        const likeCountEl = document.getElementById('likeCount');

        async function loadLikes() {
            if (!likeBtn) return;
            try {
                const all = await sb(`project_likes?project_id=eq.${PROJECT_ID}&select=id`);
                setLikeCount(all.length);
                if (localStorage.getItem(LIKE_KEY)) activateLikeBtn();
                likeBtn.addEventListener('click', toggleLike);
            } catch (e) { console.warn('Likes unavailable', e); }
        }

        function setLikeCount(n) {
            if (likeCountEl) likeCountEl.textContent = n === 1 ? '1 like' : `${n} likes`;
        }
        function activateLikeBtn() {
            likeBtn.classList.add('liked');
            document.getElementById('likeHeart').textContent = '♥';
        }
        function deactivateLikeBtn() {
            likeBtn.classList.remove('liked');
            document.getElementById('likeHeart').textContent = '♡';
        }

        async function toggleLike() {
            likeBtn.disabled = true;
            try {
                const liked = localStorage.getItem(LIKE_KEY);
                if (!liked) {
                    const fp = crypto.randomUUID();
                    await sb('project_likes', {
                        method: 'POST',
                        prefer: 'return=minimal',
                        body:   { project_id: PROJECT_ID, fingerprint: fp }
                    });
                    localStorage.setItem(LIKE_KEY, fp);
                    activateLikeBtn();
                } else {
                    await sb(`project_likes?project_id=eq.${PROJECT_ID}&fingerprint=eq.${liked}`, { method: 'DELETE' });
                    localStorage.removeItem(LIKE_KEY);
                    deactivateLikeBtn();
                }
                const all = await sb(`project_likes?project_id=eq.${PROJECT_ID}&select=id`);
                setLikeCount(all.length);
            } catch (e) { console.warn('Like failed', e); }
            likeBtn.disabled = false;
        }

        // ══════════════════════════════════════════════════════════
        // COMMENTS
        // ══════════════════════════════════════════════════════════
        let commentLikeCounts = {};

        function getOwnerFp(commentId) { return localStorage.getItem(`comment_owner:${commentId}`); }
        function getCommentLikeFp(commentId) { return localStorage.getItem(`comment_liked:${commentId}`); }

        function renderComment(c) {
            const isOwner    = !!getOwnerFp(c.id);
            const isLiked    = !!getCommentLikeFp(c.id);
            const likeCount  = commentLikeCounts[c.id] || 0;

            const div = document.createElement('div');
            div.className  = 'comment-item';
            div.dataset.id = c.id;

            div.innerHTML = `
                <div class="comment-top-row">
                    <div class="comment-avatar">${escHtml(c.name).trim().charAt(0).toUpperCase()}</div>
                    <div class="comment-content">
                        <div class="comment-meta-row">
                            <span class="comment-author">${escHtml(c.name)}</span>
                            <span class="comment-date">${formatDate(c.created_at)}</span>
                        </div>
                        <p class="comment-text">${escHtml(c.body)}</p>
                        <div class="comment-actions">
                            <button class="comment-like-btn ${isLiked ? 'liked' : ''}" data-comment-id="${c.id}">
                                <span class="clheart">${isLiked ? '♥' : '♡'}</span>
                                <span class="cl-count">${likeCount > 0 ? likeCount : ''}</span>
                            </button>
                            ${isOwner ? `<button class="comment-delete-btn" data-comment-id="${c.id}">Delete</button>` : ''}
                        </div>
                    </div>
                </div>
            `;
            return div;
        }

        async function loadCommentLikes(commentIds) {
            if (!commentIds.length) return;
            try {
                const ids = commentIds.map(id => `"${id}"`).join(',');
                const rows = await sb(`project_comment_likes?comment_id=in.(${ids})&select=comment_id`);
                rows.forEach(r => { commentLikeCounts[r.comment_id] = (commentLikeCounts[r.comment_id] || 0) + 1; });
            } catch (e) { console.warn('Comment likes unavailable', e); }
        }

        async function toggleCommentLike(btn) {
            const commentId = btn.getAttribute('data-comment-id');
            btn.disabled    = true;
            const fp        = getCommentLikeFp(commentId);

            try {
                if (!fp) {
                    const newFp = crypto.randomUUID();
                    await sb('project_comment_likes', {
                        method: 'POST',
                        prefer: 'return=minimal',
                        body:   { comment_id: commentId, fingerprint: newFp }
                    });
                    localStorage.setItem(`comment_liked:${commentId}`, newFp);
                    btn.classList.add('liked');
                    btn.querySelector('.clheart').textContent = '♥';
                    commentLikeCounts[commentId] = (commentLikeCounts[commentId] || 0) + 1;
                } else {
                    await sb(`project_comment_likes?comment_id=eq.${commentId}&fingerprint=eq.${fp}`, { method: 'DELETE' });
                    localStorage.removeItem(`comment_liked:${commentId}`);
                    btn.classList.remove('liked');
                    btn.querySelector('.clheart').textContent = '♡';
                    commentLikeCounts[commentId] = Math.max(0, (commentLikeCounts[commentId] || 1) - 1);
                }

                const count    = commentLikeCounts[commentId];
                const countEl  = btn.querySelector('.cl-count');
                countEl.textContent = count > 0 ? count : '';
            } catch (e) { console.warn('Comment like failed', e); }

            btn.disabled = false;
        }

        async function deleteComment(btn) {
            const commentId = btn.getAttribute('data-comment-id');
            const fp        = getOwnerFp(commentId);
            if (!fp) return;
            if (!confirm('Delete your comment? This cannot be undone.')) return;

            btn.disabled = true;
            try {
                await sb(`project_comments?id=eq.${commentId}&fingerprint=eq.${fp}`, { method: 'DELETE' });

                const item = document.querySelector(`.comment-item[data-id="${commentId}"]`);
                if (item) {
                    item.style.opacity    = '0';
                    item.style.transform  = 'translateY(-8px)';
                    item.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                    setTimeout(() => item.remove(), 320);
                }
                localStorage.removeItem(`comment_owner:${commentId}`);

                const countEl = document.getElementById('commentsCount');
                if (countEl) {
                    const cur  = parseInt(countEl.textContent) || 0;
                    const next = Math.max(0, cur - 1);
                    countEl.textContent = next === 0 ? '' : next === 1 ? '1 comment' : `${next} comments`;
                }
            } catch (e) {
                console.warn('Delete failed', e);
                btn.disabled = false;
            }
        }

        async function loadComments() {
            const list   = document.getElementById('commentsList');
            const loader = document.getElementById('commentsLoading');
            if (!list) return;

            try {
                const data = await sb(
                    `project_comments?project_id=eq.${PROJECT_ID}&order=created_at.desc&select=id,name,body,created_at,fingerprint`
                );

                const ids = data.map(c => c.id);
                await loadCommentLikes(ids);

                if (loader) loader.remove();
                const countEl = document.getElementById('commentsCount');
                if (countEl) {
                    countEl.textContent = data.length === 0 ? '' :
                                          data.length === 1 ? '1 comment' : `${data.length} comments`;
                }

                if (data.length === 0) {
                    list.innerHTML = '<p class="no-comments">No comments yet — be the first to share your thoughts.</p>';
                } else {
                    data.forEach(c => list.appendChild(renderComment(c)));
                }

                list.addEventListener('click', (e) => {
                    const likeBtn = e.target.closest('.comment-like-btn');
                    if (likeBtn) toggleCommentLike(likeBtn);
                    const deleteBtn = e.target.closest('.comment-delete-btn');
                    if (deleteBtn) deleteComment(deleteBtn);
                });

            } catch (e) {
                if (loader) loader.textContent = 'Could not load comments.';
                console.warn('Comments unavailable', e);
            }
        }

        async function submitComment() {
            const nameEl = document.getElementById('commentName');
            const bodyEl = document.getElementById('commentBody');
            const errEl  = document.getElementById('commentError');
            const btn    = document.getElementById('submitBtn');
            if (!btn) return;

            errEl.textContent = '';
            const name = nameEl.value.trim();
            const body = bodyEl.value.trim();

            if (!name) { errEl.textContent = 'Please enter your name.'; return; }
            if (!body) { errEl.textContent = 'Please write something before posting.'; return; }
            if (body.length < 3) { errEl.textContent = 'Comment is too short.'; return; }

            btn.disabled    = true;
            btn.textContent = 'Posting…';

            try {
                const fp = crypto.randomUUID();
                const result = await sb('project_comments', {
                    method:  'POST',
                    prefer:  'return=representation',
                    headers: { 'Prefer': 'return=representation' },
                    body:    { project_id: PROJECT_ID, name, body, fingerprint: fp }
                });

                const newComment = Array.isArray(result) ? result[0] : result;
                if (newComment?.id) {
                    localStorage.setItem(`comment_owner:${newComment.id}`, fp);
                }

                nameEl.value = '';
                bodyEl.value = '';
                const charCountEl = document.getElementById('charCount');
                if (charCountEl) charCountEl.textContent = '0 / 1200';

                const list  = document.getElementById('commentsList');
                const noMsg = list.querySelector('.no-comments');
                if (noMsg) noMsg.remove();

                const fakeComment = {
                    id:         newComment?.id || crypto.randomUUID(),
                    name, body,
                    created_at: new Date().toISOString()
                };
                list.insertBefore(renderComment(fakeComment), list.firstChild);

                const countEl = document.getElementById('commentsCount');
                if (countEl) {
                    const cur  = parseInt(countEl.textContent) || 0;
                    const next = cur + 1;
                    countEl.textContent = next === 1 ? '1 comment' : `${next} comments`;
                }
            } catch (e) {
                errEl.textContent = 'Failed to post comment. Please try again.';
                console.warn('Submit failed', e);
            }
            btn.disabled    = false;
            btn.textContent = 'Post Comment';
        }

        const bodyTextarea = document.getElementById('commentBody');
        if (bodyTextarea) {
            bodyTextarea.addEventListener('input', () => {
                const charCountEl = document.getElementById('charCount');
                if (charCountEl) charCountEl.textContent = `${bodyTextarea.value.length} / 1200`;
            });
        }

        const submitBtnTrigger = document.getElementById('submitBtn');
        if (submitBtnTrigger) submitBtnTrigger.addEventListener('click', submitComment);

        // ══════════════════════════════════════════════════════════
        // PROJECT SEARCH
        // ══════════════════════════════════════════════════════════
        const ALL_PROJECTS = [
            {% for p in Sharan.Projects %}
            {% if p.Published %}
            {% if p.Category and p.Category.name %}{% set pCatRaw = p.Category.name %}{% else %}{% set pCatRaw = p.Category | string %}{% endif %}
            {% set pCatName = pCatRaw | replace("_data/Sharan/Projectcategories/","") | replace("_data/Sharan/ProjectCategories/","") | replace(".json","") | replace("-"," ") | trim %}
            {
                title:    {{ (p.Title | default("")) | dump | safe }},
                category: {{ (pCatName | default("")) | dump | safe }},
                slug:     {{ (p.Title | default("") | slug) | dump | safe }},
                excerpt:  {{ (p.Description | default("")) | striptags | dump | safe }}
            },
            {% endif %}
            {% endfor %}
        ];

        function initSearch() {
            const toggle     = document.getElementById('searchToggle');
            const box        = document.getElementById('searchBox');
            const input      = document.getElementById('searchInput');
            const results    = document.getElementById('searchResults');
            const searchWrap = document.getElementById('searchWrap');

            if (!toggle || !box || !input || !results || !searchWrap) return;

            toggle.addEventListener('click', e => {
                e.stopPropagation();
                const isOpen = box.classList.toggle('open');
                if (isOpen) input.focus();
                else { input.value = ''; results.innerHTML = ''; }
            });

            document.addEventListener('click', e => {
                if (!searchWrap.contains(e.target)) {
                    box.classList.remove('open');
                    input.value = '';
                    results.innerHTML = '';
                }
            });

            input.addEventListener('input', () => {
                const q = input.value.trim().toLowerCase();
                results.innerHTML = '';
                if (!q) return;

                const likedSlugs = new Set();
                for (let i = 0; i < localStorage.length; i++) {
                    const key = localStorage.key(i);
                    if (key && key.startsWith('likedProject:')) likedSlugs.add(key.slice(13));
                }

                const matches = ALL_PROJECTS.filter(p =>
                    p.title.toLowerCase().includes(q) ||
                    p.excerpt.toLowerCase().includes(q) ||
                    p.category.toLowerCase().includes(q)
                ).slice(0, 6);

                if (!matches.length) {
                    results.innerHTML = '<span class="search-no-results">No projects found.</span>';
                    return;
                }

                matches.forEach(p => {
                    const link     = document.createElement('a');
                    link.className = 'search-result-item';
                    link.href      = `/Adit-Sahai.github.io/Sharan/projects/${p.slug}/`;
                    const likedTag = likedSlugs.has(p.slug) ? ' <span style="color:var(--accent-gold)">♥</span>' : '';
                    link.innerHTML = `<strong>${escHtml(p.title)}${likedTag}</strong><span class="s-cat">${escHtml(p.category)}</span>`;
                    results.appendChild(link);
                });
            });

            input.addEventListener('keydown', e => {
                if (e.key === 'Escape') {
                    box.classList.remove('open');
                    input.value = '';
                    results.innerHTML = '';
                }
            });
        }

        // ── Init ──────────────────────────────────────────────────
        if (document.getElementById('likesSection')) loadLikes();
        if (document.getElementById('commentsSection')) loadComments();
        initSearch();
        initLinks();
    });

    // ══════════════════════════════════════════════════════════════
    // LINK AUTO-DETECTION & EMBED ENGINE (same as article pages)
    // ══════════════════════════════════════════════════════════════
    function initLinks() {
        const items = document.querySelectorAll('.link-embed-item[data-url]');
        if (!items.length) return;

        let twitterScriptLoaded = false;

        items.forEach(item => {
            const raw = (item.dataset.url || '').trim();
            if (!raw) return;

            let url;
            try { url = new URL(raw); }
            catch (_) { item.appendChild(makePlainCard(raw, raw)); return; }

            const host = url.hostname.replace('www.', '').toLowerCase();
            const path = url.pathname;

            if (host === 'youtube.com' || host === 'youtu.be' || host === 'm.youtube.com') {
                let vid = null;
                if (host === 'youtu.be') {
                    vid = path.slice(1).split('?')[0];
                } else {
                    vid = url.searchParams.get('v');
                    if (!vid && path.startsWith('/shorts/')) vid = path.split('/shorts/')[1].split('/')[0];
                    if (!vid && path.startsWith('/embed/'))  vid = path.split('/embed/')[1].split('/')[0];
                }
                if (vid) {
                    const start = url.searchParams.get('t') || url.searchParams.get('start') || '';
                    const src   = `https://www.youtube-nocookie.com/embed/${vid}?rel=0&modestbranding=1${start ? '&start=' + parseInt(start) : ''}`;
                    item.appendChild(makeIframe(src, 'aspect-video', 'YouTube video'));
                    return;
                }
            }

            if (host === 'vimeo.com' || host === 'player.vimeo.com') {
                const match = path.match(/(\d{5,})/);
                if (match) {
                    const src = `https://player.vimeo.com/video/${match[1]}?title=0&byline=0&portrait=0`;
                    item.appendChild(makeIframe(src, 'aspect-video', 'Vimeo video'));
                    return;
                }
            }

            if (host === 'open.spotify.com') {
                const embedPath = path.replace(/^\/(track|album|playlist|episode|show|artist)/, '/embed/$1');
                const src       = `https://open.spotify.com${embedPath}?utm_source=generator&theme=0`;
                const isPlaylist = path.includes('/playlist/') || path.includes('/album/');
                item.appendChild(makeIframe(src, isPlaylist ? 'aspect-spotify-large' : 'aspect-audio', 'Spotify player'));
                return;
            }

            if (host === 'soundcloud.com') {
                const encoded = encodeURIComponent(raw);
                const src     = `https://w.soundcloud.com/player/?url=${encoded}&color=%23d4a050&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false`;
                item.appendChild(makeIframe(src, 'aspect-audio', 'SoundCloud player'));
                return;
            }

            if (host === 'twitter.com' || host === 'x.com') {
                const tweetMatch = path.match(/\/status\/(\d+)/);
                if (tweetMatch) {
                    const wrap = document.createElement('div');
                    wrap.className = 'link-embed-frame aspect-twitter loaded';
                    wrap.style.cssText = 'background:transparent;border:1px solid var(--glass-border);border-radius:14px;overflow:hidden;padding:12px;';

                    const blockquote = document.createElement('blockquote');
                    blockquote.className = 'twitter-tweet';
                    blockquote.setAttribute('data-theme', 'dark');
                    blockquote.innerHTML = `<a href="${raw}"></a>`;
                    wrap.appendChild(blockquote);
                    item.appendChild(wrap);

                    if (!twitterScriptLoaded) {
                        twitterScriptLoaded = true;
                        const s = document.createElement('script');
                        s.src   = 'https://platform.twitter.com/widgets.js';
                        s.async = true;
                        document.head.appendChild(s);
                    }
                    return;
                }
            }

            if (host === 'maps.google.com' || (host === 'google.com' && path.startsWith('/maps'))) {
                item.appendChild(makePlainCard(raw, 'Google Maps', '🗺️'));
                return;
            }

            const ext = path.split('.').pop().toLowerCase().split('?')[0];
            if (['mp4', 'webm', 'ogg', 'mov'].includes(ext)) {
                const wrap = document.createElement('div');
                wrap.className = 'video-embed-wrap loaded';
                wrap.style.cssText = 'border-radius:14px;overflow:hidden;border:1px solid var(--glass-border);';
                const vid = document.createElement('video');
                vid.controls = true; vid.preload = 'metadata';
                vid.setAttribute('playsinline', '');
                vid.style.width = '100%'; vid.style.display = 'block';
                const src = document.createElement('source');
                src.src = raw; src.type = `video/${ext === 'mov' ? 'quicktime' : ext}`;
                vid.appendChild(src); wrap.appendChild(vid);
                item.appendChild(wrap);
                return;
            }

            if (['mp3', 'wav', 'm4a', 'aac', 'flac', 'opus'].includes(ext)) {
                const wrap = document.createElement('div');
                wrap.className = 'audio-player-item loaded';
                const aud = document.createElement('audio');
                aud.controls = true; aud.preload = 'metadata'; aud.style.flex = '1';
                const src = document.createElement('source');
                src.src = raw; src.type = `audio/${ext}`;
                aud.appendChild(src); wrap.appendChild(aud);
                item.appendChild(wrap);
                return;
            }

            item.appendChild(makePlainCard(raw, url.hostname.replace('www.', '')));
        });

        function makeIframe(src, aspectClass, title) {
            const wrap = document.createElement('div');
            wrap.className = `link-embed-frame ${aspectClass}`;
            const iframe = document.createElement('iframe');
            iframe.src   = src;
            iframe.title = title;
            iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
            iframe.setAttribute('allowfullscreen', '');
            iframe.setAttribute('loading', 'lazy');
            iframe.addEventListener('load', () => wrap.classList.add('loaded'));
            wrap.appendChild(iframe);
            return wrap;
        }

        function makePlainCard(href, label, icon) {
            let hostname = label;
            try { hostname = label || new URL(href).hostname.replace('www.', ''); } catch(_) {}
            const iconChar = icon || guessIcon(href);

            const a = document.createElement('a');
            a.href = href; a.target = '_blank'; a.rel = 'noopener noreferrer';
            a.className = 'link-plain-card';
            a.innerHTML = `
                <div class="link-plain-icon">${iconChar}</div>
                <div class="link-plain-text">
                    <span class="link-plain-label">${escHtmlInline(hostname)}</span>
                    <span class="link-plain-url">${escHtmlInline(href)}</span>
                </div>
                <span class="link-plain-arrow">→</span>
            `;
            return a;
        }

        function guessIcon(url) {
            const u = url.toLowerCase();
            if (u.includes('github'))    return '🐙';
            if (u.includes('reddit'))    return '🔴';
            if (u.includes('medium'))    return '📝';
            if (u.includes('substack'))  return '📬';
            if (u.includes('linkedin'))  return '💼';
            if (u.includes('instagram')) return '📸';
            if (u.includes('tiktok'))    return '🎵';
            if (u.includes('facebook'))  return '👍';
            if (u.includes('notion'))    return '🗒️';
            if (u.includes('docs.google')) return '📄';
            if (u.includes('arxiv') || u.includes('.pdf')) return '📜';
            return '🔗';
        }

        function escHtmlInline(s) {
            return String(s || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }
    }
</script>
</body>
