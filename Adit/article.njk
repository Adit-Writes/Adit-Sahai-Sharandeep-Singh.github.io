---
pagination:
  data: Adit.Articles
  size: 1
  alias: article
permalink: "/Adit/articles/{{ article.Title | slug }}/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ article.Title }} — The Sahai Analogy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/Adit-Sahai-Sharandeep-Singh.github.io/MainCode/style.css">

    <style>
        /* ════════════════════════════════════════════════════════════
           IMAGE GALLERY
           ════════════════════════════════════════════════════════════ */

        .article-gallery {
            margin-bottom: 40px;
            position: relative;
        }

        .media-section-label {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 18px;
            color: var(--accent-gold);
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 4px;
            opacity: 0.85;
        }

        .media-section-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--accent-gold-line);
        }

        .gallery-viewport {
            position: relative;
            overflow: hidden;
            border-radius: 16px;
            border: 1px solid var(--glass-border);
            background: rgba(3, 7, 18, 0.85);
            box-shadow: 0 12px 40px rgba(0,0,0,0.55);
            transition: border-color 2.5s ease-in-out;
        }

        .gallery-track {
            display: flex;
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            will-change: transform;
        }

        .gallery-slide {
            flex: 0 0 100%;
            position: relative;
            max-height: 520px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(3, 7, 18, 0.95);
        }

        .gallery-slide img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            max-height: 520px;
            display: block;
            transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), filter 0.4s ease;
            filter: brightness(0.96) saturate(0.95);
        }

        .gallery-slide:hover img {
            transform: scale(1.015);
            filter: brightness(1) saturate(1);
        }

        .gallery-slide::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                linear-gradient(to top, rgba(2,6,23,0.55) 0%, transparent 35%),
                linear-gradient(to bottom, rgba(2,6,23,0.25) 0%, transparent 25%);
            z-index: 1;
            pointer-events: none;
        }

        .gallery-counter {
            position: absolute;
            bottom: 16px;
            right: 20px;
            z-index: 3;
            font-size: 0.7rem;
            font-weight: 600;
            color: rgba(230, 247, 255, 0.75);
            background: rgba(6, 15, 30, 0.7);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(0, 180, 200, 0.2);
            border-radius: 100px;
            padding: 4px 12px;
            letter-spacing: 1px;
            pointer-events: none;
        }

        .gallery-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            z-index: 4;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 1px solid var(--glass-border-hover);
            background: rgba(6, 15, 30, 0.75);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            color: var(--text-main);
            font-size: 1rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition:
                background   0.25s ease,
                border-color 0.25s ease,
                transform    0.25s ease,
                opacity      0.25s ease;
            opacity: 0;
        }

        .gallery-viewport:hover .gallery-btn {
            opacity: 1;
        }

        .gallery-btn:hover {
            background:    var(--accent-gold);
            border-color:  var(--accent-gold);
            color:         #000;
            transform:     translateY(-50%) scale(1.08);
        }

        .gallery-btn-prev { left: 14px; }
        .gallery-btn-next { right: 14px; }

        .gallery-viewport.single .gallery-btn,
        .gallery-viewport.single .gallery-counter,
        .gallery-dots { display: none; }
        .gallery-viewport.single .gallery-counter { display: none; }

        .gallery-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 14px;
        }

        .gallery-dot {
            width:  7px;
            height: 7px;
            border-radius: 50%;
            background: var(--glass-border-hover);
            border: none;
            cursor: pointer;
            padding: 0;
            transition: background 0.25s ease, transform 0.25s ease, width 0.3s ease;
        }

        .gallery-dot.active {
            background: var(--accent-gold);
            width: 22px;
            border-radius: 4px;
            transform: scaleY(1.1);
        }

        .gallery-lightbox {
            position: fixed;
            inset: 0;
            z-index: 9000;
            background: rgba(2, 6, 23, 0.95);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .gallery-lightbox.open {
            opacity: 1;
            pointer-events: all;
        }

        .gallery-lightbox img {
            max-width: 90vw;
            max-height: 88vh;
            object-fit: contain;
            border-radius: 10px;
            box-shadow: 0 24px 80px rgba(0,0,0,0.8);
            transform: scale(0.94);
            transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .gallery-lightbox.open img {
            transform: scale(1);
        }

        .gallery-lightbox-close {
            position: fixed;
            top: 24px;
            right: 28px;
            background: rgba(6, 15, 30, 0.75);
            border: 1px solid var(--glass-border-hover);
            color: var(--text-main);
            font-size: 1.25rem;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background 0.25s ease, transform 0.25s ease;
            z-index: 9001;
        }

        .gallery-lightbox-close:hover {
            background: var(--accent-gold);
            color: #000;
            border-color: var(--accent-gold);
            transform: scale(1.1) rotate(90deg);
        }

        .gallery-slide {
            cursor: zoom-in;
        }

        /* ════════════════════════════════════════════════════════════
           FILES SECTION
           ════════════════════════════════════════════════════════════ */

        .article-files {
            margin-bottom: 40px;
        }

        .files-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 12px;
        }

        .file-card {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 20px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 14px;
            text-decoration: none;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            transition:
                background     2.5s ease-in-out,
                border-color   0.3s ease,
                transform      0.35s cubic-bezier(0.25, 1, 0.5, 1),
                box-shadow     0.35s ease;
            position: relative;
            overflow: hidden;
        }

        .file-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                105deg,
                transparent 40%,
                rgba(0, 180, 216, 0.06) 50%,
                transparent 60%
            );
            background-size: 200% 100%;
            background-position: 200% center;
            transition: background-position 0.6s ease;
            pointer-events: none;
        }

        .file-card:hover::before {
            background-position: -200% center;
        }

        .file-card:hover {
            border-color: var(--glass-border-hover);
            transform: translateY(-3px) scale(1.01);
            box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 0 12px var(--accent-gold-dim);
        }

        .file-icon {
            width: 42px;
            height: 42px;
            border-radius: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 1.2rem;
            font-weight: 700;
            line-height: 1;
            transition: transform 0.35s ease, filter 0.35s ease;
        }

        .file-card:hover .file-icon {
            transform: scale(1.1) rotate(-3deg);
            filter: brightness(1.15);
        }

        .file-icon.type-video {
            background: rgba(255, 60, 80, 0.15);
            border: 1px solid rgba(255, 60, 80, 0.35);
            color: #ff4d6d;
        }

        .file-icon.type-audio {
            background: rgba(138, 43, 226, 0.15);
            border: 1px solid rgba(138, 43, 226, 0.35);
            color: #b66fff;
        }

        .file-icon.type-pdf {
            background: rgba(255, 120, 50, 0.15);
            border: 1px solid rgba(255, 120, 50, 0.35);
            color: #ff7c3f;
        }

        .file-icon.type-doc {
            background: rgba(30, 144, 255, 0.15);
            border: 1px solid rgba(30, 144, 255, 0.35);
            color: #4da6ff;
        }

        .file-icon.type-other {
            background: var(--accent-gold-dim);
            border: 1px solid var(--accent-gold-line);
            color: var(--accent-gold);
        }

        .file-info {
            flex: 1;
            min-width: 0;
        }

        .file-name {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-main);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 3px;
            transition: color 1.5s ease-in-out;
        }

        .file-type-label {
            display: block;
            font-size: 0.68rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 600;
            transition: color 1.5s ease-in-out;
        }

        .file-arrow {
            color: var(--accent-gold);
            opacity: 0;
            font-size: 0.9rem;
            flex-shrink: 0;
            transition: opacity 0.25s ease, transform 0.25s ease;
        }

        .file-card:hover .file-arrow {
            opacity: 1;
            transform: translateX(3px);
        }

        .article-video-embed {
            margin-bottom: 40px;
        }

        .video-embed-wrap {
            position: relative;
            width: 100%;
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            background: #000;
            box-shadow: 0 12px 40px rgba(0,0,0,0.6);
            transition: border-color 2.5s ease-in-out;
        }

        .video-embed-wrap video {
            width: 100%;
            display: block;
            max-height: 480px;
            object-fit: contain;
            background: #000;
        }

        .audio-player-wrap {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 40px;
        }

        .audio-player-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 20px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            transition: border-color 2.5s ease-in-out;
        }

        .audio-player-item audio {
            flex: 1;
            height: 36px;
            accent-color: var(--accent-gold);
            outline: none;
        }

        /* ════════════════════════════════════════════════════════════
           LINKS SECTION
           ════════════════════════════════════════════════════════════ */

        .article-links {
            margin-bottom: 40px;
        }

        .links-embed-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .link-embed-frame {
            position: relative;
            width: 100%;
            border-radius: 14px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            background: #000;
            box-shadow: 0 10px 36px rgba(0,0,0,0.55);
            transition: border-color 2.5s ease-in-out;
        }

        .link-embed-frame.aspect-video {
            aspect-ratio: 16 / 9;
        }

        .link-embed-frame.aspect-twitter {
            aspect-ratio: unset;
            min-height: 220px;
            background: transparent;
        }

        .link-embed-frame iframe {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: none;
            display: block;
        }

        .link-embed-frame.aspect-twitter iframe {
            position: static;
            width: 100%;
            height: auto;
            min-height: 220px;
        }

        .link-embed-frame.aspect-audio {
            aspect-ratio: unset;
            height: 152px;
            background: transparent;
        }

        .link-embed-frame.aspect-audio iframe {
            height: 152px;
        }

        .link-embed-frame.aspect-spotify-large {
            aspect-ratio: unset;
            height: 380px;
            background: transparent;
        }

        .link-embed-frame.aspect-spotify-large iframe {
            height: 380px;
        }

        .link-plain-card {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 18px 22px;
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            border-radius: 14px;
            text-decoration: none;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            transition:
                border-color   0.3s ease,
                transform      0.35s cubic-bezier(0.25,1,0.5,1),
                box-shadow     0.35s ease,
                background     2.5s ease-in-out;
            overflow: hidden;
        }

        .link-plain-card:hover {
            border-color: var(--glass-border-hover);
            transform: translateY(-3px);
            box-shadow: 0 12px 32px rgba(0,0,0,0.5), 0 0 10px var(--accent-gold-dim);
        }

        .link-plain-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            background: var(--accent-gold-dim);
            border: 1px solid var(--accent-gold-line);
            color: var(--accent-gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
            transition: transform 0.3s ease, filter 0.3s ease;
        }

        .link-plain-card:hover .link-plain-icon {
            transform: scale(1.1) rotate(-4deg);
            filter: brightness(1.2);
        }

        .link-plain-text {
            flex: 1;
            min-width: 0;
        }

        .link-plain-label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-main);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 3px;
            transition: color 1.5s ease-in-out;
        }

        .link-plain-url {
            display: block;
            font-size: 0.7rem;
            color: var(--text-dim);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            transition: color 1.5s ease-in-out;
        }

        .link-plain-arrow {
            color: var(--accent-gold);
            opacity: 0;
            font-size: 0.9rem;
            flex-shrink: 0;
            transition: opacity 0.25s ease, transform 0.25s ease;
        }

        .link-plain-card:hover .link-plain-arrow {
            opacity: 1;
            transform: translateX(3px);
        }

        .link-embed-frame::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(
                90deg,
                rgba(0,180,216,0.04) 0%,
                rgba(0,180,216,0.10) 50%,
                rgba(0,180,216,0.04) 100%
            );
            background-size: 200% 100%;
            animation: embedShimmer 1.8s ease-in-out infinite;
            z-index: 0;
            pointer-events: none;
            border-radius: inherit;
        }

        .link-embed-frame.loaded::before {
            display: none;
        }

        @keyframes embedShimmer {
            0%   { background-position: 200% center; }
            100% { background-position: -200% center; }
        }

        @media (max-width: 640px) {
            .gallery-btn { width: 34px; height: 34px; font-size: 0.85rem; }
            .gallery-slide { max-height: 300px; }
            .gallery-slide img { max-height: 300px; }
            .files-grid { grid-template-columns: 1fr; }
        }

        /* ════════════════════════════════════════════════════════════
   ARTICLE BODY — RICH READABLE TEXT
   ════════════════════════════════════════════════════════════ */

.article-body-card {
    background: linear-gradient(
        135deg,
        rgba(8, 20, 40, 0.92) 0%,
        rgba(4, 12, 28, 0.96) 50%,
        rgba(6, 16, 35, 0.92) 100%
    );
    border: 1px solid rgba(0, 180, 216, 0.18);
    border-radius: 20px;
    padding: 52px 60px;
    box-shadow:
        0 0 0 1px rgba(0,0,0,0.4),
        0 24px 64px rgba(0,0,0,0.6),
        inset 0 1px 0 rgba(255,255,255,0.04),
        0 0 80px rgba(0, 100, 160, 0.06);
    position: relative;
    overflow: hidden;
}

/* Subtle corner accent */
.article-body-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 220px;
    height: 220px;
    background: radial-gradient(
        circle at top left,
        rgba(0, 180, 216, 0.07) 0%,
        transparent 70%
    );
    pointer-events: none;
}

.article-body-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 180px;
    height: 180px;
    background: radial-gradient(
        circle at bottom right,
        rgba(200, 160, 60, 0.05) 0%,
        transparent 70%
    );
    pointer-events: none;
}

/* ── Core body text ── */
.article-body {
    color: rgba(220, 232, 248, 0.92);
    font-size: 1.08rem;
    line-height: 1.82;
    font-weight: 400;
    letter-spacing: 0.012em;
}

/* Paragraphs */
.article-body p {
    margin: 0 0 1.6em 0;
    color: rgba(215, 228, 245, 0.90);
}

.article-body p:last-child {
    margin-bottom: 0;
}

/* Headings inside body */
.article-body h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.55rem;
    font-weight: 700;
    color: rgba(240, 248, 255, 0.97);
    margin: 2.4em 0 0.7em;
    letter-spacing: -0.01em;
    line-height: 1.3;
}

.article-body h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    font-weight: 600;
    color: rgba(235, 245, 255, 0.93);
    margin: 2em 0 0.6em;
}

/* First paragraph drop cap style */
.article-body > p:first-child::first-letter {
    font-family: 'Playfair Display', serif;
    font-size: 3.4em;
    font-weight: 800;
    float: left;
    line-height: 0.78;
    margin: 0.06em 0.1em 0 0;
    color: var(--accent-gold);
    text-shadow: 0 0 24px rgba(200, 160, 60, 0.35);
}

/* Strong / bold */
.article-body strong, .article-body b {
    color: rgba(240, 250, 255, 0.98);
    font-weight: 600;
}

/* Italic / emphasis */
.article-body em, .article-body i {
    color: rgba(180, 215, 245, 0.88);
    font-style: italic;
}

/* Blockquote */
.article-body blockquote {
    margin: 2em 0;
    padding: 20px 28px;
    border-left: 3px solid var(--accent-gold);
    background: rgba(200, 160, 60, 0.05);
    border-radius: 0 10px 10px 0;
    color: rgba(230, 240, 255, 0.85);
    font-style: italic;
    font-size: 1.05rem;
}

/* Lists */
.article-body ul, .article-body ol {
    margin: 0 0 1.6em 1.4em;
    color: rgba(210, 228, 245, 0.88);
}

.article-body li {
    margin-bottom: 0.45em;
    line-height: 1.75;
}

/* Links */
.article-body a {
    color: #4db8d8;
    text-decoration: underline;
    text-decoration-color: rgba(77, 184, 216, 0.35);
    text-underline-offset: 3px;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
}
.article-body a:hover {
    color: #7dd4ec;
    text-decoration-color: rgba(125, 212, 236, 0.7);
}

/* Horizontal rule */
.article-body hr {
    border: none;
    border-top: 1px solid rgba(0, 180, 216, 0.2);
    margin: 2.5em 0;
}

@media (max-width: 768px) {
    .article-body-card { padding: 32px 24px; }
    .article-body { font-size: 1rem; line-height: 1.75; }
    .article-body > p:first-child::first-letter { font-size: 2.8em; }
}

        /* ════════════════════════════════════════════════════════════
           COMMENT THREADING + HOST BADGE
           ════════════════════════════════════════════════════════════ */

        .host-badge {
          display: inline-flex; align-items: center; gap: 4px;
          font-size: 0.6rem; font-weight: 700;
          letter-spacing: 1.5px; text-transform: uppercase;
          color: #04121f; background: var(--accent-gold);
          padding: 3px 9px; border-radius: 6px;
          box-shadow: 0 0 10px var(--accent-gold-dim);
        }
        .host-badge::before { content: '✦'; font-size: 0.62rem; }

        .comment-item.is-host-comment {
          background: linear-gradient(90deg, var(--accent-gold-dim), transparent 40%);
          border-radius: 10px; padding-left: 12px; margin-left: -12px;
        }

        .comment-node { display: block; }
        .comments-list > .comment-node { padding-bottom: 22px; margin-bottom: 22px; border-bottom: 1px solid rgba(255,255,255,0.06); }
        .comments-list > .comment-node:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

        .comment-reply-btn {
          font-size: 0.78rem; color: rgba(220, 232, 248, 0.5);
          background: none; border: none; cursor: pointer;
          padding: 6px 12px; border-radius: 8px; letter-spacing: 0.5px;
          transition: color 0.2s ease, background 0.2s ease;
        }
        .comment-reply-btn:hover { color: #4db8d8; background: rgba(77, 184, 216, 0.1); }

        .reply-compose {
          margin-top: 14px; margin-left: 52px;
          background: rgba(255,255,255,0.04); border: 1px solid var(--glass-border);
          border-radius: 10px; padding: 14px; display: none;
        }
        .reply-compose.open { display: block; animation: replyOpen 0.25s ease; }
        @keyframes replyOpen { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }
        .reply-compose input, .reply-compose textarea {
          width: 100%; background: transparent; border: none; color: var(--text-main);
          font-family: 'Inter', sans-serif; outline: none;
        }
        .reply-compose input {
          border-bottom: 1px solid var(--glass-border);
          font-size: 0.82rem; font-weight: 600; padding: 4px 0 6px; margin-bottom: 10px;
        }
        .reply-compose input::placeholder, .reply-compose textarea::placeholder { color: rgba(255,255,255,0.4); }
        .reply-compose textarea { font-size: 0.86rem; line-height: 1.6; resize: none; min-height: 50px; }
        .reply-compose-footer { display: flex; justify-content: flex-end; gap: 10px; margin-top: 10px; }
        .reply-compose-cancel {
          font-size: 0.72rem; color: rgba(255,255,255,0.5);
          background: none; border: none; cursor: pointer; letter-spacing: 1px;
        }
        .reply-compose-submit {
          font-size: 0.74rem; font-weight: 700;
          letter-spacing: 1px; text-transform: uppercase; color: #04121f; background: var(--accent-gold);
          border: none; border-radius: 100px; padding: 7px 18px; cursor: pointer; transition: background 0.2s ease;
        }
        .reply-compose-submit:hover { background: #e0b060; }

        .replies-wrap {
          margin-left: 52px; margin-top: 14px;
          border-left: 2px solid var(--accent-gold-line);
          padding-left: 20px;
          display: flex; flex-direction: column; gap: 18px;
        }
        .replies-toggle {
          display: flex; align-items: center; gap: 6px; margin-left: 52px; margin-top: 12px;
          font-size: 0.74rem; color: var(--accent-gold);
          background: none; border: none; cursor: pointer; letter-spacing: 1px; opacity: 0.9;
        }
        .replies-toggle:hover { opacity: 1; }
        .replies-toggle-arrow { transition: transform 0.25s ease; display: inline-block; }
        .replies-toggle.expanded .replies-toggle-arrow { transform: rotate(90deg); }
    </style>
</head>
<body>
    <!-- Reading progress bar -->
    <div class="progress-bar" id="progressBar"></div>

    <!-- Background layers -->
    <div id="bg-canvas"></div>
    <div id="bg-pattern"></div>
    <div id="bg-dots"></div>

    <nav class="navbar glass-card">
        <div class="logo">A.S.</div>
        <div class="navbar-divider"></div>
        <div class="nav-links">
            <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Adit/AditPage">About</a>
            <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Adit/AditPage#books">Books</a>
            <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Adit/AditPage#articles">Articles</a>
        </div>
        <!-- Search -->
        <div class="search-wrap" id="searchWrap">
            <button class="search-toggle" id="searchToggle" aria-label="Search articles" title="Search articles">
                &#x2315;
            </button>
            <div class="search-box" id="searchBox">
                <input
                    class="search-input"
                    id="searchInput"
                    type="text"
                    placeholder="Search articles…"
                    autocomplete="off"
                    spellcheck="false"
                />
                <div class="search-results" id="searchResults"></div>
            </div>
        </div>
    </nav>

    {# article.Topic is already resolved to the category display name by _data/Adit/Articles.js #}

    <div class="article-page">
        <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Adit/AditPage#articles" class="back-link reveal">← Back to Essays</a>

        <!-- Hero -->
        <article class="article-hero">
            <div class="article-hero-meta reveal">
                <span class="category">{{ article.Topic }}</span>
                <span class="meta-dot"></span>
                <span class="read-time">{{ article.ReadTime }} min read</span>
                <span class="meta-dot"></span>
                <span class="date">{{ article.ReleaseDate }}</span>
                {% if article.LastUpdated %}
                <span class="meta-dot"></span>
                <span class="date">Updated {{ article.LastUpdated }}</span>
                {% endif %}
            </div>
            <h1 class="article-main-title reveal-heading">{{ article.Title }}</h1>
            <div class="article-title-rule reveal scale-in"><span>✦</span></div>
            <p class="article-lead reveal blur-in">{{ article.Description | safe }}</p>
        </article>

        <!-- Section break -->
        <div class="article-divider reveal">
            <div class="article-divider-icon">· · ·</div>
        </div>

        <!-- ══ IMAGE GALLERY ══════════════════════════════════════ -->
        {% if article.Pics and article.Pics.length > 0 %}
        <div class="article-gallery reveal scale-in" id="articleGallery">
            <div class="media-section-label">
                <span>📷</span>
                <span>Images</span>
            </div>
            <div class="gallery-viewport{% if article.Pics.length === 1 %} single{% endif %}" id="galleryViewport">
                <div class="gallery-track" id="galleryTrack">
                    {% for pic in article.Pics %}
                    <div class="gallery-slide" data-index="{{ loop.index0 }}">
                        <img
                            src="/Adit-Sahai-Sharandeep-Singh.github.io{{ pic }}"
                            alt="{{ article.Title }} — image {{ loop.index }}"
                            loading="{{ 'eager' if loop.first else 'lazy' }}"
                        >
                    </div>
                    {% endfor %}
                </div>

                <button class="gallery-btn gallery-btn-prev" id="galleryPrev" aria-label="Previous image">&#8592;</button>
                <button class="gallery-btn gallery-btn-next" id="galleryNext" aria-label="Next image">&#8594;</button>

                <div class="gallery-counter" id="galleryCounter">
                    1 / {{ article.Pics.length }}
                </div>
            </div>

            {% if article.Pics.length > 1 %}
            <div class="gallery-dots" id="galleryDots">
                {% for pic in article.Pics %}
                <button
                    class="gallery-dot{% if loop.first %} active{% endif %}"
                    data-dot="{{ loop.index0 }}"
                    aria-label="Go to image {{ loop.index }}"
                ></button>
                {% endfor %}
            </div>
            {% endif %}
        </div>

        <div class="gallery-lightbox" id="galleryLightbox" role="dialog" aria-label="Image lightbox">
            <button class="gallery-lightbox-close" id="lightboxClose" aria-label="Close">&#x2715;</button>
            <img id="lightboxImg" src="" alt="">
        </div>
        {% endif %}

        <!-- ══ VIDEO FILES ════════════════════════════════════════ -->
        {%- set videoFiles = [] -%}
        {%- set audioFiles = [] -%}
        {%- set docFiles = [] -%}
        {%- if article.Files -%}
            {%- for file in article.Files -%}
                {%- set ext = file | lower -%}
                {%- if '.mp4' in ext or '.webm' in ext or '.ogg' in ext or '.mov' in ext -%}
                    {%- set videoFiles = (videoFiles.push(file), videoFiles) -%}
                {%- elif '.mp3' in ext or '.wav' in ext or '.m4a' in ext or '.aac' in ext or '.flac' in ext -%}
                    {%- set audioFiles = (audioFiles.push(file), audioFiles) -%}
                {%- else -%}
                    {%- set docFiles = (docFiles.push(file), docFiles) -%}
                {%- endif -%}
            {%- endfor -%}
        {%- endif -%}

        {% if videoFiles.length > 0 %}
        <div class="article-video-embed reveal">
            <div class="media-section-label">
                <span>🎬</span>
                <span>Video{{ 's' if videoFiles.length > 1 }}</span>
            </div>
            {% for vf in videoFiles %}
            <div class="video-embed-wrap" style="{{ 'margin-bottom:14px;' if not loop.last }}">
                <video controls preload="metadata" playsinline>
                    <source src="/Adit-Sahai-Sharandeep-Singh.github.io{{ vf }}" type="video/{{ vf.split('.')[-1] | lower | replace('mov','quicktime') }}">
                    Your browser doesn't support the video tag.
                </video>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if audioFiles.length > 0 %}
        <div class="reveal">
            <div class="media-section-label">
                <span>🎧</span>
                <span>Audio{{ 's' if audioFiles.length > 1 }}</span>
            </div>
            <div class="audio-player-wrap">
                {% for af in audioFiles %}
                <div class="audio-player-item">
                    <audio controls preload="metadata" style="flex:1;">
                        <source src="/Adit-Sahai-Sharandeep-Singh.github.io{{ af }}" type="audio/{{ af.split('.')[-1] | lower }}">
                        Your browser doesn't support the audio element.
                    </audio>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Body -->
        <div class="article-body-card reveal scale-in">
            <div class="article-body">
                {{ article.Body | safe }}
            </div>
        </div>

        <!-- ══ DOCUMENTS & OTHER FILES ════════════════════════════ -->
        {% if docFiles.length > 0 %}
        <div class="article-files reveal">
            <div class="media-section-label">
                <span>📎</span>
                <span>Attachments</span>
            </div>
            <div class="files-grid">
                {% for df in docFiles %}
                {%- set ext = df.split('.') | last | lower -%}
                {%- set isPdf    = ext === 'pdf' -%}
                {%- set isDoc    = ext in ['doc','docx','odt','pages','txt','rtf','xls','xlsx','csv','ppt','pptx'] -%}
                
                    href="/Adit-Sahai-Sharandeep-Singh.github.io{{ df }}"
                    class="file-card link-card reveal"
                    style="transition-delay: {{ loop.index0 * 60 }}ms"
                    target="_blank"
                    rel="noopener noreferrer"
                    download
                >
                    <div class="file-icon {% if isPdf %}type-pdf{% elif isDoc %}type-doc{% else %}type-other{% endif %}">
                        {% if isPdf %}📄
                        {% elif ext in ['doc','docx','odt','pages','txt','rtf'] %}📝
                        {% elif ext in ['xls','xlsx','csv'] %}📊
                        {% elif ext in ['ppt','pptx'] %}📋
                        {% elif ext in ['zip','rar','7z','tar','gz'] %}🗜️
                        {% else %}📎{% endif %}
                    </div>
                    <div class="file-info">
                        <span class="file-name">{{ df.split('/') | last }}</span>
                        <span class="file-type-label">{{ ext | upper }}</span>
                    </div>
                    <span class="file-arrow">↓</span>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- ══ LINKS ════════════════════════════════════════════ -->
        {% if article.Links and article.Links.length > 0 %}
        <div class="article-links reveal" id="articleLinks">
            <div class="media-section-label">
                <span>🔗</span>
                <span>Links</span>
            </div>
            <div class="links-embed-list" id="linksEmbedList">
                {% for link in article.Links %}
                <div class="link-embed-item reveal" style="transition-delay: {{ loop.index0 * 80 }}ms" data-url="{{ link }}"></div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- ── Likes ─────────────────────────────────────────── -->
        {% if article.Likes %}
        <div class="interactions-row reveal scale-in" id="likesSection">
            <button class="like-btn" id="likeBtn">
                <span class="like-heart" id="likeHeart">♡</span>
                <span id="likeCount">—</span>
            </button>
        </div>
        {% endif %}

        <!-- ── Comments ──────────────────────────────────────── -->
        {% if article.Comments %}
        <section class="comments-section reveal" id="commentsSection">
            <div class="comments-header">
                <h3 class="comments-title">Discussion</h3>
                <span class="comments-count" id="commentsCount"></span>
            </div>

            <div class="comment-form-card reveal blur-in">
                <div class="comment-form-fields">
                    <input
                        type="text"
                        id="commentName"
                        class="comment-input"
                        placeholder="Your name"
                        maxlength="60"
                        autocomplete="name"
                    />
                    <textarea
                        id="commentBody"
                        class="comment-textarea"
                        placeholder="Share your thoughts…"
                        maxlength="1200"
                        rows="4"
                    ></textarea>
                </div>
                <div class="comment-form-footer">
                    <span class="comment-char-count" id="charCount">0 / 1200</span>
                    <button class="comment-submit-btn" id="submitBtn">
                        Post Comment
                    </button>
                </div>
                <p class="comment-error" id="commentError"></p>
            </div>

            <div id="commentsList" class="comments-list">
                <div class="comments-loading" id="commentsLoading">
                    <span class="loading-dot"></span>
                    <span class="loading-dot"></span>
                    <span class="loading-dot"></span>
                </div>
            </div>
        </section>
        {% endif %}

        <div class="article-nav-footer reveal">
            <a href="/Adit-Sahai-Sharandeep-Singh.github.io/Adit/AditPage#articles">← View all essays</a>
        </div>
    </div>

    <footer class="footer">
        <p>&copy; 2026 The Sahai Analogy. All rights reserved.</p>
    </footer>

    <script src="/Adit-Sahai-Sharandeep-Singh.github.io/MainCode/script.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {

        function escHtml(s) {
            return String(s || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        }

        function formatDate(iso) {
            return new Date(iso).toLocaleDateString('en-US', {
                year: 'numeric', month: 'short', day: 'numeric'
            });
        }

        // ── Reading progress ──────────────────────────────────────
        const bar = document.getElementById('progressBar');
        if (bar) {
            window.addEventListener('scroll', () => {
                const docH = document.documentElement.scrollHeight - window.innerHeight;
                bar.style.width = (docH > 0 ? (window.scrollY / docH) * 100 : 0) + '%';
            }, { passive: true });
        }

        // ── Config ────────────────────────────────────────────────
        const SUPABASE_URL = 'https://mpeqripywqiotselpyut.supabase.co';
        const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1wZXFyaXB5d3Fpb3RzZWxweXV0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODEzMTE4MzUsImV4cCI6MjA5Njg4NzgzNX0.1lTHIY3M1xk5FmnTC2YMbSMNpi7vhWDuGGXUSNkwkm8';
        const ARTICLE_ID   = '{{ article.Title | slug }}';

        async function sb(path, opts = {}) {
            const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
                headers: {
                    'apikey':        SUPABASE_KEY,
                    'Authorization': `Bearer ${SUPABASE_KEY}`,
                    'Content-Type':  'application/json',
                    'Prefer':        opts.prefer || '',
                    ...opts.headers
                },
                method: opts.method || 'GET',
                body:   opts.body ? JSON.stringify(opts.body) : undefined
            });
            if (!res.ok) throw new Error(await res.text());
            const text = await res.text();
            return text ? JSON.parse(text) : null;
        }

        // ══════════════════════════════════════════════════════════
        // IMAGE GALLERY
        // ══════════════════════════════════════════════════════════
        (function initGallery() {
            const track     = document.getElementById('galleryTrack');
            const viewport  = document.getElementById('galleryViewport');
            const prevBtn   = document.getElementById('galleryPrev');
            const nextBtn   = document.getElementById('galleryNext');
            const counter   = document.getElementById('galleryCounter');
            const dotsWrap  = document.getElementById('galleryDots');
            const lightbox  = document.getElementById('galleryLightbox');
            const lbImg     = document.getElementById('lightboxImg');
            const lbClose   = document.getElementById('lightboxClose');

            if (!track) return;

            const slides = track.querySelectorAll('.gallery-slide');
            const total  = slides.length;
            let   current = 0;

            if (total <= 1) return;

            function goTo(idx) {
                current = (idx + total) % total;
                track.style.transform = `translateX(-${current * 100}%)`;
                if (counter) counter.textContent = `${current + 1} / ${total}`;
                if (dotsWrap) {
                    dotsWrap.querySelectorAll('.gallery-dot').forEach((dot, i) => {
                        dot.classList.toggle('active', i === current);
                    });
                }
            }

            prevBtn && prevBtn.addEventListener('click', () => goTo(current - 1));
            nextBtn && nextBtn.addEventListener('click', () => goTo(current + 1));

            if (dotsWrap) {
                dotsWrap.querySelectorAll('.gallery-dot').forEach(dot => {
                    dot.addEventListener('click', () => goTo(parseInt(dot.dataset.dot)));
                });
            }

            let touchStartX = 0;
            viewport && viewport.addEventListener('touchstart', e => {
                touchStartX = e.touches[0].clientX;
            }, { passive: true });
            viewport && viewport.addEventListener('touchend', e => {
                const delta = e.changedTouches[0].clientX - touchStartX;
                if (Math.abs(delta) > 40) goTo(current + (delta < 0 ? 1 : -1));
            });

            document.addEventListener('keydown', e => {
                if (lightbox && lightbox.classList.contains('open')) {
                    if (e.key === 'ArrowLeft')  goTo(current - 1);
                    if (e.key === 'ArrowRight') goTo(current + 1);
                    if (e.key === 'Escape')     closeLightbox();
                }
            });

            function openLightbox(src, alt) {
                lbImg.src = src;
                lbImg.alt = alt;
                lightbox.classList.add('open');
                document.body.style.overflow = 'hidden';
            }

            function closeLightbox() {
                lightbox.classList.remove('open');
                document.body.style.overflow = '';
            }

            slides.forEach(slide => {
                slide.addEventListener('click', () => {
                    const img = slide.querySelector('img');
                    if (img) openLightbox(img.src, img.alt);
                });
            });

            lbClose  && lbClose.addEventListener('click', closeLightbox);
            lightbox && lightbox.addEventListener('click', e => {
                if (e.target === lightbox) closeLightbox();
            });
        })();

        // ══════════════════════════════════════════════════════════
        // ARTICLE LIKES
        // ══════════════════════════════════════════════════════════
        const LIKE_KEY = `liked:${ARTICLE_ID}`;
        const likeBtn = document.getElementById('likeBtn');
        const likeCountEl = document.getElementById('likeCount');

        async function loadLikes() {
            if (!likeBtn) return;
            try {
                const all = await sb(`article_likes?article_id=eq.${ARTICLE_ID}&select=id`);
                setLikeCount(all.length);
                if (localStorage.getItem(LIKE_KEY)) activateLikeBtn();
                likeBtn.addEventListener('click', toggleLike);
            } catch (e) { console.warn('Likes unavailable', e); }
        }

        function setLikeCount(n) {
            if (likeCountEl) likeCountEl.textContent = n === 1 ? '1 like' : `${n} likes`;
        }

        function activateLikeBtn() {
            likeBtn.classList.add('liked');
            document.getElementById('likeHeart').textContent = '♥';
        }

        function deactivateLikeBtn() {
            likeBtn.classList.remove('liked');
            document.getElementById('likeHeart').textContent = '♡';
        }

        async function toggleLike() {
            likeBtn.disabled = true;
            try {
                const liked = localStorage.getItem(LIKE_KEY);
                if (!liked) {
                    const fp = crypto.randomUUID();
                    await sb('article_likes', {
                        method: 'POST',
                        prefer: 'return=minimal',
                        body:   { article_id: ARTICLE_ID, fingerprint: fp }
                    });
                    localStorage.setItem(LIKE_KEY, fp);
                    activateLikeBtn();
                } else {
                    await sb(`article_likes?article_id=eq.${ARTICLE_ID}&fingerprint=eq.${liked}`, {
                        method: 'DELETE'
                    });
                    localStorage.removeItem(LIKE_KEY);
                    deactivateLikeBtn();
                }
                const all = await sb(`article_likes?article_id=eq.${ARTICLE_ID}&select=id`);
                setLikeCount(all.length);
            } catch (e) { console.warn('Like failed', e); }
            likeBtn.disabled = false;
        }

        // ══════════════════════════════════════════════════════════
        // COMMENTS
        // ══════════════════════════════════════════════════════════
        let commentLikeCounts = {};
        const expandedThreads = new Set();

        function getOwnerFp(commentId) { return localStorage.getItem(`comment_owner:${commentId}`); }
        function getCommentLikeFp(commentId) { return localStorage.getItem(`comment_liked:${commentId}`); }
        function getHostPassphrase() { return localStorage.getItem('hostPassphrase') || null; }

        if (location.search.includes('setuphost')) {
            const p = prompt('Enter host passphrase:');
            if (p) { localStorage.setItem('hostPassphrase', p); alert('Host key saved on this device.'); }
        }

        function countDescendants(id, byParent) {
            const kids = byParent[id] || [];
            let total = kids.length;
            kids.forEach(k => { total += countDescendants(k.id, byParent); });
            return total;
        }

        function renderCommentNode(c, byParent) {
            const isOwner = !!getOwnerFp(c.id) || !!getHostPassphrase();
            const isLiked   = !!getCommentLikeFp(c.id);
            const likeCount = commentLikeCounts[c.id] || 0;

            const node = document.createElement('div');
            node.className = 'comment-node';
            node.dataset.id = c.id;

            const item = document.createElement('div');
            item.className = 'comment-item' + (c.is_host ? ' is-host-comment' : '');
            item.innerHTML = `
                <div class="comment-top-row">
                    <div class="comment-avatar">${escHtml(c.name).trim().charAt(0).toUpperCase()}</div>
                    <div class="comment-content">
                        <div class="comment-meta-row">
                            <span class="comment-author">${escHtml(c.name)}</span>
                            ${c.is_host ? '<span class="host-badge">Host</span>' : ''}
                            <span class="comment-date">${formatDate(c.created_at)}</span>
                        </div>
                        <p class="comment-text">${escHtml(c.body)}</p>
                        <div class="comment-actions">
                            <button class="comment-like-btn ${isLiked ? 'liked' : ''}" data-comment-id="${c.id}">
                                <span class="clheart">${isLiked ? '♥' : '♡'}</span>
                                <span class="cl-count">${likeCount > 0 ? likeCount : ''}</span>
                            </button>
                            <button class="comment-reply-btn" data-comment-id="${c.id}">Reply</button>
                            ${isOwner ? `<button class="comment-delete-btn" data-comment-id="${c.id}">Delete</button>` : ''}
                        </div>
                        <div class="reply-compose" id="reply-compose-${c.id}">
                            <input type="text" class="reply-name" placeholder="Your name" maxlength="60" />
                            <textarea class="reply-body" placeholder="Write a reply…" maxlength="1200" rows="2"></textarea>
                            <div class="reply-compose-footer">
                                <button class="reply-compose-cancel" data-cancel-for="${c.id}">Cancel</button>
                                <button class="reply-compose-submit" data-reply-to="${c.id}">Reply</button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            node.appendChild(item);

            const children = (byParent[c.id] || []).sort((a, b) => new Date(a.created_at) - new Date(b.created_at));
            if (children.length) {
                const key = String(c.id);
                const isOpen = expandedThreads.has(key);
                const totalReplies = countDescendants(c.id, byParent);

                const toggle = document.createElement('button');
                toggle.className = 'replies-toggle' + (isOpen ? ' expanded' : '');
                toggle.innerHTML = `<span class="replies-toggle-arrow">▸</span> ${totalReplies} ${totalReplies === 1 ? 'reply' : 'replies'}`;
                const wrap = document.createElement('div');
                wrap.className = 'replies-wrap';
                wrap.style.display = isOpen ? 'block' : 'none';
                children.forEach(child => wrap.appendChild(renderCommentNode(child, byParent)));

                toggle.addEventListener('click', () => {
                    const open = wrap.style.display !== 'none';
                    wrap.style.display = open ? 'none' : 'block';
                    toggle.classList.toggle('expanded', !open);
                    if (open) { expandedThreads.delete(key); } else { expandedThreads.add(key); }
                });

                node.appendChild(toggle);
                node.appendChild(wrap);
            }

            return node;
        }

        async function loadCommentLikes(commentIds) {
            if (!commentIds.length) return;
            try {
                const ids = commentIds.map(id => `"${id}"`).join(',');
                const rows = await sb(`comment_likes?comment_id=in.(${ids})&select=comment_id`);
                rows.forEach(r => {
                    commentLikeCounts[r.comment_id] = (commentLikeCounts[r.comment_id] || 0) + 1;
                });
            } catch (e) { console.warn('Comment likes unavailable', e); }
        }

        async function toggleCommentLike(btn) {
            const commentId = btn.getAttribute('data-comment-id');
            btn.disabled    = true;
            const fp        = getCommentLikeFp(commentId);

            try {
                if (!fp) {
                    const newFp = crypto.randomUUID();
                    await sb('comment_likes', {
                        method: 'POST',
                        prefer: 'return=minimal',
                        body:   { comment_id: commentId, fingerprint: newFp }
                    });
                    localStorage.setItem(`comment_liked:${commentId}`, newFp);
                    btn.classList.add('liked');
                    btn.querySelector('.clheart').textContent = '♥';
                    commentLikeCounts[commentId] = (commentLikeCounts[commentId] || 0) + 1;
                } else {
                    await sb(`comment_likes?comment_id=eq.${commentId}&fingerprint=eq.${fp}`, {
                        method: 'DELETE'
                    });
                    localStorage.removeItem(`comment_liked:${commentId}`);
                    btn.classList.remove('liked');
                    btn.querySelector('.clheart').textContent = '♡';
                    commentLikeCounts[commentId] = Math.max(0, (commentLikeCounts[commentId] || 1) - 1);
                }

                const count   = commentLikeCounts[commentId];
                const countEl = btn.querySelector('.cl-count');
                countEl.textContent = count > 0 ? count : '';
            } catch (e) { console.warn('Comment like failed', e); }

            btn.disabled = false;
        }

        async function deleteComment(btn) {
    const id = btn.getAttribute('data-comment-id');
    const fp = getOwnerFp(id);
    const isHost = !!getHostPassphrase();
    if ((!fp && !isHost) || !confirm('Delete this comment?')) return;
    btn.disabled = true;
    try {
        const query = fp
          ? `article_comments?id=eq.${id}&fingerprint=eq.${fp}`
          : `article_comments?id=eq.${id}`;
        await sb(query, { method: 'DELETE' });
        localStorage.removeItem(`comment_owner:${id}`);
        loadComments();
    } catch(e) {
        console.warn('Delete failed', e);
        btn.disabled = false;
    }
}

        function updateCommentCount(totalCount) {
            const countEl = document.getElementById('commentsCount');
            if (!countEl) return;
            countEl.textContent = totalCount === 0 ? '' : totalCount === 1 ? '1 comment' : `${totalCount} comments`;
        }

        async function loadComments() {
            const list   = document.getElementById('commentsList');
            const loader = document.getElementById('commentsLoading');
            if (!list) return;

            try {
                const data = await sb(
                    `article_comments?article_id=eq.${ARTICLE_ID}&order=created_at.asc&select=id,name,body,created_at,fingerprint,parent_id,is_host`
                );
                commentLikeCounts = {};
                await loadCommentLikes(data.map(c => c.id));

                const topLevel = data.filter(c => !c.parent_id).sort((a,b) => new Date(b.created_at) - new Date(a.created_at));
                const repliesByParent = {};
                data.filter(c => c.parent_id).forEach(r => {
                    (repliesByParent[r.parent_id] = repliesByParent[r.parent_id] || []).push(r);
                });

                if (loader) loader.remove();
                updateCommentCount(data.length);

                list.innerHTML = '';
                if (!topLevel.length) {
                    list.innerHTML = '<p class="no-comments">No comments yet — be the first to share your thoughts.</p>';
                } else {
                    topLevel.forEach(c => list.appendChild(renderCommentNode(c, repliesByParent)));
                }
            } catch (e) {
                if (loader) loader.textContent = 'Could not load comments.';
                console.warn('Comments unavailable', e);
            }
        }

        async function submitReply(btn) {
            const parentId = String(btn.getAttribute('data-reply-to'));
            const box = document.getElementById(`reply-compose-${parentId}`);
            const nameEl = box.querySelector('.reply-name');
            const bodyEl = box.querySelector('.reply-body');
            const name = nameEl.value.trim();
            const body = bodyEl.value.trim();
            if (!name || !body || body.length < 2) return;

            btn.disabled = true; btn.textContent = '…';
            try {
                const fp = crypto.randomUUID();
                const passphrase = getHostPassphrase();
                const result = await sb('rpc/post_article_comment', {
                    method: 'POST', prefer: 'return=representation',
                    body: { p_article_id: ARTICLE_ID, p_name: name, p_body: body, p_fingerprint: fp, p_parent_id: parentId, p_passphrase: passphrase }
                });
                const nc = Array.isArray(result) ? result[0] : result;
                if (nc?.id) localStorage.setItem(`comment_owner:${nc.id}`, fp);
                box.classList.remove('open');
                nameEl.value = ''; bodyEl.value = '';
                expandedThreads.add(parentId);
                await loadComments();
            } catch (e) { alert('Reply failed — try again'); }
            btn.disabled = false; btn.textContent = 'Reply';
        }

        async function submitComment() {
            const nameEl = document.getElementById('commentName');
            const bodyEl = document.getElementById('commentBody');
            const errEl  = document.getElementById('commentError');
            const btn    = document.getElementById('submitBtn');
            if (!btn) return;

            errEl.textContent = '';
            const name = nameEl.value.trim();
            const body = bodyEl.value.trim();

            if (!name) { errEl.textContent = 'Please enter your name.'; return; }
            if (!body) { errEl.textContent = 'Please write something before posting.'; return; }
            if (body.length < 3) { errEl.textContent = 'Comment is too short.'; return; }

            btn.disabled    = true;
            btn.textContent = 'Posting…';

            try {
                const fp = crypto.randomUUID();
                const passphrase = getHostPassphrase();
                const result = await sb('rpc/post_article_comment', {
                    method: 'POST', prefer: 'return=representation',
                    body: { p_article_id: ARTICLE_ID, p_name: name, p_body: body, p_fingerprint: fp, p_parent_id: null, p_passphrase: passphrase }
                });

                const newComment = Array.isArray(result) ? result[0] : result;
                if (newComment?.id) {
                    localStorage.setItem(`comment_owner:${newComment.id}`, fp);
                }

                nameEl.value = '';
                bodyEl.value = '';
                const charCountEl = document.getElementById('charCount');
                if (charCountEl) charCountEl.textContent = '0 / 1200';

                await loadComments();
            } catch (e) {
                errEl.textContent = 'Failed to post comment. Please try again.';
                console.warn('Submit failed', e);
            }
            btn.disabled    = false;
            btn.textContent = 'Post Comment';
        }

        const bodyTextarea = document.getElementById('commentBody');
        if (bodyTextarea) {
            bodyTextarea.addEventListener('input', () => {
                const charCountEl = document.getElementById('charCount');
                if (charCountEl) {
                    charCountEl.textContent = `${bodyTextarea.value.length} / 1200`;
                }
            });
        }

        const submitBtnTrigger = document.getElementById('submitBtn');
        if (submitBtnTrigger) {
            submitBtnTrigger.addEventListener('click', submitComment);
        }

        const commentsListEl = document.getElementById('commentsList');
        if (commentsListEl) {
            commentsListEl.addEventListener('click', e => {
                const lb = e.target.closest('.comment-like-btn');
                if (lb) toggleCommentLike(lb);
                const db = e.target.closest('.comment-delete-btn');
                if (db) deleteComment(db);
                const rb = e.target.closest('.comment-reply-btn');
                if (rb) {
                    const id = rb.getAttribute('data-comment-id');
                    document.querySelectorAll('.reply-compose.open').forEach(el => { if (el.id !== `reply-compose-${id}`) el.classList.remove('open'); });
                    document.getElementById(`reply-compose-${id}`)?.classList.toggle('open');
                }
                const cb = e.target.closest('.reply-compose-cancel');
                if (cb) document.getElementById(`reply-compose-${cb.getAttribute('data-cancel-for')}`)?.classList.remove('open');
                const sb2 = e.target.closest('.reply-compose-submit');
                if (sb2) submitReply(sb2);
            });
        }

        // ══════════════════════════════════════════════════════════
        // ARTICLE SEARCH
        // ══════════════════════════════════════════════════════════
        const ALL_ARTICLES = [
            {% for a in Adit.Articles %}
            {% if a.Published %}
            {
                title:    {{ (a.Title | default("")) | dump | safe }},
                category: {{ (a.Topic | default("")) | dump | safe }},
                slug:     {{ (a.Title | default("") | slug) | dump | safe }},
                excerpt:  {{ (a.Description | default("")) | striptags | dump | safe }}
            },
            {% endif %}
            {% endfor %}
        ];

        function initSearch() {
            const toggle     = document.getElementById('searchToggle');
            const box        = document.getElementById('searchBox');
            const input      = document.getElementById('searchInput');
            const results    = document.getElementById('searchResults');
            const searchWrap = document.getElementById('searchWrap');

            if (!toggle || !box || !input || !results || !searchWrap) return;

            toggle.addEventListener('click', e => {
                e.stopPropagation();
                const isOpen = box.classList.toggle('open');
                if (isOpen) input.focus();
                else {
                    input.value       = '';
                    results.innerHTML = '';
                }
            });

            document.addEventListener('click', e => {
                if (!searchWrap.contains(e.target)) {
                    box.classList.remove('open');
                    input.value       = '';
                    results.innerHTML = '';
                }
            });

            input.addEventListener('input', () => {
                const q = input.value.trim().toLowerCase();
                results.innerHTML = '';
                if (!q) return;

                const likedSlugs = new Set();
                for (let i = 0; i < localStorage.length; i++) {
                    const key = localStorage.key(i);
                    if (key && key.startsWith('liked:')) likedSlugs.add(key.slice(6));
                }

                const matches = ALL_ARTICLES.filter(a =>
                    a.title.toLowerCase().includes(q) ||
                    a.excerpt.toLowerCase().includes(q) ||
                    a.category.toLowerCase().includes(q)
                ).slice(0, 6);

                if (!matches.length) {
                    results.innerHTML = '<span class="search-no-results">No articles found.</span>';
                    return;
                }

                matches.forEach(a => {
                    const link     = document.createElement('a');
                    link.className = 'search-result-item';
                    link.href      = `/Adit-Sahai-Sharandeep-Singh.github.io/Adit/articles/${a.slug}/`;
                    const likedTag = likedSlugs.has(a.slug) ? ' <span style="color:var(--accent-gold)">♥</span>' : '';
                    link.innerHTML = `<strong>${escHtml(a.title)}${likedTag}</strong><span class="s-cat">${escHtml(a.category)}</span>`;
                    results.appendChild(link);
                });
            });

            input.addEventListener('keydown', e => {
                if (e.key === 'Escape') {
                    box.classList.remove('open');
                    input.value       = '';
                    results.innerHTML = '';
                }
            });
        }

        // ── Init ──────────────────────────────────────────────────
        if (document.getElementById('likesSection')) loadLikes();
        if (document.getElementById('commentsSection')) loadComments();
        initSearch();
        initLinks();
    });

    // ══════════════════════════════════════════════════════════════
    // LINK AUTO-DETECTION & EMBED ENGINE
    // ══════════════════════════════════════════════════════════════

    function initLinks() {
        const items = document.querySelectorAll('.link-embed-item[data-url]');
        if (!items.length) return;

        let twitterScriptLoaded = false;

        items.forEach(item => {
            const raw = (item.dataset.url || '').trim();
            if (!raw) return;

            let url;
            try { url = new URL(raw); }
            catch (_) {
                item.appendChild(makePlainCard(raw, raw));
                return;
            }

            const host = url.hostname.replace('www.', '').toLowerCase();
            const path = url.pathname;

            if (host === 'youtube.com' || host === 'youtu.be' || host === 'm.youtube.com') {
                let vid = null;
                if (host === 'youtu.be') {
                    vid = path.slice(1).split('?')[0];
                } else {
                    vid = url.searchParams.get('v');
                    if (!vid && path.startsWith('/shorts/')) vid = path.split('/shorts/')[1].split('/')[0];
                    if (!vid && path.startsWith('/embed/'))  vid = path.split('/embed/')[1].split('/')[0];
                }
                if (vid) {
                    const start = url.searchParams.get('t') || url.searchParams.get('start') || '';
                    const src   = `https://www.youtube-nocookie.com/embed/${vid}?rel=0&modestbranding=1${start ? '&start=' + parseInt(start) : ''}`;
                    item.appendChild(makeIframe(src, 'aspect-video', 'YouTube video'));
                    return;
                }
            }

            if (host === 'vimeo.com' || host === 'player.vimeo.com') {
                const match = path.match(/(\d{5,})/);
                if (match) {
                    const src = `https://player.vimeo.com/video/${match[1]}?title=0&byline=0&portrait=0`;
                    item.appendChild(makeIframe(src, 'aspect-video', 'Vimeo video'));
                    return;
                }
            }

            if (host === 'open.spotify.com') {
                const embedPath = path.replace(/^\/(track|album|playlist|episode|show|artist)/, '/embed/$1');
                const src       = `https://open.spotify.com${embedPath}?utm_source=generator&theme=0`;
                const isPlaylist = path.includes('/playlist/') || path.includes('/album/');
                item.appendChild(makeIframe(src, isPlaylist ? 'aspect-spotify-large' : 'aspect-audio', 'Spotify player'));
                return;
            }

            if (host === 'soundcloud.com') {
                const encoded = encodeURIComponent(raw);
                const src     = `https://w.soundcloud.com/player/?url=${encoded}&color=%2300b4d8&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false`;
                item.appendChild(makeIframe(src, 'aspect-audio', 'SoundCloud player'));
                return;
            }

            if (host === 'twitter.com' || host === 'x.com') {
                const tweetMatch = path.match(/\/status\/(\d+)/);
                if (tweetMatch) {
                    const wrap = document.createElement('div');
                    wrap.className = 'link-embed-frame aspect-twitter loaded';
                    wrap.style.cssText = 'background:transparent;border:1px solid var(--glass-border);border-radius:14px;overflow:hidden;padding:12px;';

                    const blockquote = document.createElement('blockquote');
                    blockquote.className = 'twitter-tweet';
                    blockquote.setAttribute('data-theme', 'dark');
                    blockquote.innerHTML = `<a href="${raw}"></a>`;
                    wrap.appendChild(blockquote);
                    item.appendChild(wrap);

                    if (!twitterScriptLoaded) {
                        twitterScriptLoaded = true;
                        const s = document.createElement('script');
                        s.src   = 'https://platform.twitter.com/widgets.js';
                        s.async = true;
                        document.head.appendChild(s);
                    }
                    return;
                }
            }

            if (host === 'maps.google.com' || host === 'google.com' && path.startsWith('/maps')) {
                item.appendChild(makePlainCard(raw, 'Google Maps', '🗺️'));
                return;
            }

            const ext = path.split('.').pop().toLowerCase().split('?')[0];
            if (['mp4', 'webm', 'ogg', 'mov'].includes(ext)) {
                const wrap  = document.createElement('div');
                wrap.className = 'video-embed-wrap loaded';
                wrap.style.cssText = 'border-radius:14px;overflow:hidden;border:1px solid var(--glass-border);';
                const vid   = document.createElement('video');
                vid.controls = true;
                vid.preload  = 'metadata';
                vid.setAttribute('playsinline', '');
                vid.style.width = '100%';
                vid.style.display = 'block';
                const src = document.createElement('source');
                src.src  = raw;
                src.type = `video/${ext === 'mov' ? 'quicktime' : ext}`;
                vid.appendChild(src);
                wrap.appendChild(vid);
                item.appendChild(wrap);
                return;
            }

            if (['mp3', 'wav', 'm4a', 'aac', 'flac', 'opus'].includes(ext)) {
                const wrap  = document.createElement('div');
                wrap.className = 'audio-player-item loaded';
                const aud   = document.createElement('audio');
                aud.controls = true;
                aud.preload  = 'metadata';
                aud.style.flex = '1';
                const src = document.createElement('source');
                src.src   = raw;
                src.type  = `audio/${ext}`;
                aud.appendChild(src);
                wrap.appendChild(aud);
                item.appendChild(wrap);
                return;
            }

            item.appendChild(makePlainCard(raw, url.hostname.replace('www.', '')));
        });

        function makeIframe(src, aspectClass, title) {
            const wrap   = document.createElement('div');
            wrap.className = `link-embed-frame ${aspectClass}`;

            const iframe = document.createElement('iframe');
            iframe.src             = src;
            iframe.title           = title;
            iframe.allow           = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
            iframe.setAttribute('allowfullscreen', '');
            iframe.setAttribute('loading', 'lazy');
            iframe.addEventListener('load', () => wrap.classList.add('loaded'));

            wrap.appendChild(iframe);
            return wrap;
        }

        function makePlainCard(href, label, icon) {
            let hostname = label;
            try { hostname = label || new URL(href).hostname.replace('www.', ''); } catch(_) {}

            const iconChar = icon || guessIcon(href);

            const a = document.createElement('a');
            a.href      = href;
            a.target    = '_blank';
            a.rel       = 'noopener noreferrer';
            a.className = 'link-plain-card';
            a.innerHTML = `
                <div class="link-plain-icon">${iconChar}</div>
                <div class="link-plain-text">
                    <span class="link-plain-label">${escHtmlInline(hostname)}</span>
                    <span class="link-plain-url">${escHtmlInline(href)}</span>
                </div>
                <span class="link-plain-arrow">→</span>
            `;
            return a;
        }

        function guessIcon(url) {
            const u = url.toLowerCase();
            if (u.includes('github'))    return '🐙';
            if (u.includes('reddit'))    return '🔴';
            if (u.includes('medium'))    return '📝';
            if (u.includes('substack'))  return '📬';
            if (u.includes('linkedin'))  return '💼';
            if (u.includes('instagram')) return '📸';
            if (u.includes('tiktok'))    return '🎵';
            if (u.includes('facebook'))  return '👍';
            if (u.includes('notion'))    return '🗒️';
            if (u.includes('docs.google')) return '📄';
            if (u.includes('arxiv') || u.includes('.pdf')) return '📜';
            return '🔗';
        }

        function escHtmlInline(s) {
            return String(s || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }
    }
</script>
</body>
